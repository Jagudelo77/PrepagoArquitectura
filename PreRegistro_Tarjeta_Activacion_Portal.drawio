          <mxGeometry x="580" y="100" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="st_active_desc" value="Tarjeta operativa.&#xa;Puede transaccionar." style="text;html=1;fontSize=9;fontStyle=2;fontColor=#1B5E20;align=center;" parent="1" vertex="1">
          <mxGeometry x="585" y="160" width="210" height="30" as="geometry" />
        </mxCell>
        <mxCell id="e_prereg_active" value="TH completa onboarding&#xa;en Portal + asigna PIN" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#388E3C;fontSize=9;fontStyle=1;" parent="1" source="st_prereg" target="st_active" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Flecha directa: tarjeta adicional -->
        <mxCell id="e_start_active" value="Creación&#xa;(tarjeta adicional,&#xa;cliente onboardeado)" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#388E3C;fontSize=9;fontStyle=1;dashed=1;dashPattern=8 4;" parent="1" source="st_start" target="st_active" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="95" y="370" />
              <mxPoint x="690" y="370" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- BLOCKED -->
        <mxCell id="st_blocked" value="BLOCKED" style="rounded=1;whiteSpace=wrap;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=14;fontStyle=1;fontColor=#B71C1C;" parent="1" vertex="1">
          <mxGeometry x="580" y="430" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="st_blocked_desc" value="Bloqueada por novedad NM.&#xa;No puede operar." style="text;html=1;fontSize=9;fontStyle=2;fontColor=#B71C1C;align=center;" parent="1" vertex="1">
          <mxGeometry x="585" y="490" width="210" height="30" as="geometry" />
        </mxCell>
        <mxCell id="e_active_blocked" value="Bloqueo (Novedad NM)" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#E53935;fontSize=9;fontStyle=1;" parent="1" source="st_active" target="st_blocked" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="850" y="130" />
              <mxPoint x="850" y="460" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_blocked_active" value="Desbloqueo (Novedad NM)" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#388E3C;fontSize=9;fontStyle=1;" parent="1" source="st_blocked" target="st_active" edge="1">
          <mxGeometry relative="1" as="geometry">
