        <mxCell id="c3_error" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=10;" value="Error: Tarjeta no está&#xa;en estado válido" vertex="1">
