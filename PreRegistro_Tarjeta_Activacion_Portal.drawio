        <mxCell id="e_inactive_end" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#757575;" parent="1" source="st_inactive" target="st_end" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Leyenda -->
        <mxCell id="st_leg_box" value="" style="rounded=1;fillColor=#f5f5f5;strokeColor=#999;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="50" y="820" width="1100" height="140" as="geometry" />
        </mxCell>
        <mxCell id="st_leg_title" value="Resumen de Transiciones" style="text;html=1;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="60" y="825" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="st_leg_content" value="• Creación (1ra tarjeta, cliente nuevo) → PRE_REGISTERED: Pendiente de onboarding en portal&#xa;• Creación (tarjeta adicional, cliente onboardeado) → ACTIVE: Activación directa sin portal (línea punteada)&#xa;• PRE_REGISTERED → ACTIVE: TH completa onboarding en portal + asigna PIN&#xa;• PRE_REGISTERED → EXPIRED: Token vence (72h) y se agotan 3 reintentos automáticos&#xa;• EXPIRED → PRE_REGISTERED: Reenvío manual de SMS con nuevo token&#xa;• ACTIVE → BLOCKED: Novedad no monetaria de bloqueo&#xa;• BLOCKED → ACTIVE: Novedad no monetaria de desbloqueo&#xa;• ACTIVE / BLOCKED → INACTIVE: Reexpedición (nueva tarjeta, esta se desactiva)" style="text;html=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="60" y="848" width="1080" height="105" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="edge-cases" name="3. Casos Borde y Reenvío SMS">
    <mxGraphModel dx="772" dy="547" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ec_title" parent="1" style="text;html=1;fontSize=20;fontStyle=1;align=center;" value="Casos Borde — PreRegistro de Tarjeta" vertex="1">
          <mxGeometry height="35" width="500" x="350" y="20" as="geometry" />
        </mxCell>
        <mxCell id="case1_box" parent="1" style="rounded=1;fillColor=#FFF3E0;strokeColor=#EF6C00;dashed=1;dashPattern=4 4;arcSize=4;" value="" vertex="1">
          <mxGeometry height="300" width="620" x="40" y="80" as="geometry" />
        </mxCell>
        <mxCell id="case1_title" parent="1" style="text;html=1;fontSize=13;fontStyle=1;fontColor=#BF360C;" value="CASO 1: Token Expirado (TH no completó en 72h)" vertex="1">
          <mxGeometry height="22" width="400" x="55" y="88" as="geometry" />
        </mxCell>
        <mxCell id="c1_cron" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="CronJob diario detecta&#xa;tarjetas PRE_REGISTERED&#xa;con token expirado" vertex="1">
          <mxGeometry height="55" width="170" x="61" y="127" as="geometry" />
        </mxCell>
        <mxCell id="c1_check" parent="1" style="rhombus;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" value="¿Intentos&#xa;reenvío &lt; 3?" vertex="1">
          <mxGeometry height="70" width="130" x="280" y="120" as="geometry" />
        </mxCell>
        <mxCell id="e_c1_cron_check" edge="1" parent="1" source="c1_cron" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;" target="c1_check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c1_resend" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" value="Genera nuevo token (72h)&#xa;Reenvía SMS&#xa;Incrementa contador" vertex="1">
          <mxGeometry height="55" width="175" x="463" y="127" as="geometry" />
        </mxCell>
        <mxCell id="e_c1_yes" edge="1" parent="1" source="c1_check" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#388E3C;fontColor=#388E3C;fontStyle=1;fontSize=10;" target="c1_resend" value="Sí">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c1_alert" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=10;" value="Marca tarjeta EXPIRED&#xa;Alerta a la Entidad&#xa;para gestión manual" vertex="1">
          <mxGeometry height="55" width="170" x="260" y="252" as="geometry" />
        </mxCell>
        <mxCell id="e_c1_no" edge="1" parent="1" source="c1_check" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#E53935;fontColor=#E53935;fontStyle=1;fontSize=9;" target="c1_alert" value="No (3 intentos)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c1_note" parent="1" style="shape=note;size=15;fillColor=#FFF3E0;strokeColor=#EF6C00;fontSize=9;fontStyle=2;align=left;spacingLeft=5;" value="⏱ Política de reenvío:&#xa;• Máximo 3 intentos automáticos&#xa;• Cada reenvío = nuevo token 72h&#xa;• Después de 3 → EXPIRED&#xa;• Entidad puede pedir reactivación" vertex="1">
          <mxGeometry height="80" width="185" x="460" y="210" as="geometry" />
        </mxCell>
        <mxCell id="case2_box" parent="1" style="rounded=1;fillColor=#FFEBEE;strokeColor=#E53935;dashed=1;dashPattern=4 4;arcSize=4;" value="" vertex="1">
          <mxGeometry height="300" width="740" x="700" y="80" as="geometry" />
        </mxCell>
        <mxCell id="case2_title" parent="1" style="text;html=1;fontSize=13;fontStyle=1;fontColor=#B71C1C;" value="CASO 2: Transacción con Tarjeta PRE_REGISTERED o EXPIRED" vertex="1">
          <mxGeometry height="22" width="450" x="715" y="88" as="geometry" />
        </mxCell>
        <mxCell id="c2_txn" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Transacción entrante&#xa;(compra, retiro,&#xa;recarga, etc.)" vertex="1">
          <mxGeometry height="55" width="160" x="720" y="135" as="geometry" />
        </mxCell>
        <mxCell id="c2_validate" parent="1" style="rhombus;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" value="Card Validator:&#xa;¿status == ACTIVE?" vertex="1">
