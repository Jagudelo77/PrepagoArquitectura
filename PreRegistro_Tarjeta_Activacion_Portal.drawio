          </mxGeometry>
        </mxCell>
        <!-- INACTIVE -->
        <mxCell id="st_inactive" value="INACTIVE" style="rounded=1;whiteSpace=wrap;fillColor=#E0E0E0;strokeColor=#757575;fontSize=14;fontStyle=1;fontColor=#424242;" parent="1" vertex="1">
          <mxGeometry x="580" y="620" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="st_inactive_desc" value="Desactivada permanentemente.&#xa;(Reexpedición / cancelación)" style="text;html=1;fontSize=9;fontStyle=2;fontColor=#616161;align=center;" parent="1" vertex="1">
          <mxGeometry x="580" y="680" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="e_active_inactive" value="Reexpedición" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#757575;fontSize=9;fontStyle=1;" parent="1" source="st_active" target="st_inactive" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="900" y="130" />
              <mxPoint x="900" y="650" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_blocked_inactive" value="Reexpedición" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#757575;fontSize=9;fontStyle=1;dashed=1;" parent="1" source="st_blocked" target="st_inactive" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- EXPIRED -->
        <mxCell id="st_expired" value="EXPIRED" style="rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=14;fontStyle=1;fontColor=#BF360C;" parent="1" vertex="1">
          <mxGeometry x="200" y="430" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="st_expired_desc" value="Token expiró (72h × 3 intentos).&#xa;TH nunca completó onboarding.&#xa;Requiere reenvío manual." style="text;html=1;fontSize=9;fontStyle=2;fontColor=#BF360C;align=center;" parent="1" vertex="1">
          <mxGeometry x="195" y="490" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="e_prereg_expired" value="Token expira (72h)&#xa;3 reintentos agotados" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#EF6C00;fontSize=9;fontStyle=1;dashed=1;" parent="1" source="st_prereg" target="st_expired" edge="1">
