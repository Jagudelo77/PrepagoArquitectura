        <mxCell id="e_c3_req_val" edge="1" parent="1" source="c3_request" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;" target="c3_validate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c3_new_token" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;" value="Genera nuevo token&#xa;Reenvía SMS&#xa;Resetea contador&#xa;Estado → PRE_REGISTERED" vertex="1">
          <mxGeometry height="65" width="170" x="470" y="465" as="geometry" />
        </mxCell>
        <mxCell id="e_c3_yes" edge="1" parent="1" source="c3_validate" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#388E3C;fontColor=#388E3C;fontStyle=1;fontSize=10;" target="c3_new_token" value="Sí">
