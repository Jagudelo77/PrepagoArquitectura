          <mxGeometry x="675" y="750" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="st_end_ring" value="" style="ellipse;fillColor=none;strokeColor=#000000;strokeWidth=2;" parent="1" vertex="1">
