          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c2_note" parent="1" style="shape=note;size=15;fillColor=#FFEBEE;strokeColor=#E53935;fontSize=9;fontStyle=2;align=left;spacingLeft=5;" value="⚠️ Nuevos error codes:&#xa;• CARD_NOT_ACTIVATED&#xa;• CARD_ACTIVATION_EXPIRED&#xa;&#xa;Agregar al catálogo del autorizador&#xa;y al flujo de validación de recargas." vertex="1">
          <mxGeometry height="90" width="220" x="1110" y="220" as="geometry" />
        </mxCell>
        <mxCell id="case3_box" parent="1" style="rounded=1;fillColor=#E8F5E9;strokeColor=#388E3C;dashed=1;dashPattern=4 4;arcSize=4;" value="" vertex="1">
          <mxGeometry height="250" width="620" x="40" y="420" as="geometry" />
        </mxCell>
        <mxCell id="case3_title" parent="1" style="text;html=1;fontSize=13;fontStyle=1;fontColor=#1B5E20;" value="CASO 3: Reenvío Manual de SMS (Entidad o Soporte)" vertex="1">
          <mxGeometry height="22" width="400" x="55" y="428" as="geometry" />
        </mxCell>
        <mxCell id="c3_request" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Entidad o Soporte:&#xa;POST /cards/{id}/&#xa;resend-activation" vertex="1">
          <mxGeometry height="55" width="170" x="60" y="472" as="geometry" />
        </mxCell>
        <mxCell id="c3_validate" parent="1" style="rhombus;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" value="¿Tarjeta en&#xa;PRE_REGISTERED&#xa;o EXPIRED?" vertex="1">
