        </mxCell>
        <mxCell id="e_c2_txn_val" edge="1" parent="1" source="c2_txn" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;" target="c2_validate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="c2_reject" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#FFCDD2;strokeColor=#E53935;fontSize=10;fontStyle=1;" value="❌ RECHAZADA&#xa;RC: CARD_NOT_ACTIVATED&#xa;Tarjeta pendiente&#xa;de activación" vertex="1">
          <mxGeometry height="65" width="210" x="1220" y="127" as="geometry" />
        </mxCell>
        <mxCell id="e_c2_reject" edge="1" parent="1" source="c2_validate" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#E53935;fontColor=#E53935;fontStyle=1;fontSize=9;" target="c2_reject" value="PRE_REGISTERED&#xa;o EXPIRED">
