  <diagram id="estados-tarjeta" name="2. Diagrama de Estados de Tarjeta">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="st_title" value="Diagrama de Estados — Tarjeta Prepago (con PreRegistro)" style="text;html=1;fontSize=20;fontStyle=1;align=center;" parent="1" vertex="1">
          <mxGeometry x="250" y="20" width="700" height="35" as="geometry" />
        </mxCell>
        <mxCell id="st_sub" value="Primera tarjeta → PRE_REGISTERED → onboarding → ACTIVE  |  Tarjeta adicional (cliente onboardeado) → ACTIVE directo" style="text;html=1;fontSize=11;fontStyle=2;align=center;fontColor=#666;" parent="1" vertex="1">
          <mxGeometry x="200" y="55" width="800" height="20" as="geometry" />
        </mxCell>
        <!-- Estado inicial -->
        <mxCell id="st_start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="80" y="250" width="30" height="30" as="geometry" />
        </mxCell>
        <!-- PRE_REGISTERED -->
        <mxCell id="st_prereg" value="PRE_REGISTERED" style="rounded=1;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=14;fontStyle=1;fontColor=#E65100;" parent="1" vertex="1">
          <mxGeometry x="200" y="100" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="st_prereg_desc" value="Primera tarjeta del cliente.&#xa;Pendiente de onboarding en portal.&#xa;NO puede operar." style="text;html=1;fontSize=9;fontStyle=2;fontColor=#E65100;align=center;" parent="1" vertex="1">
          <mxGeometry x="200" y="160" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="e_start_prereg" value="Creación&#xa;(1ra tarjeta)" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#F9A825;fontSize=9;fontStyle=1;" parent="1" source="st_start" target="st_prereg" edge="1">
