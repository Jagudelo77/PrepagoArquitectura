        <mxCell id="rosa-title" value="&lt;font color=&#39;#E53935&#39; style=&#39;font-size:14px;&#39;&gt;&lt;b&gt;ROSA&lt;/b&gt; (Red Hat OpenShift on AWS)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" parent="1" vertex="1">
