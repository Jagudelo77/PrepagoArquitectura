        <mxCell id="sf-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E7157B;dashed=1;dashPattern=4 4;arcSize=4;" parent="1" vertex="1">
          <mxGeometry x="920" y="230" width="300" height="620" as="geometry" />
        </mxCell>
        <mxCell id="sf-title" value="&lt;b&gt;Step Functions — File Orchestrator&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:8px;&#39; color=&#39;#880E4F&#39;&gt;🔒 Encryption at rest (KMS)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#E7157B;" parent="1" vertex="1">
          <mxGeometry x="935" y="235" width="270" height="35" as="geometry" />
        </mxCell>
        <mxCell id="sf-icon" value="" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.step_functions;" parent="1" vertex="1">
          <mxGeometry x="1080" y="237" width="25" height="25" as="geometry" />
        </mxCell>
        <mxCell id="step1" value="&lt;b&gt;① Dedup Check&lt;/b&gt;&lt;br&gt;Consulta file_hash en DynamoDB&lt;br&gt;Si existe → REJECT + notifica&lt;br&gt;Si no → continúa" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#E7157B;fontColor=#880E4F;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="945" y="275" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="&lt;b&gt;② Register Batch&lt;/b&gt;&lt;br&gt;INSERT file_batch (status=PROCESSING,&lt;br&gt;file_hash, total_records, metadata)&lt;br&gt;&lt;font color=&#39;#880E4F&#39; style=&#39;font-size:8px;&#39;&gt;Calcula TimeoutSeconds = total_records × 5s (min 3600)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#E7157B;fontColor=#880E4F;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="945" y="350" width="250" height="65" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="&lt;b&gt;③ Map Distributed&lt;/b&gt;&lt;br&gt;Split S3 en chunks de N registros&lt;br&gt;Cada child encola msgs a SQS&lt;br&gt;&lt;font color=&#39;#4A148C&#39; style=&#39;font-size:8px;&#39;&gt;⚡ taskToken incluido como&lt;br&gt;MessageAttribute en cada msg SQS&lt;br&gt;(max 2048 chars — cabe en SQS attr)&lt;br&gt;MaxConcurrency configurable&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontColor=#4A148C;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="945" y="430" width="250" height="110" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="&lt;b&gt;④ Wait for Callback&lt;/b&gt;&lt;br&gt;(.waitForTaskToken)&lt;br&gt;&lt;font color=&#39;#B71C1C&#39; style=&#39;font-size:8px;&#39;&gt;⏱ TimeoutSeconds = dinámico (total_records × 5s)&lt;br&gt;HeartbeatSeconds = 300&lt;br&gt;Catch: TaskTimedOut → ⑤b Failure Handler&lt;br&gt;Acepta: SendTaskSuccess | SendTaskFailure&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontColor=#1B5E20;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="945" y="555" width="250" height="95" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="&lt;b&gt;⑤a Build Response&lt;/b&gt;&lt;br&gt;Invoca Lambda Response Builder" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#E7157B;fontColor=#880E4F;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="945" y="668" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="step5b" value="&lt;b&gt;⑤b Failure Handler&lt;/b&gt;&lt;br&gt;Marca batch FAILED en RDS&lt;br&gt;Genera reporte parcial de errores&lt;br&gt;&lt;font color=&#39;#B71C1C&#39; style=&#39;font-size:8px;&#39;&gt;Catch: TaskTimedOut | SendTaskFailure&lt;br&gt;error (max 256 chars) + cause (max 32KB)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontColor=#B71C1C;fontSize=9;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="945" y="720" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="step6" value="&lt;b&gt;⑥ Notify&lt;/b&gt;&lt;br&gt;Publica en SNS → SES email&lt;br&gt;&lt;font style=&#39;font-size:8px;&#39;&gt;(éxito o fallo)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#E7157B;fontColor=#880E4F;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="945" y="805" width="250" height="40" as="geometry" />
        </mxCell>
