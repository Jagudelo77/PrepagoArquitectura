        </mxCell>
        <mxCell id="card-svc" value="&lt;b&gt;Card Provisioning Service&lt;/b&gt;&lt;br&gt;(Spring Boot)&lt;br&gt;&lt;br&gt;Lógica por registro:&lt;br&gt;1) Upsert Cliente&lt;br&gt;2) Validar Grupo Afinidad&lt;br&gt;3) Crear Cuenta si no existe&lt;br&gt;4) Invocar API Emisor (mTLS)&lt;br&gt;5) Persistir resultado (RDS schema prepago)&lt;br&gt;6) UPSERT file_record_result (RDS schema batch)&lt;br&gt;&lt;font color=&#39;#7B1FA2&#39; style=&#39;font-size:8px;&#39;&gt;⚡ Lee taskToken del SQS MessageAttribute&lt;br&gt;(sin round-trip a RDS para obtenerlo)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontColor=#B71C1C;fontSize=10;arcSize=6;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="1560" y="430" width="250" height="230" as="geometry" />
        </mxCell>
        <mxCell id="retry-box" value="&lt;b&gt;Resilience4j&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:8px;&#39;&gt;CircuitBreaker: CLOSED→OPEN→HALF_OPEN&lt;br&gt;Retry: maxAttempts=3, backoff exponencial&lt;br&gt;Bulkhead: maxConcurrent=50&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontColor=#E65100;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="1560" y="680" width="250" height="65" as="geometry" />
        </mxCell>
        <mxCell id="heartbeat-box" value="&lt;b&gt;Heartbeat Sender&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:8px;&#39;&gt;SendTaskHeartbeat(taskToken) cada 300s&lt;br&gt;Si recibe TaskTimedOut → stop processing&lt;br&gt;Si recibe TaskDoesNotExist → stop + alert&lt;br&gt;taskToken obtenido del SQS MessageAttribute&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontColor=#1B5E20;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="1560" y="765" width="250" height="75" as="geometry" />
        </mxCell>
        <mxCell id="event-pub-box" value="&lt;b&gt;Event Publisher&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:8px;&#39;&gt;Publica batch_completed a EventBridge&lt;br&gt;Payload: {file_id, taskToken, total_ok,&lt;br&gt;total_error, s3_result_key}&lt;br&gt;taskToken propagado desde SQS attr&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;fontColor=#283593;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="1560" y="860" width="250" height="75" as="geometry" />
        </mxCell>
        <mxCell id="api-pomelo" value="&lt;b&gt;API Pomelo&lt;/b&gt;&lt;br&gt;(Crear cliente + tarjeta)&lt;br&gt;&lt;font color=&quot;#E65100&quot; style=&quot;font-size: 8px;&quot;&gt;🔒 mTLS&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF6F00;fontColor=#E65100;fontSize=11;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="1960" y="510" width="170" height="90" as="geometry" />
        </mxCell>
        <mxCell id="eb-batch" value="" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.eventbridge;" parent="1" vertex="1">
          <mxGeometry x="1300" y="1070" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eb-batch-label" value="&lt;b&gt;EventBridge&lt;/b&gt;&lt;br&gt;event: batch_completed&lt;br&gt;&lt;font style=&#39;font-size:8px;&#39;&gt;{file_id, taskToken,&lt;br&gt;total_ok, total_error}&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;fontSize=9;fontColor=#E7157B;" parent="1" vertex="1">
          <mxGeometry x="1255" y="1123" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="api-contract-box" value="&lt;b&gt;📋 Callback API Contract (AWS Step Functions)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;&lt;b&gt;SendTaskSuccess&lt;/b&gt;(taskToken, output)&lt;br&gt;  · taskToken: string (1–2048 chars) — Required&lt;br&gt;  · output: JSON string (max 262144 bytes / 256KB) — Required&lt;br&gt;&lt;br&gt;&lt;b&gt;SendTaskFailure&lt;/b&gt;(taskToken, error, cause)&lt;br&gt;  · taskToken: string (1–2048 chars) — Required&lt;br&gt;  · error: string (max 256 chars) — Optional&lt;br&gt;  · cause: string (max 32768 chars) — Optional&lt;br&gt;&lt;br&gt;&lt;b&gt;SendTaskHeartbeat&lt;/b&gt;(taskToken)&lt;br&gt;  · taskToken: string (1–2048 chars) — Required&lt;br&gt;&lt;br&gt;&lt;b&gt;Errores a manejar:&lt;/b&gt;&lt;br&gt;  · InvalidToken / InvalidOutput (400)&lt;br&gt;  · TaskTimedOut / TaskDoesNotExist (400)&lt;br&gt;  · KmsAccessDenied / KmsInvalidState / KmsThrottling (400)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=10;arcSize=6;verticalAlign=top;align=left;spacingLeft=8;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1560" y="1070" width="310" height="230" as="geometry" />
