        </mxCell>
        <mxCell id="dynamo-label" value="&lt;b&gt;DynamoDB&lt;/b&gt;&lt;br&gt;Idempotency Table&lt;br&gt;&lt;font color=&#39;#E65100&#39; style=&#39;font-size:8px;&#39;&gt;TTL=24h · PK=file_hash&lt;br&gt;🔒 Cifrado KMS&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;fontSize=9;fontColor=#C925D1;" parent="1" vertex="1">
