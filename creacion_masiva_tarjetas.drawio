        </mxCell>
        <mxCell id="lambda-dlq-label" value="&lt;b&gt;Lambda DLQ&lt;br&gt;Reprocessor&lt;/b&gt;&lt;br&gt;Analiza, reintenta o&lt;br&gt;marca FAILED" style="text;html=1;align=center;verticalAlign=top;fontSize=8;fontColor=#D45B07;" parent="1" vertex="1">
          <mxGeometry x="1370" y="652" width="100" height="45" as="geometry" />
        </mxCell>
        <mxCell id="lambda-checker" value="" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#D45B07;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.lambda_function;" parent="1" vertex="1">
          <mxGeometry x="1300" y="850" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lambda-checker-label" value="&lt;b&gt;Lambda Completion Checker&lt;/b&gt;&lt;br&gt;count(results) == total_records?&lt;br&gt;&lt;font color=&#39;#1B5E20&#39; style=&#39;font-size:8px;&#39;&gt;✅ → SendTaskSuccess(taskToken, output)&lt;br&gt;output = {file_id, ok, errors, s3_key} ≤ 256KB&lt;br&gt;❌ → SendTaskFailure(taskToken, error, cause)&lt;br&gt;error max 256 chars · cause max 32KB&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#B71C1C&#39; style=&#39;font-size:8px;&#39;&gt;Catch: TaskTimedOut, TaskDoesNotExist&lt;br&gt;KmsAccessDenied, KmsThrottling (retry)&lt;br&gt;Requiere: kms:Decrypt en IAM role&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;fontSize=9;fontColor=#D45B07;" parent="1" vertex="1">
