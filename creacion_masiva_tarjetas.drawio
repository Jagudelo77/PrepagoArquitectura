        <mxCell id="dlq-alarm-label" value="&lt;b&gt;CW Alarm&lt;/b&gt;&lt;br&gt;DLQ depth &gt; 0&lt;br&gt;→ SNS → Ops" style="text;html=1;align=center;verticalAlign=top;fontSize=8;fontColor=#E7157B;" parent="1" vertex="1">
          <mxGeometry x="1265" y="742" width="110" height="35" as="geometry" />
