        <mxCell id="DDHSACo3WAjdBxM0exQj-13" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Batch — CronJob OpenShift]" vertex="1">
