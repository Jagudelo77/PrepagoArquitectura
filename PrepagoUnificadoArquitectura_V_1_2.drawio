        <mxCell id="rec-note-1" parent="1" style="text;html=1;fontSize=9;fontStyle=2;align=center;fontColor=#60A5FA;fillColor=none;strokeColor=#60A5FA;rounded=1;spacingLeft=8;spacingRight=8;" value="⏰ Secuencia de ejecución diaria:&lt;br&gt;1. 05:00 — Clearing File Ingestion (recibe archivos franquicia)&lt;br&gt;2. 06:00 — Reconciliation Matcher (cuadre txn vs clearing)&lt;br&gt;3. 06:30 — Exception Handler (procesa diferencias)&lt;br&gt;4. 07:00 — Settlement Calculator (posición neta)&lt;br&gt;5. 08:00 — Dashboard disponible para operaciones" vertex="1">
          <mxGeometry height="75" width="380" x="80" y="770" as="geometry" />
        </mxCell>
        <mxCell id="rec-note-2" parent="1" style="text;html=1;fontSize=9;fontStyle=2;align=center;fontColor=#D97706;fillColor=#FFFBEB;strokeColor=#D97706;rounded=1;spacingLeft=8;spacingRight=8;" value="💡 El Matcher usa Oracle Read Replica para queries&lt;br&gt;pesados y no impactar el hot-path transaccional.&lt;br&gt;Las excepciones UNMATCHED_LOCAL con antigüedad&lt;br&gt;&amp;lt; 24h se auto-resuelven en el siguiente ciclo&lt;br&gt;(clearing puede llegar con 1 día de retraso)." vertex="1">
          <mxGeometry height="65" width="380" x="80" y="860" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
