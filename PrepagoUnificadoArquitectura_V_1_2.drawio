        <mxCell id="DDHSACo3WAjdBxM0exQj-17" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Novelty API" vertex="1">
          <mxGeometry height="22" width="340" x="690" y="302" as="geometry" />
