        <mxCell id="rec-ext-franchise" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="280" x="80" y="170" as="geometry" />
