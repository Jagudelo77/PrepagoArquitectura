          </mxCell>
        </object>
        <mxCell id="cm-scheduler" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="300" x="80" y="185" as="geometry" />
        </mxCell>
        <mxCell id="cm-scheduler-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Prepaid_Fee_Scheduler" vertex="1">
          <mxGeometry height="22" width="300" x="80" y="188" as="geometry" />
        </mxCell>
        <mxCell id="cm-scheduler-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot 3 — CronJob OpenShift]" vertex="1">
          <mxGeometry height="14" width="300" x="80" y="210" as="geometry" />
        </mxCell>
        <mxCell id="cm-scheduler-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Ejecuta mensualmente (configurable por grupo de afinidad).&lt;br&gt;Consulta tarjetas activas con cuota pendiente.&lt;br&gt;Genera lote de cobros y dispara el Fee Processor.&lt;br&gt;Cron: 0 2 1 * * (1er día del mes, 2:00 AM)" vertex="1">
          <mxGeometry height="60" width="290" x="85" y="228" as="geometry" />
        </mxCell>
        <mxCell id="cm-processor" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="130" width="340" x="460" y="180" as="geometry" />
        </mxCell>
        <mxCell id="cm-processor-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Prepaid_Fee _Processor" vertex="1">
          <mxGeometry height="22" width="340" x="460" y="188" as="geometry" />
        </mxCell>
        <mxCell id="cm-processor-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Batch — Chunk-oriented processing]" vertex="1">
          <mxGeometry height="14" width="340" x="460" y="210" as="geometry" />
        </mxCell>
        <mxCell id="cm-processor-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Procesa lote de cobros en chunks (100 registros):&lt;br&gt;1. Lee tarjeta + cuenta + config cuota del grupo afinidad&lt;br&gt;2. Calcula monto (cuota base + IVA si aplica)&lt;br&gt;3. Débito atómico UPDATE account SET balance = balance - fee&lt;br&gt;4. INSERT fee_transaction (tipo=MANAGEMENT_FEE)&lt;br&gt;5. Si saldo insuficiente → marca como pendiente" vertex="1">
          <mxGeometry height="68" width="330" x="465" y="228" as="geometry" />
        </mxCell>
        <mxCell id="cm-oracle" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="120" width="260" x="500" y="400" as="geometry" />
        </mxCell>
        <mxCell id="cm-oracle-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Oracle Database" vertex="1">
          <mxGeometry height="22" width="260" x="500" y="428" as="geometry" />
        </mxCell>
        <mxCell id="cm-oracle-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Oracle 19c+ — Shared]" vertex="1">
          <mxGeometry height="14" width="260" x="500" y="450" as="geometry" />
        </mxCell>
        <mxCell id="cm-oracle-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Tablas: fee_schedule, fee_transaction, account (balance).&lt;br&gt;fee_config por affinity_group (monto, periodicidad, IVA).&lt;br&gt;Constraint: no permite balance negativo." vertex="1">
          <mxGeometry height="40" width="250" x="505" y="468" as="geometry" />
        </mxCell>
        <mxCell id="cm-notifier" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="240" x="940" y="185" as="geometry" />
        </mxCell>
        <mxCell id="cm-notifier-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Prepaid_Fee_Notifier" vertex="1">
          <mxGeometry height="22" width="240" x="940" y="188" as="geometry" />
        </mxCell>
        <mxCell id="cm-notifier-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot — Async Worker]" vertex="1">
          <mxGeometry height="14" width="240" x="940" y="210" as="geometry" />
        </mxCell>
        <mxCell id="cm-notifier-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Genera reporte de cobros ejecutados.&lt;br&gt;Notifica cobros fallidos (saldo insuficiente).&lt;br&gt;Envía resumen al portal administrativo.&lt;br&gt;Registra auditoría del proceso." vertex="1">
          <mxGeometry height="55" width="230" x="945" y="228" as="geometry" />
        </mxCell>
        <mxCell id="cm-retry" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#D97706;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="110" width="340" x="460" y="600" as="geometry" />
        </mxCell>
        <mxCell id="cm-retry-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#D97706;fillColor=none;strokeColor=none;" value="Fee Retry Processor" vertex="1">
          <mxGeometry height="22" width="340" x="460" y="608" as="geometry" />
        </mxCell>
        <mxCell id="cm-retry-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#D97706;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Batch — CronJob diario]" vertex="1">
          <mxGeometry height="14" width="340" x="460" y="630" as="geometry" />
        </mxCell>
        <mxCell id="cm-retry-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#D97706;fillColor=none;strokeColor=none;" value="Reintenta cobros fallidos por saldo insuficiente.&lt;br&gt;Ejecuta diariamente hasta max 3 reintentos.&lt;br&gt;Si falla 3 veces → marca tarjeta para revisión.&lt;br&gt;Cron: 0 3 * * * (3:00 AM diario)" vertex="1">
          <mxGeometry height="48" width="330" x="465" y="648" as="geometry" />
        </mxCell>
        <mxCell id="cm-edge-1" edge="1" parent="1" source="cm-scheduler" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#3B82F6;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="cm-processor" value="Dispara lote">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cm-edge-2" edge="1" parent="1" source="cm-processor" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#3B82F6;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;entryPerimeter=0;" target="cm-oracle" value="Débito atómico +&lt;br&gt;INSERT fee_transaction">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cm-edge-4" edge="1" parent="1" source="cm-processor" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#3B82F6;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="cm-notifier" value="Reporte + alertas">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cm-edge-5" edge="1" parent="1" source="cm-oracle" style="endArrow=block;endFill=1;html=1;strokeColor=#D97706;strokeWidth=1.5;fontSize=8;fontColor=#D97706;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" value="Reintento cobros&lt;br&gt;pendientes">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="635" y="600" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="cm-edge-6" edge="1" parent="1" style="endArrow=block;endFill=1;html=1;strokeColor=#D97706;strokeWidth=1.5;strokeDashArray=4;fontSize=8;fontColor=#D97706;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;entryPerimeter=0;edgeStyle=orthogonalEdgeStyle;" target="cm-oracle" value="Retry débito">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="805" y="650" />
              <mxPoint x="835" y="650" />
              <mxPoint x="835" y="490" />
            </Array>
            <mxPoint x="805" y="655" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="cm-note" parent="1" style="text;html=1;fontSize=9;fontStyle=2;align=center;fontColor=#60A5FA;fillColor=none;strokeColor=#60A5FA;rounded=1;spacingLeft=8;spacingRight=8;" value="💡 La cuota de manejo se configura por grupo de afinidad&lt;br&gt;en el Portal Administrativo (fee_config table).&lt;br&gt;Monto, periodicidad (mensual/bimestral), IVA aplicable.&lt;br&gt;El cobro genera una transacción tipo MANAGEMENT_FEE&lt;br&gt;visible en el historial del tarjetahabiente." vertex="1">
          <mxGeometry height="65" width="360" x="50" y="635" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
