        <mxCell id="fe-note-1" parent="1" style="text;html=1;fontSize=9;fontStyle=2;align=center;fontColor=#DC2626;fillColor=#FEF2F2;strokeColor=#DC2626;rounded=1;spacingLeft=8;spacingRight=8;" value="⚠️ COMIDD.MM es exclusivo para comisiones.&lt;br&gt;Las novedades GMF usan GMFNOVDD.MM&lt;br&gt;(separación por prefijo lógico para evitar&lt;br&gt;ambigüedad — Req. 9.5, 9.6)" vertex="1">
          <mxGeometry height="60" width="280" x="2260" y="892" as="geometry" />
        </mxCell>
        <mxCell id="fe-note-2" parent="1" style="text;html=1;fontSize=9;fontStyle=2;align=center;fontColor=#D97706;fillColor=#FFFBEB;strokeColor=#D97706;rounded=1;spacingLeft=8;spacingRight=8;" value="💡 Flujo dual: Batch (SFTP → NFS → CronJob)&lt;br&gt;y En Línea (API REST → Gateway → WebFlux).&lt;br&gt;Ambos canales convergen en los mismos&lt;br&gt;Novelty Processors (lógica unificada)." vertex="1">
          <mxGeometry height="60" width="280" x="2580" y="892" as="geometry" />
        </mxCell>
        <mxCell id="fe-note-3" parent="1" style="text;html=1;fontSize=9;fontStyle=2;align=center;fontColor=#10B981;fillColor=#ECFDF5;strokeColor=#10B981;rounded=1;spacingLeft=8;spacingRight=8;" value="📊 Archivos de salida: TNN, TNM, TAS, TAV&lt;br&gt;(resúmenes/rechazos), AUSR, NOVR, TRX,&lt;br&gt;COMI, SALD, AUM, CANJ, EXT, ABO, TAR&lt;br&gt;(operativos), MXXXXXXMMDD, AUMCT&lt;br&gt;(autorizador), indicadores_base.xlsx (mensual)" vertex="1">
          <mxGeometry height="70" width="220" x="2910" y="892" as="geometry" />
        </mxCell>
        <mxCell id="fe-note-4" parent="1" style="text;html=1;fontSize=9;fontStyle=2;align=center;fontColor=#6B21A8;fillColor=#F5F3FF;strokeColor=#8B5CF6;rounded=1;spacingLeft=8;spacingRight=8;" value="🔒 Idempotencia en todas las operaciones&lt;br&gt;de escritura (idempotency_key UNIQUE).&lt;br&gt;Round-trip validation en File Name Resolver.&lt;br&gt;Multifile Controller con checksum + secuencia." vertex="1">
          <mxGeometry height="60" width="280" x="2260" y="972" as="geometry" />
        </mxCell>
