        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="130" width="480" x="430" y="470" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-21" parent="1" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Novelty Orchestrator" vertex="1">
          <mxGeometry height="25" width="480" x="430" y="478" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-22" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Spring Service — Core de Negocio compartido]" vertex="1">
          <mxGeometry height="14" width="480" x="430" y="503" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-23" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Lógica de negocio unificada:&lt;br&gt;1. Validar que la tarjeta exista y esté ACTIVE&lt;br&gt;2. Resolver cuenta asociada a la tarjeta&lt;br&gt;3. Validar monto &amp;gt; 0 &lt;font style=&quot;color: rgb(220, 38, 38);&quot;&gt;y dentro de límites de recarga&lt;/font&gt;&lt;br&gt;4. Acreditar saldo atómicamente (UPDATE ... RETURNING INTO)&lt;br&gt;5. Registrar transacción de recarga + invalidar cache Redis" vertex="1">
          <mxGeometry height="70" width="460" x="440" y="522" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-24" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="100" width="260" x="370" y="680" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-25" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Oracle Database" vertex="1">
          <mxGeometry height="22" width="260" x="370" y="708" as="geometry" />
