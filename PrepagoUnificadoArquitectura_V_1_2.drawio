        <mxCell id="DDHSACo3WAjdBxM0exQj-14" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Lee archivo de recargas de GAW, parsea registros&lt;br&gt;(card_id + amount), invoca Reload Orchestrator&lt;br&gt;por cada registro, genera archivo de respuesta." vertex="1">
          <mxGeometry height="50" width="330" x="295" y="343" as="geometry" />
