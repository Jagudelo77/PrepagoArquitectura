        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-19" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Endpoint REST POST /api/v1/reloads para&lt;br&gt;recarga unitaria. Valida request, invoca&lt;br&gt;Reload Orchestrator, respuesta síncrona." vertex="1">
