        <mxCell id="nm-proc-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Service — Core de Negocio compartido por batch y API]" vertex="1">
          <mxGeometry height="14" width="540" x="670" y="590" as="geometry" />
        </mxCell>
        <mxCell id="nm-proc-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;spacingLeft=12;spacingTop=4;" value="&lt;b&gt;Lógica común para todas las novedades no monetarias:&lt;/b&gt;&#xa;1. Resolver tarjeta (card_id por User ID + AFG)&#xa;2. Validar AFG asociado al NIT y entidad correctos&#xa;3. Validar estado de tarjeta válido (Creada, Activa, Bloqueo Temporal)&#xa;     ↳ EXCEPCIÓN: Bloqueo Definitivo procesa cualquier estado&#xa;4. Idempotencia (rechaza si flag novedad_aplicada = S)&#xa;5. Despachar a sub-handler según tipo de novedad:" vertex="1">
          <mxGeometry height="100" width="520" x="680" y="608" as="geometry" />
        </mxCell>
        <mxCell id="nm-h1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;arcSize=8;align=center;verticalAlign=top;fontSize=9;fontColor=#991B1B;spacingTop=4;" value="&lt;b&gt;Bloqueo Definitivo&lt;/b&gt;&#xa;(Deshabilitación)&#xa;━━━━━━━━━━━━━&#xa;• Cualquier estado&#xa;• Captura saldo final&#xa;  → insumo NOVR&#xa;• status = DESHABILITADA&#xa;• card_state_history" vertex="1">
          <mxGeometry height="155" width="125" x="685" y="715" as="geometry" />
        </mxCell>
        <mxCell id="nm-h2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;arcSize=8;align=center;verticalAlign=top;fontSize=9;fontColor=#92400E;spacingTop=4;" value="&lt;b&gt;Bloqueo Temporal&lt;/b&gt;&#xa;━━━━━━━━━━━━━&#xa;• Estado válido:&#xa;  Creada / Activa&#xa;• status =&#xa;  BLOQUEO_TEMPORAL&#xa;• card_state_history" vertex="1">
          <mxGeometry height="155" width="125" x="820" y="715" as="geometry" />
        </mxCell>
        <mxCell id="nm-h3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#047857;strokeWidth=2;arcSize=8;align=center;verticalAlign=top;fontSize=9;fontColor=#065F46;spacingTop=4;" value="&lt;b&gt;Desbloqueo&lt;/b&gt;&#xa;━━━━━━━━━━━━━&#xa;• Estado válido:&#xa;  BLOQUEO_TEMPORAL&#xa;• status = ACTIVA&#xa;• card_state_history" vertex="1">
          <mxGeometry height="155" width="125" x="955" y="715" as="geometry" />
        </mxCell>
        <mxCell id="nm-h4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;arcSize=8;align=center;verticalAlign=top;fontSize=9;fontColor=#5B21B6;spacingTop=4;" value="&lt;b&gt;Modificación de Datos&lt;/b&gt;&#xa;━━━━━━━━━━━━━━━&#xa;• NIT, AFG, doc → INMUTABLES&#xa;• Email modificable&#xa;  → si registrado: correo&#xa;     login&#xa;  → si no: PreRegistration&#xa;• gmf_exempt (pos 440)&#xa;• Update Pomelo&#xa;• Auditoría exoneración" vertex="1">
          <mxGeometry height="155" width="160" x="1090" y="715" as="geometry" />
        </mxCell>
        <mxCell id="nm-pomcl" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
