        <mxCell id="2QuNeFU_GCBFWjPr9n5C-16" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="• Consulta de saldo en tiempo real&lt;br&gt;• Historial de movimientos (filtrado)&lt;br&gt;• Bloqueo / Desbloqueo de tarjeta&lt;br&gt;• Actualización de datos personales&lt;br&gt;• Descarga de extracto (PDF)&amp;nbsp;&lt;br&gt;• Cambio de PIN (delegado a Pomelo Iframe)&lt;br&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(59, 130, 246), rgb(76, 137, 236));&quot;&gt;•&amp;nbsp;&lt;/span&gt;Activar Tarjeta&lt;br&gt;• Datos de tarjeta (last4, vencimiento)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
