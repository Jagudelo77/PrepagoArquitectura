        <mxCell id="nm-pomcl-d" parent="1" style="text;html=1;fontSize=9;align=center;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="• PATCH /cards/{id}/status (block/unblock)&#xa;• PATCH /clients/{id} (modificación de datos)&#xa;• PATCH /cards/{id} (campos editables)" vertex="1">
