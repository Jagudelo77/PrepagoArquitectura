        <mxCell id="e-orch-prereg" edge="1" parent="1" source="onb-orchestrator-ext" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=2;fontSize=8;fontColor=#3B82F6;exitX=1;exitY=0.5;entryX=0;entryY=0.75;edgeStyle=orthogonalEdgeStyle;entryDx=0;entryDy=0;rounded=1;align=center;verticalAlign=middle;fontFamily=Helvetica;labelBackgroundColor=default;" target="onb-prereg-svc-t" value="1. createPreRegistration&#xa;(client_id, email)">
