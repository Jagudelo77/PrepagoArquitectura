        <mxCell id="v17-ref" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#92400E;fontColor=#92400E;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;dashed=1;dashPattern=4 2;" value="🔗 PESTAÑAS COMPLEMENTARIAS&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;• Comisiones Batch (Recobros) — recobro programado de pending_charge&lt;br&gt;• GMF Batch — Job mensual Ley 2277/2022 (acumulado UVT)&lt;br&gt;• Cuotas de manejo — cobro recurrente cuota mensual&lt;br&gt;• Reconciliacion End-of-Day — clearing Pomelo vs Credibanco&lt;br&gt;• Intercambio de Archivos — vista general SFTP/PGP NXXX/MXXX" vertex="1">
          <mxGeometry height="135" width="540" x="2720" y="531.75" as="geometry" />
        </mxCell>
        <mxCell id="v17-legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="LEYENDA&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;🔵 Componente Credibanco (Java/Spring)&lt;br&gt;🔴 Cache / Contadores (Redis)&lt;br&gt;🟣 Sistema externo (Pomelo)&lt;br&gt;🟦 On-Prem / DMZ (SFTP, GAW)&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;CAMINOS DE ENTRADA:&lt;br&gt;1) Archivo MXXXddmmcc por SFTP&lt;br&gt;2) API uno-a-uno (Entidad)&lt;br&gt;3) Webhook /webhooks/adjustment (Pomelo)&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;Referencia: requerimientos-novedades-monetarias.md" vertex="1">
          <mxGeometry height="220" width="370" x="2720" y="688.75" as="geometry" />
        </mxCell>
