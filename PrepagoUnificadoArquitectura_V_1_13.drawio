        <mxCell id="v17-b2b-d" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Notifica fallas masivas a Entidad:&lt;br&gt;TRAILER_NIT, ARCHIVO_FECHA,&lt;br&gt;TRAILER_FECHA, TRAILER_NUM_REG,&lt;br&gt;NIT_EN_NOVEDAD, LONGITUD (128b)." vertex="1">
