        <mxCell id="WYurlSI6gKorOprcLl8n-21" parent="WYurlSI6gKorOprcLl8n-1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot 3 — REST API]" vertex="1">
