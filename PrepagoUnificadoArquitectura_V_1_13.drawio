        <mxCell id="cs-e8" edge="1" parent="1" source="cs-activa" style="endArrow=block;endFill=1;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=8;fontColor=#6B7280;" target="cs-expirada" value="Vencimiento (batch)">
