        <mxCell id="v17-rec-d" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Tras un ABONO acreditado:&lt;br&gt;EXEC SP_RECOVER_CHARGES(card_id, increment)&lt;br&gt;Itera pending_charge ASC, status=PENDIENTE,&lt;br&gt;expires_at &gt; SYSTIMESTAMP. INSERT txn=RECOBRO.&lt;br&gt;Vigencia 3 meses. Reporta en COMI." vertex="1">
          <mxGeometry height="68" width="270" x="690" y="760" as="geometry" />
        </mxCell>
