        </mxCell>
        <mxCell id="e-notif-smtp" edge="1" parent="1" source="onb-notif" style="endArrow=block;endFill=1;html=1;strokeColor=#7C3AED;strokeWidth=1.5;fontSize=8;fontColor=#7C3AED;exitX=0;exitY=0.5;entryX=0.5;entryY=1;edgeStyle=orthogonalEdgeStyle;entryDx=0;entryDy=0;" target="onb-smtp" value="SMTP / TLS&#xa;HTML">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-smtp-th" edge="1" parent="1" source="onb-smtp" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;strokeDashArray=6;fontSize=8;fontColor=#3B82F6;exitX=0;exitY=0.5;entryX=0.75;entryY=1;edgeStyle=orthogonalEdgeStyle;entryDx=0;entryDy=0;rounded=1;align=center;verticalAlign=middle;fontFamily=Helvetica;labelBackgroundColor=default;" target="onb-th" value="Email TH&#xa;(link / OTP / confirmación)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-th-portal" edge="1" parent="1" source="onb-th" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#3B82F6;exitX=1;exitY=0.5;entryX=0;entryY=0.4;edgeStyle=orthogonalEdgeStyle;" target="onb-portal" value="3. Abre URL&#xa;preregistro.credibanco.com&#xa;/registro/{code}">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-portal-api" edge="1" parent="1" source="onb-portal" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=2;fontSize=8;fontColor=#3B82F6;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" target="onb-api" value="4. POST /verify&lt;br&gt;7. POST /validate-otp&lt;br&gt;8. POST /resend-otp&lt;br&gt;10. POST /create-account">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-api-prereg" edge="1" parent="1" source="onb-api" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=2;fontSize=8;fontColor=#3B82F6;exitX=0.5;exitY=1;entryX=0.5;entryY=0;edgeStyle=orthogonalEdgeStyle;entryDx=0;entryDy=0;" target="onb-prereg-svc" value="Delega lógica de negocio&lt;br&gt;verify / validate-otp / resend-otp / create-account">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-prereg-sso" edge="1" parent="1" source="onb-prereg-svc" style="endArrow=block;endFill=1;html=1;strokeColor=#10B981;strokeWidth=2;fontSize=8;fontColor=#10B981;exitX=0.85;exitY=1;entryX=0.5;entryY=0;edgeStyle=orthogonalEdgeStyle;" target="onb-sso" value="11. POST /admin/realms/cardholder/users&#xa;(username, password, attributes)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-prereg-oracle" edge="1" parent="1" source="onb-prereg-svc" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=2;fontSize=8;fontColor=#3B82F6;exitX=0.55;exitY=1;entryX=0.5;entryY=0;edgeStyle=orthogonalEdgeStyle;jumpStyle=arc;" target="onb-oracle" value="INSERT preregistration · INSERT otp&#xa;UPDATE status=COMPLETADO · INSERT app_user">
          <mxGeometry relative="1" x="0.4118" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e-prereg-audit" edge="1" parent="1" source="onb-prereg-svc" style="endArrow=block;endFill=1;html=1;strokeColor=#0EA5E9;strokeWidth=1.5;strokeDashArray=6;fontSize=8;fontColor=#0EA5E9;exitX=1;exitY=0.5;entryX=0;entryY=0.3;edgeStyle=orthogonalEdgeStyle;exitDx=0;exitDy=0;" target="onb-audit" value="Audit async&#xa;(req+resp+ctx)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="onb-note-fases" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#FEF9C3;strokeColor=#CA8A04;fontSize=9;fontColor=#713F12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="&lt;b&gt;5 FASES (resumen)&lt;/b&gt;&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;F1. Tras crear tarjeta nominada → genera code&#xa;     UUID, status=PENDIENTE, envía email link.&#xa;F2. TH abre link → Portal pide cédula → API valida&#xa;     contra preregistration + tarjeta (max 3 intentos).&#xa;F3. Sistema emite OTP 6 dígitos hash, TTL 5 min;&#xa;     TH ingresa OTP; sesión registro 10 min al validar.&#xa;F4. TH crea contraseña (12+ / Mayús / Núm / Esp);&#xa;     PreRegistration_Service crea usuario en SSO.&#xa;F5. status=COMPLETADO; TH va al Portal TH.&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;Detalle paso a paso (swimlanes y errores)&#xa;en Onboarding_Tarjetahabiente.drawio." vertex="1">
          <mxGeometry height="240" width="280" x="20" y="1135" as="geometry" />
        </mxCell>
        <mxCell id="onb-note-innominada" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=9;fontColor=#5B21B6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="&lt;b&gt;TARJETAS INNOMINADAS&lt;/b&gt;&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;Este flujo aplica solo a tarjetas NOMINADAS&#xa;(email del TH conocido al crear).&#xa;&#xa;Las INNOMINADAS:&#xa;• NO disparan pre-registro al crearse.&#xa;• Activación pública (BIN+last4+exp+CVV2)&#xa;     vía Activacion_PIN_Innominada.drawio (ADR-010).&#xa;• Si tras la activación el TH quiere portal,&#xa;     el flujo de SSO/onboarding es opcional&#xa;     y se ejecuta a posteriori (mismo Service).&#xa;&#xa;ADR-016 — uno por cliente, no por tarjeta." vertex="1">
          <mxGeometry height="220" width="320" x="490" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="onb-note-seg" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=9;fontColor=#991B1B;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="&lt;b&gt;CONTROLES DE SEGURIDAD&lt;/b&gt;&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;• Code de pre-registro: UUID v4, TTL 30 días, 1 uso.&lt;br&gt;• Verificación de identidad: tipo+número de documento&lt;br&gt;  + correo electrónico registrado; max 3 intentos → BLOQUEADO.&lt;br&gt;• OTP gestionada por OTP_Service: 6 dígitos,&lt;br&gt;  hash SHA-256 en BD, TTL 5 min, max 3 intentos.&lt;br&gt;• Session_registro: TTL 10 min post-OTP.&lt;br&gt;• Password: min 12 chars, mayúscula, minúscula,&lt;br&gt;  número, especial. TLS 1.3 en tránsito.&lt;br&gt;• X-Correlation-Id propagado a auditoría.&lt;br&gt;• Errores en formato Problem Details / RFC 7807.&lt;br&gt;• HSTS, X-Frame-Options DENY, X-Content-Type-Options nosniff.&lt;br&gt;• Cookies Secure / HttpOnly / SameSite=Strict.&lt;br&gt;• CSP + SRI para PreRegistration_Portal." vertex="1">
          <mxGeometry height="260" width="320" x="850" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="onb-note-modif-email" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ECFDF5;strokeColor=#10B981;fontSize=9;fontColor=#065F46;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="&lt;b&gt;DISPARADORES DEL PRE-REGISTRO&lt;/b&gt;&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;1. Creación de tarjeta nominada&lt;br&gt;     (Prepaid_Card_Creation_Orchestrator).&lt;br&gt;2. Modificación de email del TH cuando&lt;br&gt;     no tiene usuario registrado&lt;br&gt;     (Prepaid_Non_Monetary_Novelty_Processor).&lt;br&gt;3. Operaciones puntuales desde Portal Admin&lt;br&gt;     (Prepaid_Admin_API: reenvío manual).&lt;br&gt;&lt;br&gt;En todos los casos: el Service decide si crea&lt;br&gt;un nuevo code o reusa el PENDING vigente." vertex="1">
          <mxGeometry height="220" width="320" x="1210" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="onb-note-errores" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#FFFBEB;strokeColor=#D97706;fontSize=9;fontColor=#92400E;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="&lt;b&gt;ESTADOS Y ERRORES&lt;/b&gt;&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;Estados preregistration:&#xa;PENDIENTE | PENDING_NO_EMAIL |&#xa;COMPLETADO | EXPIRADO | BLOQUEADO&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;• Code expirado (30d) → &#39;Link expirado, contacte&#xa;     a su entidad&#39;.&#xa;• Code ya usado → &#39;Cuenta ya creada&#39;.&#xa;• Cédula no coincide (3x) → BLOQUEADO.&#xa;• OTP inválido (3x) → reiniciar desde cédula.&#xa;• OTP expirado (5 min) → reenviar nuevo.&#xa;• SSO error → retry interno; si falla, alerta&#xa;     a operación + email al TH." vertex="1">
          <mxGeometry height="220" width="320" x="1570" y="1259" as="geometry" />
        </mxCell>
