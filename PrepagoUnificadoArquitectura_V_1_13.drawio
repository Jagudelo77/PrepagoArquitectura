        <mxCell id="9h6DZfhbntDv2zF3RPcr-2" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#5B21B6;" value="Iframe de Pomelo" vertex="1">
          <mxGeometry height="22" width="380" x="389" y="-900" as="geometry" />
        </mxCell>
        <mxCell id="9h6DZfhbntDv2zF3RPcr-3" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#5B21B6;" value="[Sistema Externo — Dominio Pomelo · HSM de Pomelo]" vertex="1">
          <mxGeometry height="14" width="380" x="389" y="-878" as="geometry" />
        </mxCell>
        <mxCell id="9h6DZfhbntDv2zF3RPcr-4" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#5B21B6;spacingLeft=10;spacingTop=4;" value="4 procesos delegados a Pomelo (ADR-031):&#xa;1. Activacion de tarjeta nominada (asignacion PIN)&#xa;2. Cambio de PIN (PIN actual + nuevo)&#xa;3. Mostrar datos sensibles (PAN / CVV2 / exp)&#xa;4. Activacion de tarjeta innominada (Fase 2)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;El PIN nunca toca infraestructura de Credibanco.&#xa;Los datos sensibles los renderiza Pomelo.&#xa;Credibanco solo orquesta apertura + recibe confirmacion." vertex="1">
          <mxGeometry height="130" width="370" x="394" y="-861" as="geometry" />
        </mxCell>
        <mxCell id="ySpkxX1h6-Eog-_5oZI9-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="149" width="350" x="-164" y="-679" as="geometry" />
        </mxCell>
        <mxCell id="ySpkxX1h6-Eog-_5oZI9-2" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="SSO Keycloak" vertex="1">
          <mxGeometry height="22" width="350" x="-164" y="-673" as="geometry" />
        </mxCell>
        <mxCell id="ySpkxX1h6-Eog-_5oZI9-3" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Container: Keycloak — Realm CARDHOLDER — OIDC/OAuth2/JWT]" vertex="1">
          <mxGeometry height="14" width="350" x="-164" y="-651" as="geometry" />
        </mxCell>
        <mxCell id="ySpkxX1h6-Eog-_5oZI9-4" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Gestion de identidad TH:&#xa;• Login: documento + contrasena → JWT (TTL 30 min)&#xa;• Password policy: min 12 chars, 1 mayus, 1 num, 1 especial&#xa;• Max 3 intentos login → bloqueo 24h&#xa;• Restablecer: link por email + BIN + last4&#xa;• Cambiar: con contrasena actual&#xa;• MFA step-up antes de iframe sensible (Req 8.3.6)&#xa;• Bloqueo definitivo por 3 datos errados en pre-registro" vertex="1">
          <mxGeometry height="107" width="340" x="-158" y="-637" as="geometry" />
        </mxCell>
        <mxCell id="IcuCmjiHhoo69OGeB5tY-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Alcance" vertex="1">
