        </mxCell>
        <mxCell id="limit-counter-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot 3]" vertex="1">
          <mxGeometry height="14" width="260" x="1235" y="996" as="geometry" />
        </mxCell>
        <mxCell id="limit-counter-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="&lt;b&gt;Contadores por tarjeta en Redis&lt;/b&gt;&lt;br&gt;• Qty/Monto compras diarias (POS)&lt;br&gt;• Qty/Monto retiros diarios (ATM)&lt;br&gt;• Qty consultas de saldo (POS/ATM)&lt;br&gt;• Trx aprobadas diarias por cliente (todos canales)&lt;br&gt;• Compras VNP con 3DS (#D) qty+monto&lt;br&gt;• e-Commerce Nal/Int qty+monto&lt;br&gt;• PIN errado • Utilizaciones POS/ATM (regla 11)&lt;br&gt;• Novedades monetarias por monto (regla 81)&lt;br&gt;&lt;b&gt;Ops:&lt;/b&gt; CHECK / INCREMENT / DECREMENT / RESET&lt;br&gt;TTL = fin período → auto-reinicio" vertex="1">
          <mxGeometry height="120" width="250" x="1240" y="1012" as="geometry" />
        </mxCell>
        <mxCell id="e-engine-limit" edge="1" parent="1" source="L-JxTnSPuCsDWRgZwE4I-11" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#D97706;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="limit-counter-svc" value="n ">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-limit-redis" edge="1" parent="1" source="limit-counter-svc" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#3B82F6;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;entryPerimeter=0;edgeStyle=orthogonalEdgeStyle;" target="GbSRN02RT5quMc9xkAOz-1" value="INCR/GET&#xa;contadores">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="nota-pipeline" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ECFDF5;strokeColor=#10B981;fontSize=9;fontColor=#065F46;" value="COMISIÓN (paso 6):&#xa;Parametría AFG en Redis:&#xa;network_type + channel + txn_type&#xa;+ exempt_count + commission_value&#xa;IF contador ≤ exempt → $0&#xa;ELSE → commission_value&#xa;Se suma al débito atómico en SP" vertex="1">
          <mxGeometry height="110" width="200" x="20" y="840" as="geometry" />
        </mxCell>
        <mxCell id="nota-gmf" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ECFDF5;strokeColor=#10B981;fontSize=9;fontColor=#065F46;" value="GMF (paso 7):&#xa;Si entidad.gmf_mode = LINEA&#xa;Y tarjeta.gmf_exenta = N&#xa;→ Calcula 4x1000 sobre monto&#xa;→ Se suma al débito atómico&#xa;Si entidad.gmf_mode = BATCH&#xa;→ Se omite (cobro posterior)" vertex="1">
          <mxGeometry height="110" width="200" x="20" y="974.5" as="geometry" />
        </mxCell>
        <mxCell id="nota-tech-exit" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#991B1B;" value="TX TÉCNICAMENTE EXITOSA:&#xa;Si response_code IN (51,55,57,61,75)&#xa;Y regla TECH_EXITOSA activa en AFG:&#xa;→ SP_CHARGE_TECH_EXITOSA&#xa;→ Débito: valor fijo o según tabla&#xa;→ INSERT txn tipo=TECH_EXITOSA&#xa;No incrementa contadores de límite" vertex="1">
          <mxGeometry height="110" width="200" x="20" y="1114.5" as="geometry" />
        </mxCell>
        <mxCell id="audit-svc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#0EA5E9;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="140.5" width="260" x="365" y="1069.5" as="geometry" />
        </mxCell>
        <mxCell id="audit-title" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#0EA5E9;fillColor=none;strokeColor=none;" value="Audit_Service" vertex="1">
          <mxGeometry height="22" width="260" x="365" y="1077.5" as="geometry" />
        </mxCell>
        <mxCell id="audit-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#0EA5E9;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot 3 — async]" vertex="1">
          <mxGeometry height="14" width="260" x="365" y="1099.5" as="geometry" />
        </mxCell>
        <mxCell id="audit-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#0EA5E9;fillColor=none;strokeColor=none;" value="&lt;b&gt;Auditoría transversal + PCI 10.2&lt;/b&gt;&lt;br&gt;Campos: ID_AUDIT, SERVICE_NAME, MESSAGE_ID,&lt;br&gt;REQUEST/RESPONSE_PAYLOAD, STATUS, MS,&lt;br&gt;TECHNICAL_USER, ID_TARJETA, ID_PROCESO&lt;br&gt;PCI 10.2: userId, eventType, date, success/fail,&lt;br&gt;origen, recursos afectados.&lt;br&gt;Fire-and-forget desde Auth Engine → Oracle" vertex="1">
          <mxGeometry height="80" width="250" x="370" y="1115.5" as="geometry" />
        </mxCell>
        <mxCell id="e-engine-audit" edge="1" parent="1" source="L-JxTnSPuCsDWRgZwE4I-11" style="endArrow=block;endFill=1;html=1;strokeColor=#0EA5E9;strokeWidth=1.5;strokeDashArray=6;fontSize=8;fontColor=#0EA5E9;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="audit-svc" value="10. Audit async&#xa;(req+resp+ctx)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-audit-oracle" edge="1" parent="1" source="audit-svc" style="endArrow=block;endFill=1;html=1;strokeColor=#0EA5E9;strokeWidth=1.5;strokeDashArray=6;fontSize=8;fontColor=#0EA5E9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;entryPerimeter=0;" target="7v2w9tGaHyppmew7mQDd-1" value="INSERT audit_log&#xa;INSERT pci_event_log">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="670" y="1140" />
              <mxPoint x="670" y="1605" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="nota-pomelo-scope" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#DBEAFE;strokeColor=#3B82F6;fontSize=9;fontColor=#1E3A8A;" value="VALIDACIONES EN POMELO (pre-autorizador):&#xa;• PIN (regla 07)&#xa;• CVV/CVV2 (reglas 08, 09)&#xa;• Fecha de vencimiento (regla 13)&#xa;• Existencia y estado de tarjeta (regla 10)&#xa;• BIN y AFG activos&#xa;• Límite PIN errado&#xa;• Val. PIN en F&#39; (regla 69)&#xa;Credibanco NO repite estas validaciones" vertex="1">
          <mxGeometry height="130" width="230" x="360" y="334" as="geometry" />
        </mxCell>
        <mxCell id="nota-reversos" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=9;fontColor=#92400E;" value="REVERSO / ANULACIÓN:&#xa;1. Match txn original: id_card + amount +&#xa;   auth_code + merchant + terminal + RRN +&#xa;   response_code=exitoso + flag reversada=0&#xa;2. Idempotencia: set flag reversada/anulada=1&#xa;3. DECREMENT contador correspondiente&#xa;4. REVERSO → reusa auth_code original&#xa;   ANULACIÓN → genera nuevo auth_code&#xa;5. INSERT txn concepto=REVERSO_* / ANULACION" vertex="1">
          <mxGeometry height="130" width="230" x="20" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="7v2w9tGaHyppmew7mQDd-1" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#0EA5E9;strokeWidth=2;size=12;" value="" vertex="1">
