        <mxCell id="fe-hsm-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Descifra PAN (AES-256-GCM) con DEK,&lt;br&gt;DEK protegida por KEK (RSA-4096, KeyStore PKCS12)&lt;br&gt;Solo para archivo TAR. PAN en memoria del proceso." vertex="1">
          <mxGeometry height="40" width="230" x="1658" y="926" as="geometry" />
        </mxCell>
        <mxCell id="fe-edge-ofg-hsm" edge="1" parent="1" source="fe-ofg" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=2;fontSize=8;fontColor=#3B82F6;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="fe-hsm" value="Descifra PAN (envelope)&#xa;solo para TAR">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fe-edge-ofg-pgp" edge="1" parent="1" source="fe-ofg" style="endArrow=block;endFill=1;html=1;strokeColor=#10B981;strokeWidth=2;fontSize=8;fontColor=#10B981;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="6XBRHB69_4WNQx562Y04-1" value="Deposita archivo plano&#xa;en NFS /output">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1560" y="977" />
              <mxPoint x="1560" y="1463" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="fe-nota-pci-files" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#991B1B;fontStyle=1;" value="PCI DSS — ARCHIVOS CON PAN (solo TAR):&lt;br&gt;&lt;br&gt;Flujo: OFG descifra PAN (Envelope_Encryption_Service, KEK)&lt;br&gt;→ Genera archivo plano en NFS /output&lt;br&gt;→ GoAnywhere detecta archivo&lt;br&gt;→ Cifra con PGP (llave pública entidad)&lt;br&gt;→ Borra archivo plano original&lt;br&gt;→ Entrega .pgp vía SFTP a entidad&lt;br&gt;&lt;br&gt;Controles PCI:&lt;br&gt;• NFS /output dentro del CDE&lt;br&gt;• Permisos: solo OFG escribe, solo GAW lee&lt;br&gt;• Archivo plano temporal (segundos)&lt;br&gt;• GAW borra plano después de cifrar&lt;br&gt;• PAN en memoria Java solo durante escritura&lt;br&gt;• SIN HSM — envelope encryption (ADR-006/031)" vertex="1">
          <mxGeometry height="220" width="240" x="1670" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="kEAqfl9jmRmXkvQ7sq5b-1" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#10B981;fillColor=none;strokeColor=none;" value="1. Detecta archivo plano en NFS /output&lt;br&gt;2. Cifra con PGP (llave pública entidad)&lt;br&gt;3. Borra archivo plano original&lt;br&gt;4. Entrega .pgp a entidad vía SFTP&lt;br&gt;Llave PGP por entidad (rotación periódica)" vertex="1">
          <mxGeometry height="58" width="230" x="1270" y="1450" as="geometry" />
        </mxCell>
        <mxCell id="kEAqfl9jmRmXkvQ7sq5b-2" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#10B981;fillColor=none;strokeColor=none;" value="[Managed File Transfer — On-Prem / DMZ]" vertex="1">
          <mxGeometry height="14" width="180" x="1290" y="1433" as="geometry" />
        </mxCell>
        <mxCell id="xoWdRxr2fHIb4EwiPkV6-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="100" width="280" x="1310" y="324" as="geometry" />
        </mxCell>
        <mxCell id="xoWdRxr2fHIb4EwiPkV6-2" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="SSO" vertex="1">
          <mxGeometry height="22" width="266" x="1314" y="334" as="geometry" />
        </mxCell>
        <mxCell id="xoWdRxr2fHIb4EwiPkV6-3" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Keycloac]&lt;br&gt;&lt;br&gt;• Realm ADMIN: roles (ADMIN, OPERATOR, VIEWER)&lt;br&gt;• Realm CARDHOLDER: autenticación por doc + OTP&lt;br&gt;• OAuth2 / OIDC, JWT tokens, MFA" vertex="1">
          <mxGeometry height="55" width="261" x="1315" y="352" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
