        <mxCell id="onb-portal-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="PreRegistration_Portal_Gateway" vertex="1">
