        <mxCell id="e-audit-oracle" edge="1" parent="1" source="nm-audit" style="endArrow=block;endFill=1;html=1;strokeColor=#0EA5E9;strokeWidth=1.5;strokeDashArray=6;fontSize=8;fontColor=#0EA5E9;exitX=0.5;exitY=1;entryX=0.95;entryY=0.4;edgeStyle=orthogonalEdgeStyle;exitDx=0;exitDy=0;" target="nm-oracle" value="INSERT&#xa;audit_log + pci_event_log">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="nm-note-validations" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#FEF9C3;strokeColor=#CA8A04;fontSize=9;fontColor=#713F12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="&lt;b&gt;VALIDACIONES (paso 1-4 del Processor)&lt;/b&gt;&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;✅ AFG existe y está ACTIVA&#xa;✅ AFG asociado al NIT correcto&#xa;✅ AFG asociado a la entidad correcta&#xa;✅ User ID con tarjeta en estado válido:&#xa;     Creada / Activa / Bloqueo Temporal&#xa;     ⚠️ Bloqueo Definitivo: cualquier estado&#xa;✅ NXXXddmmcc:&#xa;     • dd-día: ≤ 6 días calendario&#xa;     • file_name + control_record único&#xa;✅ Idempotencia (flag novedad_aplicada)&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;Si falla → archivo TAS con causal" vertex="1">
          <mxGeometry height="220" width="280" x="530" y="1520" as="geometry" />
        </mxCell>
        <mxCell id="nm-note-modif" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=9;fontColor=#5B21B6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="&lt;b&gt;MODIFICACIÓN DE DATOS — REGLAS&lt;/b&gt;&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;❌ NO modificables (lanza error):&#xa;     NIT • AFG • tipo_doc • número_doc&#xa;✅ Modificables:&#xa;     email, phone, address, city,&#xa;     nominated/innominada (S↔N),&#xa;     gmf_exempt (S↔N) — pos 440&#xa;━━━ Cambio de email del TH ━━━&#xa;     1) Si email nuevo ya existe en BD&#xa;        para otro client → RECHAZA&#xa;     2) Si TH ya está registrado&#xa;        → email de ingreso al portal&#xa;     3) Si TH no registrado&#xa;        → PreRegistration_Service&#xa;        → email con URL pre-registro" vertex="1">
          <mxGeometry height="240" width="320" x="1930" y="1047" as="geometry" />
        </mxCell>
        <mxCell id="nm-note-novr" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=9;fontColor=#991B1B;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="&lt;b&gt;ARCHIVO NOVR&lt;/b&gt; (batch 01:00 AM)&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;Solo bloqueos definitivos (Deshabilitación)&#xa;y retiros del día.&#xa;Cada registro debe incluir el SALDO de la&#xa;tarjeta al momento del bloqueo&#xa;(captura por el Processor en el paso 5).&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;Bloqueo Temporal y Desbloqueo:&#xa;NO van en NOVR — solo en TNN.&#xa;Cuota de manejo y comisiones del&#xa;saldo en deshabilitación: ver pestaña&#xa;Cuotas de manejo / Comisiones Batch." vertex="1">
          <mxGeometry height="180" width="320" x="1930" y="1297" as="geometry" />
        </mxCell>
        <mxCell id="nm-note-pendientes" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=9;fontColor=#374151;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="&lt;b&gt;PENDIENTES (del documento fuente)&lt;/b&gt;&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;1. Detalle de validaciones que ejecuta GAW&#xa;     hoy y deben replicarse en el Processor.&#xa;2. Soporte para multibolsillo y tarjeta&#xa;     amparada (diferido Fase 2).&#xa;3. Confirmar con Pomelo si aplican&#xa;     restricciones a la modificación de datos.&#xa;4. Otros movimientos administrativos&#xa;     desde portal admin (Postman) que&#xa;     pasen también por este flujo.&#xa;Ver: docs/requerimientos-ciclo-vida-tarjeta&#xa;-y-portal-th.md §4 y §5." vertex="1">
          <mxGeometry height="220" width="280" x="210" y="1520" as="geometry" />
        </mxCell>
        <mxCell id="iYyg1i36GOpgUE_Kgo2T-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="100" width="280" x="1371" y="255" as="geometry" />
        </mxCell>
        <mxCell id="iYyg1i36GOpgUE_Kgo2T-2" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="SSO" vertex="1">
          <mxGeometry height="22" width="266" x="1375" y="265" as="geometry" />
        </mxCell>
        <mxCell id="iYyg1i36GOpgUE_Kgo2T-3" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Keycloac]&lt;br&gt;&lt;br&gt;• Realm ADMIN: roles (ADMIN, OPERATOR, VIEWER)&lt;br&gt;• Realm CARDHOLDER: autenticación por doc + OTP&lt;br&gt;• OAuth2 / OIDC, JWT tokens, MFA" vertex="1">
          <mxGeometry height="55" width="261" x="1376" y="283" as="geometry" />
        </mxCell>
        <mxCell id="Rg2wvyILOwjkbO3NmvBh-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;CDE&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="60" x="1380" y="439.5" as="geometry" />
        </mxCell>
        <mxCell id="SgBcRaIOJ7hNFma-2WxP-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Alcance&lt;/b&gt;" vertex="1">
