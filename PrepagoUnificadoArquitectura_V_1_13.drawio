          <mxGeometry height="15" width="240" x="1185" y="1410" as="geometry" />
        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-26" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Standby con Redo Apply en tiempo real.&lt;br&gt;Consultas, Reportería, auditoría, analítica y BI.&lt;br&gt;No impacta el hot-path transaccional." vertex="1">
          <mxGeometry height="55" width="230" x="1190" y="1430" as="geometry" />
        </mxCell>
