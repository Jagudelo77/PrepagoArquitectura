        <mxCell id="DDHSACo3WAjdBxM0exQj-14" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Lee MXXXddmmcc descifrado, valida estructura&lt;br&gt;(±6 días, trailer NIT/fecha/total, longitud 128 bytes),&lt;br&gt;chunk 1k-5k registros, invoca Novelty Orchestrator.&lt;br&gt;&lt;b&gt;Persiste resultado en file_record (writer);&lt;/b&gt;&lt;br&gt;&lt;b&gt;NO escribe archivos — Output_File_Generator publica TNM/TAV.&lt;/b&gt;&lt;br&gt;&lt;br&gt;⚠️ También procesa archivo GMF de la Entidad&lt;br&gt;(nombre y estructura TBD): type=GMF, charge_type=GMF.&lt;br&gt;La Entidad calcula UVT y envía la novedad — Credibanco aplica." vertex="1">
          <mxGeometry height="50" width="330" x="965" y="513" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="340" x="1360" y="450" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-16" parent="1" style="text;html=1;fontSize=7;fontStyle=1;align=center;fontColor=#000000;fillColor=#60A5FA;strokeColor=none;rounded=1;" value="CAMINO 2: API" vertex="1">
          <mxGeometry height="14" width="85" x="1368" y="456" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-17" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Prepaid_Monetary_Novelty_Service" vertex="1">
          <mxGeometry height="22" width="340" x="1360" y="472" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-18" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot 3 + WebFlux — Pods OpenShift]" vertex="1">
          <mxGeometry height="14" width="340" x="1360" y="494" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-19" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="POST /api/v1/monetary-novelty (mTLS + JWT)&lt;br&gt;Soporta type=ABONO|CARGO. Idempotency-Key.&lt;br&gt;Valida AFG↔NIT↔Entidad, estado tarjeta&lt;br&gt;∈{Creada, Activa, Bloqueo Temporal}." vertex="1">
          <mxGeometry height="50" width="330" x="1365" y="513" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="160" width="540" x="1100" y="640" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-21" parent="1" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Novelty_Orchestrator" vertex="1">
          <mxGeometry height="25" width="540" x="1100" y="648" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-22" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Spring Service — Núcleo unificado de aplicación de novedades]" vertex="1">
          <mxGeometry height="14" width="540" x="1100" y="673" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-23" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="1. Resolver card_id por (afg_id, doc_type, doc_number)&lt;br&gt;2. Validar estado tarjeta ∈ {Creada, Activa, Bloqueo Temporal}&lt;br&gt;3. CHECK regla 81 (Limit_Counter_Service)&lt;br&gt;4. Si CARGO + saldo insuficiente → SP_APPLY_MONETARY parcial + INSERT pending_charge&lt;br&gt;5. Si ABONO → SP_APPLY_MONETARY + Recovery_Service (recobro pendientes)&lt;br&gt;6. INSERT transaction (ABONO/CARGO) + UPDATE saldo (atómico en SP)&lt;br&gt;7. Limit_Counter.INCREMENT regla 81 + Audit_Service async + invalidar cache" vertex="1">
          <mxGeometry height="70" width="460" x="1110" y="692" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-24" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="140" width="300" x="965" y="1310" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-25" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Oracle Primary" vertex="1">
          <mxGeometry height="22" width="300" x="965" y="1338" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-26" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Oracle 19c — Particionada por mes]&lt;br&gt;SP_APPLY_MONETARY · SP_APPLY_ADJUSTMENT&lt;br&gt;SP_RECOVER_CHARGES · SP_GMF_MONTHLY_BATCH&lt;br&gt;Tablas: transaction · pending_charge&lt;br&gt;file_processing · file_record · adjustment_inbox" vertex="1">
          <mxGeometry height="30" width="250" x="990" y="1350" as="geometry" />
        </mxCell>
        <mxCell id="DDHSACo3WAjdBxM0exQj-27" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DC2626;strokeWidth=2;size=12;" value="" vertex="1">
