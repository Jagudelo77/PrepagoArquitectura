          <mxGeometry height="22" width="280" x="1280" y="426" as="geometry" />
        </mxCell>
        <mxCell id="pth-mail-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Templates HTML para TH:&#xa;• Link de pre-registro&#xa;• OTP&#xa;• Confirmacion de registro&#xa;• Bloqueo de OTP&#xa;• Login exitoso&#xa;• Bloqueo por PIN errado (3 intentos)" vertex="1">
          <mxGeometry height="88" width="270" x="1285" y="452" as="geometry" />
        </mxCell>
