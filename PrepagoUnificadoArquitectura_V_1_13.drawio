        <mxCell id="S102A3fR_j41dhUKZe1R-14" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Lee archivos de GAW, parsea registros, invoca&lt;br&gt;el Card Creation Orchestrator por cada registro.&lt;br&gt;Genera archivo de respuesta al finalizar.&lt;br&gt;Tracking de estado por registro (OK/ERROR)." vertex="1">
          <mxGeometry height="58" width="330" x="711" y="604" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="130" width="340" x="1106" y="540" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-16" parent="1" style="text;html=1;fontSize=7;fontStyle=1;align=center;fontColor=#000000;fillColor=#3B82F6;strokeColor=none;rounded=1;" value="CAMINO 2: API" vertex="1">
          <mxGeometry height="16" width="85" x="1114" y="546" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-17" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Prepaid_Card_Creation_API" vertex="1">
          <mxGeometry height="22" width="340" x="1106" y="564" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-18" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot 3 + WebFlux — Pods OpenShift]" vertex="1">
          <mxGeometry height="14" width="340" x="1106" y="586" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-19" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Endpoint REST POST /api/v1/cards para&lt;br&gt;creación unitaria. Valida request, invoca&lt;br&gt;el Card Creation Orchestrator y retorna&lt;br&gt;respuesta síncrona al llamante." vertex="1">
          <mxGeometry height="58" width="330" x="1111" y="605" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="289" width="460" x="856" y="751" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-21" parent="1" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;Prepaid_&lt;/span&gt;Card_Creation _Orchestrator" vertex="1">
          <mxGeometry height="25" width="460" x="856" y="759" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-22" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Spring Service — Core de Negocio compartido por ambos caminos]" vertex="1">
          <mxGeometry height="14" width="460" x="856" y="789" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-23" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Lógica de negocio unificada para ambos canales:&lt;br&gt;1. Validar grupo de afinidad en Pomelo API&lt;br&gt;2. Validar existencia de cliente en Pomelo API&lt;br&gt;3. Si no existe → crear cliente en Pomelo API&lt;br&gt;4. Solicitar creación de tarjeta en Pomelo API&lt;br&gt;5. GET /cards/{id}/sensitive-data → recibe PAN + exp + CVV2&lt;br&gt;6. Invoca Envelope_Encryption_Service:&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;6a. Genera DEK (AES-256, SecureRandom)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;6b. AES-256-GCM(PAN, DEK, IV, AAD) → pan_encrypted+iv+auth_tag&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;6c. RSA-4096 OAEP(DEK, KEK_public) → dek_encrypted&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;6d. Zeroiza DEK y PAN en memoria post-uso&lt;br&gt;7. Calcula SHA-256(PAN) → pan_hash | Extrae last_four + BIN&lt;br&gt;8. DESCARTA CVV2 inmediatamente (PCI Req 3.3.2)&lt;br&gt;9. Persiste: client, account(saldo 0), card(pan_encrypted, pan_iv,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;pan_auth_tag, dek_encrypted, kek_version, pan_hash,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;last_four, bin, exp, card_token, status=CREADA)&lt;br&gt;10. Si tarjeta NOMINADA → SELECT user WHERE client_id=?&lt;br&gt;11. Si user NO existe → invoca PreRegistration_Service&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;(uno por cliente; innominadas: omitir, ver&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Activacion_PIN_Innominada.drawio)" vertex="1">
          <mxGeometry height="215" width="440" x="866" y="803" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-24" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="175" width="260" x="971" y="1540" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-25" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Oracle Database" vertex="1">
          <mxGeometry height="22" width="260" x="970" y="1569" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-26" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Oracle 19c+ TDE — Shared con Auth Engine]" vertex="1">
          <mxGeometry height="14" width="260" x="970" y="1591" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-27" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="client, account, batch_job, batch_record,&lt;br&gt;affinity_group, card (pan_encrypted, pan_iv,&lt;br&gt;pan_auth_tag, dek_encrypted, kek_version,&lt;br&gt;pan_hash, last_four, bin, exp_date, card_token&lt;br&gt;— SIN CVV2), user (client_id, username,&lt;br&gt;status), preregistration (code PK, client_id FK,&lt;br&gt;email, status, expires_at, attempts)" vertex="1">
          <mxGeometry height="90" width="250" x="975" y="1609" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-28" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="110" width="220" x="326" y="550" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-29" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="File Storage" vertex="1">
          <mxGeometry height="22" width="220" x="326" y="576" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-30" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: NFS / PersistentVolume]" vertex="1">
          <mxGeometry height="14" width="220" x="326" y="598" as="geometry" />
        </mxCell>
