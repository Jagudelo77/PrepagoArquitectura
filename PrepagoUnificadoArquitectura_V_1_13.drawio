        <mxCell id="onb-portal-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Angular 17+ SPA]" vertex="1">
          <mxGeometry height="14" width="280" x="720" y="204.5" as="geometry" />
