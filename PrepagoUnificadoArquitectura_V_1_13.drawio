  <diagram id="deferred-charges-engine-001" name="Motor de Cobros Diferidos">
    <mxGraphModel dx="1025" dy="562" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="dce-title" parent="1" style="text;html=1;fontSize=20;fontStyle=1;align=left;fontColor=#000000;" value="Motor de Cobros Diferidos — Cuotas · GMF · Comisiones · Técnicamente Exitosas · Recobros" vertex="1">
          <mxGeometry height="32" width="1500" x="100" y="50" as="geometry" />
        </mxCell>
        <mxCell id="dce-subtitle" parent="1" style="text;html=1;fontSize=11;align=left;fontColor=#9CA3AF;" value="C4 Level 2  |  Patrón unificado: schedulers/eventos generan cobros → settlement service aplica → si falla saldo, queda en pending_charge → recovery al detectar abono. Reemplaza pestañas Cuotas de manejo + GMF Batch + Comisiones Batch (Recobros)." vertex="1">
          <mxGeometry height="20" width="2300" x="40" y="65" as="geometry" />
        </mxCell>
        <object placeholders="1" c4Name="Credibanco" c4Type="SystemScopeBoundary" c4Application="Software System" label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;&lt;div style=&quot;text-align: left&quot;&gt;%c4Name%&lt;/div&gt;&lt;/b&gt;&lt;/font&gt;&lt;div style=&quot;text-align: left&quot;&gt;[%c4Application%]&lt;/div&gt;" id="dce-cred-boundary">
          <mxCell parent="1" style="rounded=1;fontSize=11;whiteSpace=wrap;html=1;dashed=1;arcSize=20;fillColor=none;strokeColor=#003366;fontColor=#333333;labelBackgroundColor=none;align=left;verticalAlign=bottom;labelBorderColor=none;spacingTop=0;spacing=10;dashPattern=8 4;metaEdit=1;rotatable=0;perimeter=rectanglePerimeter;noLabel=0;labelPadding=0;allowArrows=0;connectable=0;expand=0;recursiveResize=0;editable=1;pointerEvents=0;absoluteArcSize=1;strokeWidth=2;" vertex="1">
            <mxGeometry height="1280" width="1930" x="20" y="140" as="geometry" />
          </mxCell>
        </object>
        <object placeholders="1" c4Name="OpenShift" c4Type="SystemScopeBoundary" c4Application="Container Platform" label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;&lt;div style=&quot;text-align: left&quot;&gt;%c4Name%&lt;/div&gt;&lt;/b&gt;&lt;/font&gt;&lt;div style=&quot;text-align: left&quot;&gt;[%c4Application%]&lt;/div&gt;" id="dce-ocp-boundary">
          <mxCell parent="1" style="rounded=1;fontSize=11;whiteSpace=wrap;html=1;dashed=1;arcSize=20;fillColor=none;strokeColor=#CC0000;fontColor=#CC0000;labelBackgroundColor=none;align=left;verticalAlign=bottom;labelBorderColor=none;spacingTop=0;spacing=10;dashPattern=8 4;metaEdit=1;rotatable=0;perimeter=rectanglePerimeter;noLabel=0;labelPadding=0;allowArrows=0;connectable=0;expand=0;recursiveResize=0;editable=1;pointerEvents=0;absoluteArcSize=1;strokeWidth=2;" vertex="1">
            <mxGeometry height="990" width="1860" x="60" y="160" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="dce-src-header" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;fontColor=#1F2937;" value="📅  Fuentes de Cobros (writers)" vertex="1">
          <mxGeometry height="24" width="380" x="120" y="201" as="geometry" />
        </mxCell>
        <mxCell id="dce-fee-sched" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="140" width="380" x="120" y="241" as="geometry" />
        </mxCell>
        <mxCell id="dce-fee-sched-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="Maintenance_Fee_Scheduler" vertex="1">
          <mxGeometry height="22" width="380" x="120" y="247" as="geometry" />
        </mxCell>
        <mxCell id="dce-fee-sched-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Java 21 + Spring Batch — CronJob OpenShift]" vertex="1">
          <mxGeometry height="14" width="380" x="120" y="269" as="geometry" />
        </mxCell>
        <mxCell id="dce-fee-sched-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Cuota mensual de manejo por tarjeta activa.&#xa;• Lee config por AFG (monto base + IVA + periodicidad)&#xa;• Aplica a estados {Activa, Bloqueo Temporal, Bloqueo PIN Errado}&#xa;• Cron: 0 2 1 * *  (1er día del mes 02:00)&#xa;• Charge_type = CUOTA_MANEJO" vertex="1">
          <mxGeometry height="92" width="380" x="120" y="286" as="geometry" />
        </mxCell>
        <mxCell id="dce-gmf-calc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#92400E;strokeWidth=2;arcSize=8;dashed=1;dashPattern=8 4;" value="" vertex="1">
          <mxGeometry height="170" width="380" x="120" y="410" as="geometry" />
        </mxCell>
        <mxCell id="dce-gmf-calc-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#92400E;" value="GMF batch — entra como novedad" vertex="1">
          <mxGeometry height="22" width="380" x="120" y="416" as="geometry" />
        </mxCell>
        <mxCell id="dce-gmf-calc-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#92400E;" value="[NO es writer activo aquí — origen externo]" vertex="1">
          <mxGeometry height="14" width="380" x="120" y="438" as="geometry" />
        </mxCell>
        <mxCell id="dce-gmf-calc-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#92400E;spacingLeft=10;spacingTop=4;" value="La Entidad calcula el GMF según Ley 2277/2022 art. 881-1 ET&#xa;y envía la novedad por archivo SFTP cifrado PGP a Credibanco.&#xa;Credibanco aplica lo que la Entidad indica (no calcula UVT).&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Flujo: ver pestaña &#39;Flujo de novedades monetarias&#39;.&#xa;Llega como charge_type=GMF al Charge_Settlement_Service&#xa;vía Prepaid_Monetary_Novelty_Processor.&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;⚠️ Pendiente de definición con la Entidad:&#xa;nombre del archivo (¿GXXXddmmcc?) y estructura del registro." vertex="1">
          <mxGeometry height="120" width="370" x="125" y="455" as="geometry" />
        </mxCell>
        <mxCell id="dce-com-eng" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="140" width="380" x="120" y="600" as="geometry" />
        </mxCell>
        <mxCell id="dce-com-eng-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="Commission_Charge_Engine" vertex="1">
          <mxGeometry height="22" width="380" x="120" y="606" as="geometry" />
        </mxCell>
        <mxCell id="dce-com-eng-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Java 21 + Spring — invocado desde Authorization_Engine]" vertex="1">
          <mxGeometry height="14" width="380" x="120" y="628" as="geometry" />
        </mxCell>
        <mxCell id="dce-com-eng-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Comisiones por transacción (POS/ATM, propia/no propia/intl).&#xa;• Calculadas en línea por el motor transaccional&#xa;• Si NO efectivo → pasa a recobro&#xa;• Tipos: retiro, consulta saldo, internacional&#xa;• Charge_type = COMISION" vertex="1">
          <mxGeometry height="92" width="380" x="120" y="645" as="geometry" />
        </mxCell>
        <mxCell id="dce-te-eng" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="140" width="380" x="120" y="760" as="geometry" />
        </mxCell>
        <mxCell id="dce-te-eng-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="Tech_Exitosa_Charge_Engine" vertex="1">
          <mxGeometry height="22" width="380" x="120" y="766" as="geometry" />
        </mxCell>
        <mxCell id="dce-te-eng-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Java 21 + Spring]" vertex="1">
          <mxGeometry height="14" width="380" x="120" y="788" as="geometry" />
        </mxCell>
        <mxCell id="dce-te-eng-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Cobro por transacciones técnicamente exitosas (denegadas).&#xa;• Códigos 51, 55, 57, 61, 75&#xa;• Disparado por Authorization_Engine tras denegación&#xa;• Charge_type = TECH_EXITOSA&#xa;• SP_CHARGE_TECH_EXITOSA" vertex="1">
          <mxGeometry height="92" width="380" x="120" y="805" as="geometry" />
        </mxCell>
        <mxCell id="dce-core-header" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;fontColor=#1F2937;" value="⚙️  Núcleo común — Liquidación atómica" vertex="1">
          <mxGeometry height="24" width="500" x="760" y="200" as="geometry" />
        </mxCell>
        <mxCell id="dce-core" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=3;arcSize=8;" value="" vertex="1">
          <mxGeometry height="280" width="500" x="760" y="240" as="geometry" />
        </mxCell>
        <mxCell id="dce-core-t" parent="1" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="Charge_Settlement_Service" vertex="1">
          <mxGeometry height="26" width="500" x="760" y="248" as="geometry" />
        </mxCell>
        <mxCell id="dce-core-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Container: Java 21 + Spring Service — orquestador único]" vertex="1">
          <mxGeometry height="14" width="500" x="760" y="274" as="geometry" />
        </mxCell>
        <mxCell id="dce-core-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=12;spacingTop=4;" value="Contrato único: settle(card_id, charge_type, amount, concept, source, originalTxId, periodKay).&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;Pipeline atómico:&lt;br&gt;1. Validar tarjeta en estado elegible (Activa, Bloqueo Temporal, Bloqueo PIN Errado).&lt;br&gt;2. Resolver cuenta y bolsillo (multibolsillo si aplica).&lt;br&gt;3. EXEC SP_SETTLE_CHARGE (Oracle):&lt;br&gt;     • Lee saldo  •  IF saldo &amp;gt;= amount: UPDATE balance + INSERT transaction (txn_type por charge_type)&lt;br&gt;     • ELSE: INSERT pending_charge(status=PENDIENTE, expires_at = now + 90d)&lt;br&gt;4. Marca movimiento en COMI/CSAT/CINS según resultado.&lt;br&gt;5. Audit async (PCI 10.2) + invalidate cache Redis.&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;txn_type derivado de charge_type:&lt;br&gt;• CUOTA_MANEJO → period_key = YYYMM&amp;nbsp;&lt;div&gt;• COMISION → period_key = original_tx_id&amp;nbsp;&lt;br&gt;• GMF → GMF&amp;nbsp;&lt;/div&gt;&lt;div&gt;• TECH_EXITOSA → TECH_EXITOSA&lt;br&gt;• RECOBRO → RECOBRO (cobro previo liquidado)&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;Idempotencia: clave (charge_type, card_id, period) impide doble cobro.&lt;/div&gt;" vertex="1">
          <mxGeometry height="208" width="490" x="765" y="292" as="geometry" />
        </mxCell>
        <mxCell id="dce-rec-header" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;fontColor=#1F2937;" value="♻️  Recovery — drena pending_charge" vertex="1">
          <mxGeometry height="24" width="180" x="650" y="1150" as="geometry" />
        </mxCell>
        <mxCell id="dce-recovery" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#10B981;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="285" width="450" x="660" y="850" as="geometry" />
        </mxCell>
        <mxCell id="dce-recovery-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#065F46;" value="Recovery_Service" vertex="1">
          <mxGeometry height="22" width="350" x="690" y="863" as="geometry" />
        </mxCell>
        <mxCell id="dce-recovery-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#065F46;" value="[Java 21 + Spring — disparo por evento (abono) o batch diario]" vertex="1">
          <mxGeometry height="14" width="350" x="720" y="883" as="geometry" />
        </mxCell>
        <mxCell id="dce-recovery-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#065F46;spacingLeft=12;spacingTop=4;" value="Disparadores (4 caminos hacia Recovery_Service):&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;1. EVENTO — Abono acreditado:&#xa;     Novelty_Orchestrator (pestaña &#39;Flujo de novedades monetarias&#39;)&#xa;     tras SP_APPLY_MONETARY con type=ABONO&#xa;2. EVENTO — Ajuste Crédito de Pomelo:&#xa;     Adjustment_Service tras SP_APPLY_ADJUSTMENT type=CREDITO&#xa;3. EVENTO — Reverso que devuelve saldo:&#xa;     Motor txn (pestaña &#39;Flujo de transacciones&#39;)&#xa;     tras SP_REVERSE_TXN&#xa;4. BATCH — Catch-all nocturno:&#xa;     Recovery_Retry_Scheduler (cron 0 3 * * *, antigüedad ASC)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;EXEC SP_RECOVER_CHARGES(card_id, [available_balance]):&#xa;• Itera pending_charge ASC por created_at, status=PENDIENTE, no expirados&#xa;• Liquida hasta agotar saldo nuevo. Cada liquidación → transaction(RECOBRO)&#xa;• Vencimiento 90 días → status=EXPIRADA → archivo CINS&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;NOTA: el Charge_Settlement_Service NO dispara Recovery — los flujos&#xa;son inversos (settlement = débito; recovery = crédito sobre pendientes)." vertex="1">
          <mxGeometry height="106" width="425" x="672.5" y="900" as="geometry" />
        </mxCell>
        <mxCell id="dce-retry-sched" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#D97706;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="380" x="120" y="932" as="geometry" />
        </mxCell>
        <mxCell id="dce-retry-sched-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#D97706;" value="Recovery_Retry_Scheduler" vertex="1">
          <mxGeometry height="22" width="380" x="120" y="938" as="geometry" />
        </mxCell>
        <mxCell id="dce-retry-sched-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#D97706;" value="[Spring Batch CronJob diario]" vertex="1">
          <mxGeometry height="14" width="380" x="120" y="960" as="geometry" />
        </mxCell>
        <mxCell id="dce-retry-sched-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#D97706;spacingLeft=10;spacingTop=4;" value="Recorre pending_charge antiguos sin haber sido liquidados por evento.&#xa;• Cron: 0 3 * * * (03:00 diario)&#xa;• Antigüedad ASC, intenta SP_SETTLE_CHARGE&#xa;• Vencimiento 90 días → marca EXPIRADA + alerta operación" vertex="1">
          <mxGeometry height="74" width="370" x="125" y="977" as="geometry" />
        </mxCell>
        <mxCell id="dce-oracle" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="220" width="380" x="1080" y="1180" as="geometry" />
        </mxCell>
        <mxCell id="dce-oracle-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="Oracle Primary" vertex="1">
          <mxGeometry height="22" width="380" x="1080" y="1210" as="geometry" />
        </mxCell>
        <mxCell id="dce-oracle-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Oracle 19c — particionada por mes]" vertex="1">
          <mxGeometry height="14" width="380" x="1080" y="1232" as="geometry" />
        </mxCell>
        <mxCell id="dce-oracle-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=12;spacingTop=4;" value="Tablas:&lt;br&gt;• transaction (txn_type ∈ {CUOTA_MANEJO, GMF, COMISION,&lt;br&gt;                              TECH_EXITOSA, RECOBRO})&lt;br&gt;• pending_charge (status, expires_at, attempts)&lt;br&gt;• account (balance), card, fee_config (por AFG)&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;Stored Procedures:&lt;br&gt;• SP_SETTLE_CHARGE (atómico)&lt;br&gt;• SP_RECOVER_CHARGES&lt;br&gt;• SP_GMF_MONTHLY_BATCH" vertex="1">
          <mxGeometry height="130" width="310" x="1110" y="1250" as="geometry" />
        </mxCell>
        <mxCell id="dce-redis" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DC2626;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="138" width="280" x="1470" y="222" as="geometry" />
        </mxCell>
        <mxCell id="dce-redis-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#DC2626;" value="Redis Cluster" vertex="1">
          <mxGeometry height="22" width="280" x="1470" y="252" as="geometry" />
        </mxCell>
        <mxCell id="dce-redis-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#DC2626;" value="[Redis 7+ Sentinel HA]" vertex="1">
          <mxGeometry height="14" width="280" x="1470" y="274" as="geometry" />
        </mxCell>
        <mxCell id="dce-redis-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#DC2626;spacingLeft=10;spacingTop=4;" value="• Idempotency keys (charge_type+card+period)&lt;br&gt;• Lock distribuido SP_SETTLE_CHARGE&lt;br&gt;• Invalidación tras cada cobro" vertex="1">
          <mxGeometry height="48" width="270" x="1475" y="292" as="geometry" />
        </mxCell>
        <mxCell id="dce-states" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#92400E;fontColor=#92400E;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;dashed=1;dashPattern=4 2;" value="📋  ESTADOS DE pending_charge&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;PENDIENTE  ←  insert tras cobro NO efectivo&#xa;     ↓ (evento Abono o batch retry exitoso)&#xa;COBRADA   ←  liquidada (txn_type=RECOBRO en transaction)&#xa;     ↓ (90 días sin liquidación)&#xa;EXPIRADA  ←  reportada en archivo CINS&#xa;     ↓ (operación / acta)&#xa;CANCELADA ←  cancelada manualmente desde Portal Admin&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Vigencia 90 días = 3 meses (regla de negocio)." vertex="1">
          <mxGeometry height="200" width="380" x="1470" y="1440" as="geometry" />
        </mxCell>
        <mxCell id="dce-monetary-ref" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontColor=#5B21B6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;dashed=1;dashPattern=4 2;" value="🔗  DISPARADORES EVENTUALES&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;➤ HACIA Charge_Settlement_Service (cobros entrantes):&#xa;&#xa;Pestaña &#39;Flujo de transacciones&#39;:&#xa;• Denegación 51/55/57/61/75 →&#xa;     Tech_Exitosa_Charge_Engine.charge(...)&#xa;• Comisión calculada (POS/ATM) →&#xa;     Commission_Charge_Engine.charge(...)&#xa;&#xa;Pestaña &#39;Flujo de novedades monetarias&#39;:&#xa;• Cargo (type=CARGO) o GMF por archivo →&#xa;     Prepaid_Monetary_Novelty_Processor.charge(...)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;➤ HACIA Recovery_Service (abonos entrantes):&#xa;&#xa;Pestaña &#39;Flujo de novedades monetarias&#39;:&#xa;• Abono → Novelty_Orchestrator.recoverByEvent(card_id)&#xa;• Ajuste_Crédito Pomelo → Adjustment_Service.recoverByEvent(card_id)&#xa;&#xa;Pestaña &#39;Flujo de transacciones&#39;:&#xa;• Reverso con devolución de saldo → Motor txn.recoverByEvent(card_id)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Settlement y Recovery son flujos inversos:&#xa;Settlement = débito (sale plata); Recovery = drena pendientes." vertex="1">
          <mxGeometry height="380" width="500" x="2490" y="205" as="geometry" />
        </mxCell>
        <mxCell id="dce-ofg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="160" width="380" x="1490" y="490" as="geometry" />
        </mxCell>
        <mxCell id="dce-ofg-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="Output_File_Generator" vertex="1">
          <mxGeometry height="22" width="380" x="1490" y="498" as="geometry" />
        </mxCell>
        <mxCell id="dce-ofg-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Java 21 + Spring Batch — publisher único]" vertex="1">
          <mxGeometry height="14" width="380" x="1490" y="520" as="geometry" />
        </mxCell>
        <mxCell id="dce-ofg-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Lee de transaction y pending_charge, descifra PAN&#xa;en memoria y escribe archivos PLANOS en NFS:&#xa;• COMI dd.MM — Comisiones cobradas + recobros&#xa;• CSAT dd.MM — Comisiones satisfactorias&#xa;• CINS dd.MM — Comisiones insatisfactorias (3 meses)&#xa;• AUM dd.MM — Movimientos del día (incluye CUOTA_MANEJO, GMF)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Cron: 0 1 * * * (01:00 AM diario)&#xa;GAW cifra PGP y entrega vía SFTP a la Entidad." vertex="1">
          <mxGeometry height="106" width="370" x="1495" y="540" as="geometry" />
        </mxCell>
        <mxCell id="dce-audit" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
