        <mxCell id="S102A3fR_j41dhUKZe1R-32" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="135" width="280" x="2078" y="783.5" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-33" parent="1" style="text;html=1;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="APIs Pomelo" vertex="1">
          <mxGeometry height="25" width="280" x="2078" y="802.5" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-34" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Sistema Externo]&lt;br&gt;&lt;br&gt;• GET /affinity-groups/{id}&lt;br&gt;• GET /clients/{docType}/{docNumber}&lt;br&gt;• POST /clients&lt;br&gt;• POST /cards&lt;br&gt;• GET /cards/{id}/sensitive-data (PAN+exp+CVV2)" vertex="1">
          <mxGeometry height="90" width="270" x="2083" y="820.5" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-37" edge="1" parent="1" source="S102A3fR_j41dhUKZe1R-10" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#60A5FA;align=center;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="S102A3fR_j41dhUKZe1R-20" value="processRecord&lt;div&gt;(cardRequest)&lt;/div&gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-38" edge="1" parent="1" source="S102A3fR_j41dhUKZe1R-15" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#60A5FA;align=center;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="S102A3fR_j41dhUKZe1R-20" value="createCard&lt;div&gt;(cardRequest)&lt;/div&gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-40" edge="1" parent="1" source="S102A3fR_j41dhUKZe1R-20" style="endArrow=block;endFill=1;html=1;strokeColor=#60A5FA;strokeWidth=1.5;fontSize=8;fontColor=#60A5FA;align=center;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;entryPerimeter=0;edgeStyle=orthogonalEdgeStyle;" target="S102A3fR_j41dhUKZe1R-24" value="Persist: client, account,&lt;br&gt;card (pan_encrypted, pan_iv,&lt;br&gt;pan_auth_tag, dek_encrypted,&lt;br&gt;kek_version, pan_hash,&lt;br&gt;last_four, bin — SIN CVV2)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="env-enc-svc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;fontColor=default;" value="" vertex="1">
          <mxGeometry height="150" width="280" x="1354" y="1011" as="geometry" />
        </mxCell>
        <mxCell id="env-enc-svc-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;fontFamily=Helvetica;" value="Envelope_Encryption_Service" vertex="1">
          <mxGeometry height="22" width="280" x="1354" y="1019" as="geometry" />
        </mxCell>
        <mxCell id="env-enc-svc-tech" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;fontFamily=Helvetica;" value="[Component: Java 21 — JCE / BouncyCastle]" vertex="1">
          <mxGeometry height="14" width="280" x="1354" y="1041" as="geometry" />
        </mxCell>
        <mxCell id="env-enc-svc-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;fontFamily=Helvetica;" value="1. DEK = SecureRandom(32B) — AES-256&lt;br&gt;2. IV = SecureRandom(12B); AAD = card_id+created_at&lt;br&gt;3. AES-256-GCM(PAN, DEK, IV, AAD) → ciphertext+auth_tag&lt;br&gt;4. RSA-4096 OAEP(DEK, KEK_public) → dek_encrypted&lt;br&gt;5. Arrays.fill(DEK, 0); PAN = null (zeroización)&lt;br&gt;&lt;br&gt;Ver detalle: Envelope_Encryption_PAN.drawio" vertex="1">
          <mxGeometry height="95" width="270" x="1359" y="1059" as="geometry" />
        </mxCell>
        <mxCell id="kek-keystore" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;fontColor=default;" value="" vertex="1">
          <mxGeometry height="130" width="240" x="1788" y="1021" as="geometry" />
        </mxCell>
        <mxCell id="kek-keystore-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;fontFamily=Helvetica;" value="🔐 KEK_KeyStore" vertex="1">
          <mxGeometry height="22" width="240" x="1788" y="1027" as="geometry" />
        </mxCell>
        <mxCell id="kek-keystore-tech" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;fontFamily=Helvetica;" value="[PKCS12 KeyStore — OpenShift Secret]" vertex="1">
          <mxGeometry height="14" width="240" x="1788" y="1049" as="geometry" />
        </mxCell>
        <mxCell id="kek-keystore-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;fontFamily=Helvetica;" value="/secrets/kek-keystore.p12 (volume mount)&lt;br&gt;RSA-4096 OAEP (KEK_public + KEK_private)&lt;br&gt;Passphrase: env var KEK_KEYSTORE_PASS&lt;br&gt;Split knowledge (2 custodios)&lt;br&gt;Rotación cada 12 meses — versionada" vertex="1">
          <mxGeometry height="80" width="230" x="1793" y="1067" as="geometry" />
        </mxCell>
        <mxCell id="e-orch-env" edge="1" parent="1" source="S102A3fR_j41dhUKZe1R-20" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#60A5FA;align=center;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;rounded=1;verticalAlign=middle;fontFamily=Helvetica;labelBackgroundColor=default;" target="env-enc-svc" value="6. encryptPan(pan, cardId)&#xa;AES-256-GCM + RSA-4096 OAEP">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1494" y="968" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-env-orch" edge="1" parent="1" source="env-enc-svc" style="endArrow=block;endFill=1;html=1;strokeColor=#D97706;strokeWidth=1.5;fontSize=8;fontColor=#92400E;align=center;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.731;entryY=1.002;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;entryPerimeter=0;" target="S102A3fR_j41dhUKZe1R-20" value="Retorna pan_encrypted, pan_iv,&#xa;pan_auth_tag, dek_encrypted,&#xa;kek_version">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1192" y="1086" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-env-kek" edge="1" parent="1" source="env-enc-svc" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#60A5FA;align=center;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;rounded=1;verticalAlign=middle;fontFamily=Helvetica;labelBackgroundColor=default;" target="kek-keystore" value="load(KEK_vN)&#xa;passphrase from Secret">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="nota-pci-cifrado" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#991B1B;fontStyle=1;" value="PCI DSS v4.0 — ALMACENAMIENTO:&lt;br&gt;&lt;br&gt;✅ PAN: envelope encryption (Req 3.4/3.5)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;AES-256-GCM (datos) + RSA-4096 OAEP (DEK)&lt;br&gt;✅ DEK por tarjeta, cifrada con KEK&lt;br&gt;✅ KEK en PKCS12 + OpenShift Secret&lt;br&gt;✅ Passphrase split knowledge (Req 3.6.6)&lt;br&gt;✅ Dual control sobre KEK (Req 3.6.7)&lt;br&gt;✅ PAN hash: SHA-256 para búsquedas&lt;br&gt;✅ Last 4: en claro (permitido Req 3.3)&lt;br&gt;✅ BIN: en claro (dato público)&lt;br&gt;✅ Card token: en claro (no es PAN)&lt;br&gt;✅ TDE Oracle: defense-in-depth&lt;br&gt;&lt;br&gt;❌ CVV2: PROHIBIDO almacenar (Req 3.3.2)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;Se descarta inmediatamente post-creación&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;Visualización: consulta Pomelo en tiempo real" vertex="1">
          <mxGeometry height="260" width="280" x="310" y="950" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-42" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;pointerEvents=0;align=center;verticalAlign=top;fontFamily=Helvetica;fontSize=12;fontColor=default;gradientColor=none;" value="" vertex="1">
          <mxGeometry height="131" width="340" x="1436" y="789.5" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-43" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Pomelo _API_Client" vertex="1">
