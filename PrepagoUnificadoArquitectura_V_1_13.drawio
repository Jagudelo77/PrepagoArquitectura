        <mxCell id="L-JxTnSPuCsDWRgZwE4I-14" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="&lt;b&gt;Pipeline autorización:&lt;/b&gt; 1.Resuelve tarjeta(Oracle) → 2.Lee AFG config(Redis→Oracle fallback) →&amp;nbsp;&lt;div&gt;3.Valida estado → 4.CHECK límites(Limit Counter) → 5.Reglas negocio + Plan Validación Comercio(MCC/CU incl/excl)&amp;nbsp;&lt;/div&gt;&lt;div&gt;→ 6.Calcula comisión(red+canal+exentas) → 7.Calcula GMF(si entidad=línea y tarjeta no exenta) →&lt;br&gt;8.SP_AUTHORIZE_TXN(débito atómico) → 9.INCREMENT contadores&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(59, 130, 246), rgb(76, 137, 236));&quot;&gt;→ 10.Response code + Audit async.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Si denegada(51,55,57,61,75):&lt;/b&gt; SP_CHARGE_TECH_EXITOSA.&lt;br&gt;&lt;b&gt;Reverso/Anulación:&lt;/b&gt; match txn original (RRN+auth_code+amount+terminal)&amp;nbsp;&lt;/div&gt;&lt;div&gt;→ idempotencia (flag reversada/anulada) → DECREMENT contadores →&amp;nbsp;&lt;/div&gt;&lt;div&gt;reusa auth_code (reverso) o genera nuevo (anulación)&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="470" x="625" y="902" as="geometry" />
        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-19" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="140" width="290" x="805" y="1360" as="geometry" />
        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-20" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Oracle Primary" vertex="1">
          <mxGeometry height="22" width="240" x="834" y="1385" as="geometry" />
        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-21" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Oracle Database 19c+ — Read/Write]" vertex="1">
          <mxGeometry height="15" width="240" x="834" y="1407" as="geometry" />
        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-22" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="&lt;b&gt;Stored Procedures:&lt;/b&gt;&lt;br&gt;SP_AUTHORIZE_TXN: débito atómico (monto+comisión+GMF)&lt;br&gt;SP_CHARGE_TECH_EXITOSA: cobro txn denegadas&lt;br&gt;SP_FALLBACK_READ: lee config si Redis down&lt;br&gt;Tabla transaction particionada por mes." vertex="1">
          <mxGeometry height="60" width="230" x="839" y="1427" as="geometry" />
        </mxCell>
