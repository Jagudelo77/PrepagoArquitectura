        <mxCell id="onb-sso-d" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#065F46;fillColor=none;strokeColor=none;whiteSpace=wrap;" value="POST /admin/realms/cardholder/users&#xa;• username = doc_number&#xa;• password (hash bcrypt/argon2)&#xa;• attributes: client_id, entity_id, email, phone&#xa;• role: CARDHOLDER · enabled: true&#xa;OAuth2 / OIDC / JWT / MFA." vertex="1">
          <mxGeometry height="72" width="270" x="1675" y="696" as="geometry" />
        </mxCell>
