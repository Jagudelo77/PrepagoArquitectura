        <mxCell id="1" parent="0" />
        <mxCell id="pth-title" parent="1" style="text;html=1;fontSize=20;fontStyle=1;align=left;fontColor=#000000;" value="Portal Tarjetahabiente — Onboarding + Activacion + PIN + Datos Sensibles + Autoservicio" vertex="1">
          <mxGeometry height="32" width="2000" x="40" y="30" as="geometry" />
        </mxCell>
        <mxCell id="pth-subtitle" parent="1" style="text;html=1;fontSize=11;align=left;fontColor=#9CA3AF;" value="C4 Level 2  |  Procesos del TH en el Portal Web Prepago. PIN, activacion, visualizacion de datos sensibles e innominadas via iframe de Pomelo (ADR-031). Onboarding, login, password via SSO Keycloak." vertex="1">
          <mxGeometry height="20" width="2100" x="40" y="65" as="geometry" />
        </mxCell>
        <object placeholders="1" c4Name="Credibanco" c4Type="SystemScopeBoundary" c4Application="Software System" label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;&lt;div style=&quot;text-align: left&quot;&gt;%c4Name%&lt;/div&gt;&lt;/b&gt;&lt;/font&gt;&lt;div style=&quot;text-align: left&quot;&gt;[%c4Application%]&lt;/div&gt;" id="pth-cred">
          <mxCell parent="1" style="rounded=1;fontSize=11;whiteSpace=wrap;html=1;dashed=1;arcSize=20;fillColor=none;strokeColor=#003366;fontColor=#333333;labelBackgroundColor=none;align=left;verticalAlign=bottom;labelBorderColor=none;spacingTop=0;spacing=10;dashPattern=8 4;metaEdit=1;rotatable=0;perimeter=rectanglePerimeter;noLabel=0;labelPadding=0;allowArrows=0;connectable=0;expand=0;recursiveResize=0;editable=1;pointerEvents=0;absoluteArcSize=1;strokeWidth=2;" vertex="1">
            <mxGeometry height="1500" width="2120" x="20" y="100" as="geometry" />
          </mxCell>
        </object>
        <object placeholders="1" c4Name="OpenShift" c4Type="SystemScopeBoundary" c4Application="Container Platform" label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;&lt;div style=&quot;text-align: left&quot;&gt;%c4Name%&lt;/div&gt;&lt;/b&gt;&lt;/font&gt;&lt;div style=&quot;text-align: left&quot;&gt;[%c4Application%]&lt;/div&gt;" id="pth-ocp">
          <mxCell parent="1" style="rounded=1;fontSize=11;whiteSpace=wrap;html=1;dashed=1;arcSize=20;fillColor=none;strokeColor=#CC0000;fontColor=#CC0000;labelBackgroundColor=none;align=left;verticalAlign=bottom;labelBorderColor=none;spacingTop=0;spacing=10;dashPattern=8 4;metaEdit=1;rotatable=0;perimeter=rectanglePerimeter;noLabel=0;labelPadding=0;allowArrows=0;connectable=0;expand=0;recursiveResize=0;editable=1;pointerEvents=0;absoluteArcSize=1;strokeWidth=2;" vertex="1">
            <mxGeometry height="1420" width="2060" x="40" y="120" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="pth-th" parent="1" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.users;labelBackgroundColor=none;sketch=0;fillColor=#D45B07;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="60" width="60" x="80" y="200" as="geometry" />
        </mxCell>
        <mxCell id="pth-th-label" parent="1" style="text;html=1;align=center;verticalAlign=top;fontSize=11;fontColor=#333333;" value="&lt;b&gt;Tarjetahabiente&lt;/b&gt;" vertex="1">
          <mxGeometry height="20" width="100" x="60" y="265" as="geometry" />
        </mxCell>
        <mxCell id="pth-portal" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="160" width="380" x="250" y="180" as="geometry" />
        </mxCell>
        <mxCell id="pth-portal-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="Portal Tarjetahabiente" vertex="1">
          <mxGeometry height="22" width="380" x="250" y="186" as="geometry" />
        </mxCell>
        <mxCell id="pth-portal-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Container: Angular 17+ SPA — portal.prepago.credibanco.com]" vertex="1">
          <mxGeometry height="14" width="380" x="250" y="208" as="geometry" />
        </mxCell>
        <mxCell id="pth-portal-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Funciones del TH:&#xa;• Pre-registro (link por email)&#xa;• Login (documento + contrasena)&#xa;• Restablecer / Cambiar contrasena&#xa;• Activar tarjeta (abre iframe Pomelo)&#xa;• Cambio de PIN (abre iframe Pomelo)&#xa;• Ver datos sensibles (abre iframe Pomelo)&#xa;• Consulta saldo, historial, bloqueo (Fase 2)" vertex="1">
          <mxGeometry height="118" width="370" x="255" y="225" as="geometry" />
        </mxCell>
        <mxCell id="pth-iframe-pomelo" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;arcSize=8;dashed=1;dashPattern=8 4;" value="" vertex="1">
          <mxGeometry height="200" width="380" x="250" y="420" as="geometry" />
        </mxCell>
        <mxCell id="pth-iframe-pomelo-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#5B21B6;" value="Iframe de Pomelo" vertex="1">
          <mxGeometry height="22" width="380" x="250" y="428" as="geometry" />
        </mxCell>
        <mxCell id="pth-iframe-pomelo-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#5B21B6;" value="[Sistema Externo — Dominio Pomelo · HSM de Pomelo]" vertex="1">
          <mxGeometry height="14" width="380" x="250" y="450" as="geometry" />
        </mxCell>
        <mxCell id="pth-iframe-pomelo-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#5B21B6;spacingLeft=10;spacingTop=4;" value="4 procesos delegados a Pomelo (ADR-031):&#xa;1. Activacion de tarjeta nominada (asignacion PIN)&#xa;2. Cambio de PIN (PIN actual + nuevo)&#xa;3. Mostrar datos sensibles (PAN / CVV2 / exp)&#xa;4. Activacion de tarjeta innominada (Fase 2)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;El PIN nunca toca infraestructura de Credibanco.&#xa;Los datos sensibles los renderiza Pomelo.&#xa;Credibanco solo orquesta apertura + recibe confirmacion." vertex="1">
          <mxGeometry height="130" width="370" x="255" y="467" as="geometry" />
        </mxCell>
        <mxCell id="pth-bff" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="160" width="380" x="780" y="180" as="geometry" />
        </mxCell>
        <mxCell id="pth-bff-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="Cardholder_API (BFF)" vertex="1">
          <mxGeometry height="22" width="380" x="780" y="186" as="geometry" />
        </mxCell>
        <mxCell id="pth-bff-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Container: Java 21 + Spring Boot 3 + WebFlux — Pods OpenShift]" vertex="1">
          <mxGeometry height="14" width="380" x="780" y="208" as="geometry" />
        </mxCell>
        <mxCell id="pth-bff-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Backend del portal tarjetahabiente:&#xa;• POST /api/preregistro/verify (doc_type + doc_number + email)&#xa;• POST /api/preregistro/otp/validate&#xa;• POST /api/preregistro/password&#xa;• POST /api/auth/login&#xa;• POST /api/auth/reset-password&#xa;• GET /api/cards/{cardId}/activate → orquesta iframe Pomelo&#xa;• GET /api/cards/{cardId}/change-pin → orquesta iframe Pomelo&#xa;• GET /api/cards/{cardId}/sensitive-data → orquesta iframe Pomelo" vertex="1">
          <mxGeometry height="118" width="370" x="785" y="225" as="geometry" />
        </mxCell>
        <mxCell id="pth-prereg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="140" width="350" x="780" y="420" as="geometry" />
        </mxCell>
        <mxCell id="pth-prereg-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="PreRegistration_Service" vertex="1">
          <mxGeometry height="22" width="350" x="780" y="426" as="geometry" />
        </mxCell>
        <mxCell id="pth-prereg-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Java 21 + Spring Service]" vertex="1">
          <mxGeometry height="14" width="350" x="780" y="448" as="geometry" />
        </mxCell>
        <mxCell id="pth-prereg-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Orquestador del onboarding (ADR-016/023/024/025):&#xa;• Genera code UUID v4 + persiste preregistration&#xa;• Invoca OTP_Service para generar OTP&#xa;• Envia email de pre-registro via B2B_Mail_Service&#xa;• Verifica identidad: doc_type + doc_number + email&#xa;• Crea usuario en SSO Keycloak (Realm CARDHOLDER)&#xa;• TTL 30 dias, max 3 intentos" vertex="1">
          <mxGeometry height="100" width="340" x="785" y="465" as="geometry" />
        </mxCell>
        <mxCell id="pth-otp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="280" x="780" y="620" as="geometry" />
        </mxCell>
        <mxCell id="pth-otp-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="OTP_Service" vertex="1">
          <mxGeometry height="22" width="280" x="780" y="626" as="geometry" />
        </mxCell>
        <mxCell id="pth-otp-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Java 21 + Spring] (ADR-024)" vertex="1">
          <mxGeometry height="14" width="280" x="780" y="648" as="geometry" />
        </mxCell>
        <mxCell id="pth-otp-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Solo genera/valida OTP (6 digitos, 5 min):&#xa;• issueOtp(client_id) → code en memoria&#xa;• validateOtp(client_id, code) → boolean&#xa;• NO envia emails (lo orquesta PreReg_Service)" vertex="1">
          <mxGeometry height="65" width="270" x="785" y="665" as="geometry" />
        </mxCell>
        <mxCell id="pth-sso" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="140" width="350" x="1280" y="180" as="geometry" />
        </mxCell>
        <mxCell id="pth-sso-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;" value="SSO Keycloak" vertex="1">
          <mxGeometry height="22" width="350" x="1280" y="186" as="geometry" />
        </mxCell>
        <mxCell id="pth-sso-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;" value="[Container: Keycloak — Realm CARDHOLDER — OIDC/OAuth2/JWT]" vertex="1">
          <mxGeometry height="14" width="350" x="1280" y="208" as="geometry" />
        </mxCell>
        <mxCell id="pth-sso-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;spacingLeft=10;spacingTop=4;" value="Gestion de identidad TH:&#xa;• Login: documento + contrasena → JWT (TTL 30 min)&#xa;• Password policy: min 12 chars, 1 mayus, 1 num, 1 especial&#xa;• Max 3 intentos login → bloqueo 24h&#xa;• Restablecer: link por email + BIN + last4&#xa;• Cambiar: con contrasena actual&#xa;• MFA step-up antes de iframe sensible (Req 8.3.6)&#xa;• Bloqueo definitivo por 3 datos errados en pre-registro" vertex="1">
          <mxGeometry height="105" width="340" x="1285" y="225" as="geometry" />
        </mxCell>
        <mxCell id="pth-mail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
