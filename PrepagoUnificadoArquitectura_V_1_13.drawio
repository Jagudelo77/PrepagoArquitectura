        <mxCell id="onb-portal-d" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;whiteSpace=wrap;" value="URL: preregistro.credibanco.com/registro/{code}&lt;br&gt;Pasos UX: 1) verificar identidad (tipo+núm doc + correo) →&lt;br&gt;2) ingresar OTP → 3) crear contraseña → 4) ir al Portal TH&lt;br&gt;Validaciones de cliente (longitud password, etc.)&lt;br&gt;CAPTCHA + rate limiting" vertex="1">
          <mxGeometry height="70" width="270" x="725" y="221.5" as="geometry" />
        </mxCell>
        <mxCell id="onb-api" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=default;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="145" width="320" x="1230" y="164" as="geometry" />
        </mxCell>
        <mxCell id="onb-api-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="PreRegistration_API" vertex="1">
          <mxGeometry height="20" width="320" x="1230" y="172" as="geometry" />
        </mxCell>
        <mxCell id="onb-api-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot 3 + WebFlux]" vertex="1">
          <mxGeometry height="14" width="320" x="1230" y="192" as="geometry" />
        </mxCell>
        <mxCell id="onb-api-d" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;whiteSpace=wrap;" value="POST /api/preregistro/verify (doc_type + doc_number + email)&lt;br&gt;POST /api/preregistro/validate-otp&lt;br&gt;POST /api/preregistro/resend-otp&lt;br&gt;POST /api/preregistro/create-account&lt;br&gt;Validaciones de schema y autenticación.&lt;br&gt;Delega lógica de negocio en PreRegistration_Service.&lt;br&gt;session_registro post-OTP (TTL 10 min)." vertex="1">
          <mxGeometry height="95" width="310" x="1235" y="209" as="geometry" />
        </mxCell>
        <mxCell id="onb-prereg-svc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;fontColor=default;" value="" vertex="1">
          <mxGeometry height="160" width="640" x="1070" y="380" as="geometry" />
        </mxCell>
        <mxCell id="onb-prereg-svc-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="PreRegistration_Service" vertex="1">
          <mxGeometry height="22" width="640" x="1070" y="388" as="geometry" />
        </mxCell>
        <mxCell id="onb-prereg-svc-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Service — núcleo de negocio del onboarding]" vertex="1">
          <mxGeometry height="14" width="540" x="1130" y="410" as="geometry" />
        </mxCell>
        <mxCell id="onb-prereg-svc-d" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;whiteSpace=wrap;spacingLeft=12;spacingTop=4;" value="1. createPreRegistration(client_id, email) — disparado desde Prepaid_Card_Creation_Orchestrator (ver pestaña &#39;Creacion de tarjetas&#39;)&#xa;     • Idempotente: si ya existe PENDING vigente para client_id → reusar&#xa;     • code = UUID v4, expires_at = NOW + 30 días, status = PENDIENTE&#xa;     • INSERT preregistration; invoca B2B_Mail_Service (URL pre-registro)&#xa;2. verifyIdentity(code, doc_type, doc_number, email) — Fase 2: valida tipo+número de doc + correo vs cliente; max 3 intentos → BLOQUEADO&#xa;3. requestOtp(code) — Fase 3: invoca OTP_Service.issueOtp(client_id, purpose=PRE_REGISTRO); orquesta envío vía B2B_Mail_Service&#xa;4. confirmOtp(code, otp) — invoca OTP_Service.validateOtp; si OK emite session_registro (TTL 10 min)&#xa;5. createAccount(code, password) — Fase 4: crea usuario en SSO Realm CARDHOLDER; status=COMPLETADO; orquesta email confirmación" vertex="1">
          <mxGeometry height="105" width="620" x="1080" y="428" as="geometry" />
        </mxCell>
        <mxCell id="onb-notif" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#7C3AED;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="140" width="320" x="1050" y="710" as="geometry" />
        </mxCell>
        <mxCell id="onb-notif-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#5B21B6;fillColor=none;strokeColor=none;" value="B2B_Mail_Service" vertex="1">
          <mxGeometry height="20" width="320" x="1050" y="718" as="geometry" />
        </mxCell>
        <mxCell id="onb-notif-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#5B21B6;fillColor=none;strokeColor=none;" value="[Container: Servicio existente en CCO — cliente SMTP corporativo]" vertex="1">
          <mxGeometry height="14" width="320" x="1050" y="738" as="geometry" />
        </mxCell>
        <mxCell id="onb-notif-d" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#5B21B6;fillColor=none;strokeColor=none;whiteSpace=wrap;" value="Servicio único de envío de correos transaccionales en CCO.&#xa;Compartido por todos los componentes que requieren email&#xa;(onboarding TH, distribución a entidades emisoras, alertas).&#xa;Templates HTML por tipo de mensaje. Audit log por envío.&#xa;Sin PAN ni datos sensibles. TLS 1.3 al SMTP corporativo." vertex="1">
          <mxGeometry height="90" width="310" x="1055" y="756" as="geometry" />
        </mxCell>
        <mxCell id="onb-sso" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#10B981;strokeWidth=2;arcSize=8;" value="" vertex="1">
