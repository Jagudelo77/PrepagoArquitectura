        </mxCell>
        <mxCell id="prom-label" value="&lt;b&gt;Prometheus + Grafana&lt;/b&gt;&lt;br&gt;Métricas + Dashboards&lt;br&gt;AlertManager&lt;br&gt;&lt;font color=&apos;#666&apos; style=&apos;font-size:8px;&apos;&gt;equiv: CloudWatch&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;fontSize=10;fontColor=#E7157B;" parent="1" vertex="1">
          <mxGeometry x="1895" y="275" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- ==================== OPENSHIFT (equiv ROSA) ==================== -->
        <mxCell id="ocp-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#E53935;verticalAlign=top;fontSize=13;arcSize=4;dashed=1;dashPattern=8 4;" parent="1" vertex="1">
          <mxGeometry x="1530" y="380" width="330" height="580" as="geometry" />
        </mxCell>
        <mxCell id="ocp-title" value="&lt;font color=&apos;#E53935&apos; style=&apos;font-size:14px;&apos;&gt;&lt;b&gt;OpenShift Container Platform&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&apos;#666&apos; style=&apos;font-size:9px;&apos;&gt;equiv: ROSA (Red Hat OpenShift on AWS)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="1545" y="385" width="300" height="35" as="geometry" />
        </mxCell>
        <!-- CARD PROVISIONING SERVICE -->
        <mxCell id="card-svc" value="&lt;b&gt;Card Provisioning Service&lt;/b&gt;&lt;br&gt;(Spring Boot Pod)&lt;br&gt;&lt;br&gt;Lógica por registro:&lt;br&gt;1) Upsert Cliente&lt;br&gt;2) Validar Grupo Afinidad&lt;br&gt;3) Crear Cuenta si no existe&lt;br&gt;4) Invocar API Emisor (mTLS)&lt;br&gt;5) Persistir resultado (PG schema prepago)&lt;br&gt;6) UPSERT file_record_result (PG schema batch)&lt;br&gt;&lt;font color=&apos;#7B1FA2&apos; style=&apos;font-size:8px;&apos;&gt;⚡ Lee workflowRunId del RabbitMQ header&lt;br&gt;(sin round-trip a DB para correlationId)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E53935;fontColor=#B71C1C;fontSize=10;arcSize=6;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="1560" y="435" width="260" height="230" as="geometry" />
        </mxCell>
        <!-- RESILIENCE4J -->
        <mxCell id="retry-box" value="&lt;b&gt;Resilience4j&lt;/b&gt;&lt;br&gt;&lt;font style=&apos;font-size:8px;&apos;&gt;CircuitBreaker: CLOSED→OPEN→HALF_OPEN&lt;br&gt;Retry: maxAttempts=3, backoff exponencial&lt;br&gt;Bulkhead: maxConcurrent=50&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontColor=#E65100;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="1560" y="685" width="260" height="60" as="geometry" />
        </mxCell>
        <!-- HEARTBEAT SENDER -->
        <mxCell id="heartbeat-box" value="&lt;b&gt;Heartbeat Sender&lt;/b&gt;&lt;br&gt;&lt;font style=&apos;font-size:8px;&apos;&gt;Temporal Activity Heartbeat cada 300s&lt;br&gt;Si recibe TimeoutError → stop processing&lt;br&gt;workflowRunId del RabbitMQ header&lt;/font&gt;&lt;br&gt;&lt;font color=&apos;#666&apos; style=&apos;font-size:8px;&apos;&gt;equiv: SendTaskHeartbeat&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontColor=#1B5E20;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="1560" y="765" width="260" height="70" as="geometry" />
        </mxCell>
        <!-- EVENT PUBLISHER -->
        <mxCell id="event-pub-box" value="&lt;b&gt;Event Publisher&lt;/b&gt;&lt;br&gt;&lt;font style=&apos;font-size:8px;&apos;&gt;Publica batch_completed a Kafka&lt;br&gt;Payload: {file_id, workflowRunId,&lt;br&gt;total_ok, total_error, minio_key}&lt;/font&gt;&lt;br&gt;&lt;font color=&apos;#666&apos; style=&apos;font-size:8px;&apos;&gt;equiv: EventBridge event publisher&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;fontColor=#283593;fontSize=9;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="1560" y="855" width="260" height="70" as="geometry" />
        </mxCell>
        <!-- API POMELO -->
        <mxCell id="api-pomelo" value="&lt;b&gt;API Pomelo&lt;/b&gt;&lt;br&gt;(Crear cliente + tarjeta)&lt;br&gt;&lt;font color=&quot;#E65100&quot; style=&quot;font-size: 8px;&quot;&gt;🔒 mTLS (certs from Vault PKI)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF6F00;fontColor=#E65100;fontSize=11;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="1960" y="510" width="170" height="90" as="geometry" />
        </mxCell>
        <!-- KAFKA BATCH COMPLETED (equiv EventBridge batch_completed) -->
        <mxCell id="kafka-batch" value="📡" style="text;html=1;align=center;verticalAlign=middle;fontSize=28;" parent="1" vertex="1">
          <mxGeometry x="1305" y="1080" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="kafka-batch-label" value="&lt;b&gt;Kafka&lt;/b&gt;&lt;br&gt;topic: batch.completed&lt;br&gt;&lt;font style=&apos;font-size:8px;&apos;&gt;{file_id, workflowRunId,&lt;br&gt;total_ok, total_error}&lt;/font&gt;&lt;br&gt;&lt;font color=&apos;#666&apos; style=&apos;font-size:8px;&apos;&gt;equiv: EventBridge&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;fontSize=9;fontColor=#E7157B;" parent="1" vertex="1">
          <mxGeometry x="1255" y="1123" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- ==================== EQUIVALENCE TABLE ==================== -->
        <mxCell id="equiv-box" value="&lt;b&gt;📋 Tabla de Equivalencias AWS → On-Premises&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&apos;font-size:9px;&apos;&gt;&lt;b&gt;S3&lt;/b&gt; → MinIO (S3-compatible API)&lt;br&gt;&lt;b&gt;Step Functions&lt;/b&gt; → Temporal.io (durable workflows)&lt;br&gt;&lt;b&gt;SQS&lt;/b&gt; → RabbitMQ (AMQP)&lt;br&gt;&lt;b&gt;EventBridge&lt;/b&gt; → Apache Kafka (event streaming)&lt;br&gt;&lt;b&gt;Lambda&lt;/b&gt; → Spring Boot Pods (OpenShift)&lt;br&gt;&lt;b&gt;SNS/SES&lt;/b&gt; → Kafka topic + SMTP (Postfix/Exchange)&lt;br&gt;&lt;b&gt;DynamoDB&lt;/b&gt; → Redis (TTL cache)&lt;br&gt;&lt;b&gt;RDS + RDS Proxy&lt;/b&gt; → PostgreSQL + PgBouncer + Patroni HA&lt;br&gt;&lt;b&gt;ROSA&lt;/b&gt; → OpenShift Container Platform (OCP)&lt;br&gt;&lt;b&gt;KMS + Secrets Manager&lt;/b&gt; → HashiCorp Vault (Transit + KV + PKI)&lt;br&gt;&lt;b&gt;CloudWatch&lt;/b&gt; → Prometheus + Grafana + AlertManager&lt;br&gt;&lt;br&gt;&lt;b&gt;Callback Pattern:&lt;/b&gt;&lt;br&gt;  · SendTaskSuccess → Temporal Signal &apos;complete&apos;&lt;br&gt;  · SendTaskFailure → Temporal Signal &apos;fail&apos;&lt;br&gt;  · SendTaskHeartbeat → Temporal Activity Heartbeat&lt;br&gt;  · taskToken → workflowRunId (en RabbitMQ header)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=10;arcSize=6;verticalAlign=top;align=left;spacingLeft=8;spacingRight=8;" parent="1" vertex="1">
          <mxGeometry x="1560" y="1070" width="320" height="260" as="geometry" />
        </mxCell>
        <!-- ==================== EDGES ==================== -->
        <!-- Entidad → SFTP -->
        <mxCell id="e-ent-sftp" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#5C6BC0;strokeWidth=2;entryX=0;entryY=0.75;" parent="1" source="ent-box" target="sftp" edge="1">
          <mxGeometry relative="1" as="geometry" />
