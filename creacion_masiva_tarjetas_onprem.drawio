        </mxCell>
        <mxCell id="minio-out-label" value="&lt;b&gt;MinIO&lt;/b&gt;&lt;br&gt;/outbound&lt;br&gt;&lt;font color=&apos;#E65100&apos; style=&apos;font-size:8px;&apos;&gt;🔒 SSE (Vault)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;fontSize=10;fontColor=#3F8624;" parent="1" vertex="1">
          <mxGeometry x="550" y="715" width="110" height="50" as="geometry" />
