        </mxCell>
        <mxCell id="vault-secrets-label" value="&lt;b&gt;Vault Secret Engine&lt;/b&gt;&lt;br&gt;&lt;font color=&apos;#666&apos; style=&apos;font-size:8px;&apos;&gt;equiv: Secrets Manager&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;fontSize=10;fontColor=#DD344C;" parent="1" vertex="1">
