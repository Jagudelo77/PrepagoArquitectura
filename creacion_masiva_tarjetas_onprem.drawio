          <mxGeometry x="595" y="805" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="smtp-label" value="&lt;b&gt;SMTP Server&lt;/b&gt;&lt;br&gt;(Postfix / Exchange)&lt;br&gt;&lt;font color=&apos;#666&apos; style=&apos;font-size:8px;&apos;&gt;equiv: SES&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;fontSize=9;fontColor=#DD344C;" parent="1" vertex="1">
          <mxGeometry x="560" y="840" width="100" height="40" as="geometry" />
