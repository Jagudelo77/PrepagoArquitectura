        <mxCell id="e-sftp-ga" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3F51B5;strokeWidth=2;" parent="1" source="sftp" target="goanywhere" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-sftp-ga-lbl" value="Detecta archivo" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#3F51B5;" parent="e-sftp-ga" connectable="0" vertex="1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint x="10" as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- GoAnywhere → MinIO inbound -->
        <mxCell id="e-ga-minio" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3F8624;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" parent="1" source="goanywhere" target="minio-in-icon" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-ga-minio-lbl" value="Deposita archivo validado" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#3F8624;" parent="e-ga-minio" connectable="0" vertex="1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint y="-15" as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- MinIO → Kafka (bucket notification) -->
        <mxCell id="e-minio-kafka" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E7157B;strokeWidth=2;" parent="1" source="minio-in-icon" target="kafka-s3" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="605" y="283" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-minio-kafka-lbl" value="Bucket Notification&lt;br&gt;(MinIO → Kafka)" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#E7157B;" parent="e-minio-kafka" connectable="0" vertex="1">
          <mxGeometry x="-0.3" relative="1" as="geometry">
            <mxPoint x="-10" as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- Kafka → Validator Service -->
        <mxCell id="e-kafka-val" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#D45B07;strokeWidth=2;" parent="1" source="kafka-s3" target="validator-svc" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-kafka-val-lbl" value="Consumer" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#D45B07;" parent="e-kafka-val" connectable="0" vertex="1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint y="-12" as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- Validator → Redis -->
        <mxCell id="e-val-redis" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#C925D1;strokeWidth=1;dashed=1;" parent="1" source="validator-svc" target="redis-icon" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="770" y="285" />
              <mxPoint x="660" y="285" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-val-redis-lbl" value="Check file_hash" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=8;fontColor=#C925D1;" parent="e-val-redis" connectable="0" vertex="1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint y="-12" as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- Validator → Temporal -->
        <mxCell id="e-val-temporal" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E7157B;strokeWidth=2;" parent="1" source="validator-svc" target="temporal-box" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-val-temporal-lbl" value="Start Workflow&lt;br&gt;(minio_key, file_id,&lt;br&gt;total_records)" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#E7157B;" parent="e-val-temporal" connectable="0" vertex="1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint y="-20" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Temporal → PostgreSQL -->
        <mxCell id="e-temporal-pg" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#C925D1;strokeWidth=1;dashed=1;exitX=0;exitY=0.5;" parent="1" target="pg-proxy" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="900" y="385" />
              <mxPoint x="900" y="1075" />
            </Array>
            <mxPoint x="945" y="385" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e-temporal-pg-lbl" value="INSERT file_batch&lt;br&gt;(workflowRunId viaja&lt;br&gt;por RabbitMQ header)" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=8;fontColor=#C925D1;" parent="e-temporal-pg" connectable="0" vertex="1">
          <mxGeometry x="-0.5" relative="1" as="geometry">
            <mxPoint x="-55" y="-43" as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- Temporal Fan-Out → RabbitMQ -->
        <mxCell id="e-fanout-rabbit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7B1FA2;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" parent="1" source="step3" target="rabbit-work" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-fanout-rabbit-lbl" value="Encola 1 msg por solicitud&lt;br&gt;&lt;font style=&apos;font-size:8px;&apos;&gt;Header: workflowRunId&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#7B1FA2;" parent="e-fanout-rabbit" connectable="0" vertex="1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint x="-3" y="-25" as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- RabbitMQ → DLQ -->
        <mxCell id="e-rabbit-dlq" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;" parent="1" source="rabbit-work" target="rabbit-dlq" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-rabbit-dlq-lbl" value="Dead Letter Exchange" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=8;fontColor=#999999;" parent="e-rabbit-dlq" connectable="0" vertex="1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint y="15" as="offset" />
          </mxGeometry>
        </mxCell>
        <!-- DLQ → Prometheus Alarm -->
        <mxCell id="e-dlq-prom" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E7157B;strokeWidth=1;dashed=1;" parent="1" source="rabbit-dlq" target="prom-alarm" edge="1">
