        </mxCell>
        <mxCell id="kafka-notify-label" value="&lt;b&gt;Kafka&lt;/b&gt;&lt;br&gt;topic: notifications&lt;br&gt;&lt;font color=&apos;#666&apos; style=&apos;font-size:8px;&apos;&gt;equiv: SNS&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;fontSize=10;fontColor=#E7157B;" parent="1" vertex="1">
          <mxGeometry x="660" y="838" width="100" height="40" as="geometry" />
