          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f2_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 2 — Iframe solicita datos sensibles al backend (TLS 1.3, viewToken de un solo uso)" vertex="1">
          <mxGeometry height="22" width="1410" x="30" y="430" as="geometry" />
        </mxCell>
        <mxCell id="f2_i1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="POST /api/card-data/request&#xa;{ cardId, sessionToken,&#xa;  action: &#39;VIEW_CARD_DATA&#39; }&#xa;Headers: Origin, X-Correlation-Id&#xa;TLS 1.3 — No cache" vertex="1">
          <mxGeometry height="80" width="260" x="350" y="477" as="geometry" />
        </mxCell>
        <mxCell id="f2_b1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Valida:&#xa;• sessionToken activo (SSO)&#xa;• MFA completado para esta sesión&#xa;• Origin === secure-data.credibanco.*&#xa;• Rate limit: &lt; 3 views/tarjeta/hora&#xa;• cardId pertenece al usuario&#xa;Genera viewToken (UUID, TTL 30s, 1 uso)" vertex="1">
          <mxGeometry height="105" width="230" x="670" y="465" as="geometry" />
        </mxCell>
        <mxCell id="e_f2_1" edge="1" parent="1" source="f2_i1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666666;strokeWidth=1.5;fontSize=9;fontColor=#666666;" target="f2_b1" value="TLS 1.3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_f1i_f2i" edge="1" parent="1" source="f1_i1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;" target="f2_i1" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f3_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 3 — Backend descifra datos de tarjeta desde Vault/HSM (PAN, exp) + obtiene CVV2 (estático o dinámico)" vertex="1">
          <mxGeometry height="22" width="1410" x="30" y="590" as="geometry" />
        </mxCell>
        <mxCell id="f3_b1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Busca en Oracle:&#xa;card_id → pan_encrypted,&#xa;exp_date, card_token_pomelo&#xa;PAN almacenado cifrado (AES-256)&#xa;bajo llave custodiada en HSM/Vault" vertex="1">
          <mxGeometry height="80" width="230" x="670" y="625" as="geometry" />
        </mxCell>
        <mxCell id="f3_v1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Descifra PAN:&#xa;Cmd Thales M2/M4 (Data Decrypt)&#xa;o Vault Transit Engine&#xa;Llave AES-256 bajo LMK&#xa;PAN en claro solo en memoria&#xa;del proceso (nunca en disco/log)" vertex="1">
          <mxGeometry height="90" width="210" x="960" y="625" as="geometry" />
        </mxCell>
        <mxCell id="f3_b2_static" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Opción A — CVV2 estático:&#xa;Descifra cvv2_encrypted&#xa;del mismo registro Oracle&#xa;(mismo flujo que PAN)" vertex="1">
          <mxGeometry height="60" width="230" x="670" y="730" as="geometry" />
        </mxCell>
        <mxCell id="e_f3_1" edge="1" parent="1" source="f2_b1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666666;strokeWidth=1.5;" target="f3_b1" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_f3_2" edge="1" parent="1" source="f3_b1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;strokeWidth=1.5;fontSize=9;fontColor=#5a3d00;" target="f3_v1" value="Descifra PAN&#xa;mTLS interno">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_f3_3" edge="1" parent="1" source="f3_b1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666666;strokeWidth=1;dashed=1;" target="f3_b2_static" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_f3_4" edge="1" parent="1" source="f3_b1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=1.5;fontSize=9;fontColor=#1a3d1a;exitX=0.75;exitY=0;exitDx=0;exitDy=0;" target="f3_p1_dynamic" value="O: CVV dinámico&#xa;mTLS Pomelo">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="840" y="625" />
              <mxPoint x="840" y="580" />
              <mxPoint x="1335" y="580" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="f4_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 4 — Backend entrega datos al iframe (respuesta TLS, no cacheada, viewToken consumido)" vertex="1">
          <mxGeometry height="22" width="1410" x="30" y="815" as="geometry" />
        </mxCell>
        <mxCell id="f4_b1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Construye respuesta:&#xa;{ pan, exp, cvv2, viewToken }&#xa;Headers:&#xa;  Cache-Control: no-store, no-cache&#xa;  Pragma: no-cache&#xa;  X-Content-Type-Options: nosniff&#xa;Consume viewToken (1 solo uso)&#xa;Log: correlationId + timestamp&#xa;(SIN loguear PAN ni CVV2)" vertex="1">
          <mxGeometry height="130" width="230" x="670" y="850" as="geometry" />
        </mxCell>
        <mxCell id="f4_i1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Recibe JSON con datos sensibles&#xa;Solo dentro del contexto del iframe&#xa;Same-origin policy impide que&#xa;el portal padre lea este DOM" vertex="1">
          <mxGeometry height="65" width="260" x="350" y="870" as="geometry" />
        </mxCell>
        <mxCell id="e_f4_1" edge="1" parent="1" source="f3_v1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;strokeWidth=1.5;dashed=1;fontSize=9;fontColor=#5a3d00;" target="f4_b1" value="PAN en claro&#xa;(solo en memoria)">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1065" y="800" />
              <mxPoint x="785" y="800" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_f4_2" edge="1" parent="1" source="f4_b1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=2;dashed=1;fontSize=9;fontColor=#023d74;" target="f4_i1" value="JSON { pan, exp, cvv2 }&#xa;TLS 1.3 — No cache">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f5_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 5 — Iframe renderiza datos con protecciones anti-copia, auto-oculta en 30s, borra DOM (Req 3.3, 3.4)" vertex="1">
          <mxGeometry height="22" width="1410" x="30" y="1000" as="geometry" />
        </mxCell>
        <mxCell id="f5_i1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;strokeWidth=2;" value="Renderiza en DOM del iframe:&#xa;&#xa;┌─────────────────────────┐&#xa;│ Número de tarjeta            │&#xa;│ **** **** **** 1234          │&#xa;│         [👁 Ver completo]       │&#xa;│                                         │&#xa;│ Vencimiento    CVV              │&#xa;│ 12/28              •••              │&#xa;│                  [👁 Ver]           │&#xa;└─────────────────────────┘&#xa;&#xa;PAN enmascarado por defecto (Req 3.3)" vertex="1">
          <mxGeometry height="175" width="260" x="350" y="1035" as="geometry" />
        </mxCell>
        <mxCell id="f5_i2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Al presionar &quot;Ver completo&quot;:&#xa;Muestra PAN full por 30 segundos&#xa;Protecciones CSS/JS:&#xa;• user-select: none&#xa;• -webkit-user-select: none&#xa;• oncopy/oncut/onpaste = return false&#xa;• oncontextmenu = return false&#xa;• No drag-and-drop&#xa;• Screenshot: no se puede prevenir&#xa;  (limitación del navegador)" vertex="1">
          <mxGeometry height="140" width="260" x="350" y="1230" as="geometry" />
        </mxCell>
        <mxCell id="f5_p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=10;" value="Portal padre ve el iframe&#xa;pero NO puede leer su contenido&#xa;(same-origin policy)&#xa;&#xa;TH ve los datos de su tarjeta&#xa;dentro del iframe" vertex="1">
          <mxGeometry height="80" width="240" x="50" y="1080" as="geometry" />
        </mxCell>
        <mxCell id="e_f5_1" edge="1" parent="1" source="f4_i1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;" target="f5_i1" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_f5_2" edge="1" parent="1" source="f5_i1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;fontSize=9;fontColor=#023d74;" target="f5_i2" value="TH presiona &#39;Ver&#39;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_f5_3" edge="1" parent="1" source="f5_i1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0284C7;strokeWidth=1;dashed=1;fontSize=9;fontColor=#0284C7;" target="f5_p1" value="Visible dentro&#xa;del iframe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f6_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 6 — Auto-ocultar: timer 30s → enmascara datos → borra de memoria → notifica portal padre" vertex="1">
          <mxGeometry height="22" width="1410" x="30" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="f6_i1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" value="Timer 30s expira:&#xa;1. Reemplaza PAN → **** **** **** 1234&#xa;2. Reemplaza CVV → •••&#xa;3. Sobreescribe variables JS:&#xa;   pan = &#39;0&#39;.repeat(16)&#xa;   cvv = &#39;000&#39;&#xa;4. Elimina nodos DOM con datos&#xa;5. viewToken ya consumido (no reusable)" vertex="1">
          <mxGeometry height="120" width="260" x="350" y="1425" as="geometry" />
        </mxCell>
        <mxCell id="f6_i2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="postMessage al portal padre:&#xa;{ action: &#39;CARD_DATA_HIDDEN&#39;,&#xa;  reason: &#39;TIMEOUT&#39; }&#xa;Sin datos sensibles" vertex="1">
          <mxGeometry height="60" width="260" x="350" y="1565" as="geometry" />
        </mxCell>
        <mxCell id="f6_p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=10;" value="Portal recibe notificación&#xa;Muestra: &quot;Datos ocultos por seguridad&quot;&#xa;Botón: &quot;Ver de nuevo&quot;&#xa;(requiere nuevo viewToken + MFA)" vertex="1">
          <mxGeometry height="65" width="240" x="50" y="1555" as="geometry" />
        </mxCell>
        <mxCell id="e_f6_1" edge="1" parent="1" source="f5_i2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=9;fontColor=#DC2626;" target="f6_i1" value="⏱ 30 segundos">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_f6_2" edge="1" parent="1" source="f6_i1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;" target="f6_i2" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_f6_3" edge="1" parent="1" source="f6_i2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0284C7;strokeWidth=1.5;dashed=1;fontSize=9;fontColor=#0284C7;" target="f6_p1" value="postMessage&#xa;(sin datos sensibles)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="nota_pci" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#b85450;fontStyle=1;" value="PCI DSS v4.0.1 COMPLIANCE:&#xa;&#xa;Req 3.3 — PAN enmascarado por defecto&#xa;  Solo se revela con acción explícita&#xa;  Auto-oculta en 30 segundos&#xa;&#xa;Req 3.3.2 — CVV2 no se almacena&#xa;  Se obtiene de Pomelo en tiempo real&#xa;  (CVV2 dinámico con TTL)&#xa;&#xa;Req 3.4 — PAN no legible en storage&#xa;  No localStorage, no sessionStorage&#xa;  No cookies, no cache del navegador&#xa;  Headers: Cache-Control: no-store&#xa;&#xa;Req 4.2.1 — TLS 1.3 en todo el flujo&#xa;  mTLS entre backend y HSM/Vault&#xa;&#xa;Req 6.4.3 — CSP + SRI en iframe&#xa;  frame-ancestors restringido&#xa;  No scripts de terceros&#xa;&#xa;Req 7.2 — Acceso mínimo&#xa;  viewToken de un solo uso, TTL 30s&#xa;  Rate limit: 3 views/tarjeta/hora&#xa;&#xa;Req 8.3.6 — MFA obligatorio&#xa;  Antes de cada visualización&#xa;&#xa;Ref: PCI DSS v4.0.1 (revisión vigente&#xa;publicada por PCI SSC — aclara foco&#xa;e intención, sin cambios de requisitos)" vertex="1">
          <mxGeometry height="400" width="220" x="1460" y="26" as="geometry" />
        </mxCell>
        <mxCell id="nota_scope" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#E6E6FA;strokeColor=#9370DB;fontSize=9;fontColor=#4B0082;" value="SCOPE PCI DSS v4.0.1:&#xa;&#xa;DENTRO del CDE (confirmado):&#xa;• Iframe (secure-data.credibanco.com)&#xa;• Backend Card Data API&#xa;• HSM / Vault&#xa;• Canal iframe ↔ backend&#xa;&#xa;PROPUESTO FUERA del CDE:&#xa;• Portal TH (portal.entidad.com)&#xa;  No procesa, transmite ni almacena&#xa;  PAN/CVV2. Comunicación con iframe&#xa;  solo vía postMessage con cardId.&#xa;  Sujeto a validación de Seguridad&#xa;  de la Información y del asesor/&#xa;  auditor PCI." vertex="1">
          <mxGeometry height="260" width="220" x="1460" y="440" as="geometry" />
        </mxCell>
        <mxCell id="nota_protecciones" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#FFFBEB;strokeColor=#D97706;fontSize=9;fontColor=#92400E;" value="CONTROLES DE REDUCCIÓN DE EXPOSICIÓN:&#xa;(disuasivos — no absolutos)&#xa;&#xa;CSS: user-select: none&#xa;JS: oncopy/oncut/onpaste/oncontextmenu&#xa;    ondragstart = return false&#xa;&#xa;LIMITACIONES DOCUMENTADAS:&#xa;• Screenshot: NO se puede prevenir&#xa;• Fotografía externa: NO se puede prevenir&#xa;• Malware en endpoint: fuera de control&#xa;• DevTools: usuario avanzado puede&#xa;  inspeccionar DOM&#xa;• Extensiones navegador: CSP mitiga&#xa;  parcialmente&#xa;&#xa;MITIGACIÓN: timer 30s + viewToken&#xa;de un solo uso + rate limiting&#xa;reducen la ventana de exposición.&#xa;Estos controles NO se presentan&#xa;como absolutos ante auditoría." vertex="1">
          <mxGeometry height="310" width="220" x="1460" y="708" as="geometry" />
        </mxCell>
        <mxCell id="nota_cvv" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontColor=#1a3d1a;fontStyle=1;" value="CVV2 — DECISIÓN DE DISEÑO:&#xa;&#xa;✅ RECOMENDADO: CVV2 dinámico&#xa;  Pomelo genera CVV temporal&#xa;  TTL: 20 min, un solo uso&#xa;  No se almacena en Credibanco&#xa;  Si se filtra, expira rápido&#xa;  Menor carga de justificación PCI&#xa;  Requiere API Pomelo disponible&#xa;&#xa;⚠️ DESCARTADO: CVV2 estático&#xa;  Almacenar CVV2 cifrado en Oracle&#xa;  aumenta riesgo y carga de&#xa;  justificación ante auditoría PCI.&#xa;  PCI DSS v4.0.1 Req 3.3.2 prohíbe&#xa;  almacenar CVV2 post-autorización.&#xa;  Incluso cifrado, el QSA puede&#xa;  cuestionar la necesidad de negocio." vertex="1">
          <mxGeometry height="270" width="220" x="1460" y="1030" as="geometry" />
        </mxCell>
      </root>
