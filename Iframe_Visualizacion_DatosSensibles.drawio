        <mxCell id="f0_title" parent="1" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 0 — Pre-requisitos: CSP, SRI, MFA, dominio separado para iframe (PCI DSS v4.0.1 — Req 6.4.3, 8.3.6)" vertex="1">
