        <mxCell id="f0_p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=10;" value="Portal TH en dominio:&#xa;portal.entidad.com&#xa;Usuario autenticado SSO + MFA&#xa;FUERA de scope CDE" vertex="1">
