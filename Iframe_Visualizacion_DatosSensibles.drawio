        <mxCell id="f0_i1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Iframe en dominio separado:&#xa;secure-data.credibanco.com&#xa;CSP: frame-ancestors portal.entidad.com&#xa;script-src con SRI hashes&#xa;DENTRO de scope CDE" vertex="1">
          <mxGeometry height="75" width="260" x="350" y="105" as="geometry" />
        </mxCell>
        <mxCell id="f0_b1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Backend Card Data API:&#xa;Solo sirve al iframe (CORS)&#xa;Valida origin = secure-data.*&#xa;Rate limit: 3 views/tarjeta/hora&#xa;DENTRO de scope CDE" vertex="1">
          <mxGeometry height="75" width="230" x="670" y="105" as="geometry" />
