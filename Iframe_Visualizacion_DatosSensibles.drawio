        <mxCell id="f1_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 1 — Portal carga iframe y envía referencia de tarjeta (postMessage — sin datos sensibles)" vertex="1">
          <mxGeometry height="22" width="1410" x="30" y="200" as="geometry" />
        </mxCell>
        <mxCell id="f1_p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=10;" value="TH presiona &quot;Ver datos de tarjeta&quot;&#xa;Portal valida que MFA esté activo&#xa;Carga iframe:&#xa;&lt;iframe src=&quot;secure-data.credibanco&#xa;.com/card-view&quot; sandbox=&quot;allow-scripts&#xa;allow-same-origin&quot;&gt;" vertex="1">
          <mxGeometry height="90" width="240" x="50" y="235" as="geometry" />
        </mxCell>
        <mxCell id="f1_p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=10;" value="postMessage al iframe:&#xa;{ cardId, sessionToken,&#xa;  action: &#39;VIEW_CARD_DATA&#39; }&#xa;Valida event.origin del iframe" vertex="1">
          <mxGeometry height="65" width="240" x="50" y="345" as="geometry" />
        </mxCell>
        <mxCell id="f1_i1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Iframe recibe postMessage&#xa;Valida event.origin === portal.*&#xa;Valida event.source === parent&#xa;Extrae cardId + sessionToken" vertex="1">
          <mxGeometry height="65" width="260" x="350" y="345" as="geometry" />
        </mxCell>
        <mxCell id="e_f1_1" edge="1" parent="1" source="f1_p1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0284C7;strokeWidth=1.5;" target="f1_p2" value="">
