        <mxCell id="nota_interchange" parent="lane_proveedor" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;fontColor=#5a3d00;fontStyle=1;" value="INTERCHANGE HSM (HA Cluster):&#xa;PIN en claro existe SOLO en RAM&#xa;protegida del HSM entre pasos 1 y 2&#xa;Valida nonce anti-replay&#xa;pubKey_PROVEEDOR almacenada&#xa;en HSM bajo TR-31 — rotación periódica&#xa;Canal interno: mTLS (Req 4.2.1)" vertex="1">
