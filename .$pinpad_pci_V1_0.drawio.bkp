          <mxGeometry height="1507" width="294" x="703" y="10" as="geometry" />
        </mxCell>
        <mxCell id="fase0_title" parent="1" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 0 — Pre-requisitos de seguridad: CSP, SRI, MFA (PCI DSS v4.0 — Req 6.4.3, 8.3.6)" vertex="1">
          <mxGeometry height="22" width="1100" x="170" y="73" as="geometry" />
        </mxCell>
        <mxCell id="a0_csp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="CSP Headers estrictos:&#xa;frame-ancestors &#39;self&#39; portal.dominio&#xa;script-src con nonce/SRI hashes&#xa;Subresource Integrity en scripts" vertex="1">
          <mxGeometry height="70" width="200" x="190" y="105" as="geometry" />
        </mxCell>
        <mxCell id="b0_mfa" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Autenticación MFA del usuario&#xa;(PCI v4.0 Req 8.3.6)&#xa;Valida token MFA antes de&#xa;permitir operación de PIN" vertex="1">
          <mxGeometry height="70" width="180" x="470" y="105" as="geometry" />
        </mxCell>
        <mxCell id="b0_ratelimit" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Rate Limiting por usuario/tarjeta&#xa;Máx 3 sesiones PIN / hora&#xa;Protege HSM de agotamiento&#xa;de recursos" vertex="1">
          <mxGeometry height="70" width="180" x="470" y="189" as="geometry" />
        </mxCell>
        <mxCell id="fase1_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 1 — Inicialización: Angular obtiene pubKey efímera del HSM + correlationId" vertex="1">
          <mxGeometry height="22" width="1100" x="170" y="270" as="geometry" />
        </mxCell>
        <mxCell id="a1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Portal padre envía ref. de tarjeta&#xa;postMessage { cardId, tipo_op }&#xa;cardId = identificador opaco interno&#xa;valida event.origin + event.source" vertex="1">
          <mxGeometry height="70" width="200" x="190" y="302" as="geometry" />
        </mxCell>
        <mxCell id="a2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="POST /api/pin-session/init&#xa;{ cardId, tipo_op, sessionToken,&#xa;  mfaToken }" vertex="1">
          <mxGeometry height="60" width="200" x="190" y="402" as="geometry" />
        </mxCell>
        <mxCell id="b1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Valida sesión + MFA + rate limit&#xa;Genera correlationId (UUID)&#xa;Verifica cardId autorizado&#xa;Solicita pubKey efímera al HSM" vertex="1">
          <mxGeometry height="70" width="180" x="470" y="397" as="geometry" />
        </mxCell>
        <mxCell id="c1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Genera par RSA-2048 efímero&lt;br&gt;pubKey_HSM + privKey_HSM&lt;br&gt;TTL: 5 min — uso único&lt;br&gt;Almacena: sessionId ↔ privKey_HSM&lt;br&gt;+ nonce anti-replay" vertex="1">
          <mxGeometry height="90" width="208" x="758" y="387" as="geometry" />
        </mxCell>
        <mxCell id="b2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Retorna { sessionId, pubKey_HSM_PEM,&#xa;  nonce, correlationId }&#xa;al Angular iframe" vertex="1">
          <mxGeometry height="60" width="180" x="470" y="507" as="geometry" />
        </mxCell>
        <mxCell id="a3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="importRsaPublicKey(pubKey_HSM_PEM)&#xa;SubtleCrypto.importKey(&#39;spki&#39;)&#xa;No exportable — solo [&#39;encrypt&#39;]&#xa;Almacena nonce para bloque PIN" vertex="1">
          <mxGeometry height="70" width="200" x="190" y="502" as="geometry" />
        </mxCell>
        <mxCell id="fase2_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 2 — Captura y cifrado de PIN (Angular usa pubKey HSM — sin PAN, sin datos de tarjeta) + nonce anti-replay" vertex="1">
          <mxGeometry height="22" width="1100" x="170" y="585" as="geometry" />
        </mxCell>
        <mxCell id="a4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Teclado PIN enmascarado&#xa;autocomplete=&quot;off&quot;&#xa;oncopy / onpaste bloqueado&#xa;Timeout 30s inactividad → clear()&#xa;Máx 3 intentos → invalida sesión" vertex="1">
          <mxGeometry height="80" width="200" x="190" y="617" as="geometry" />
        </mxCell>
        <mxCell id="a5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;strokeWidth=2;" value="Construye bloque PIN&lt;br&gt;Formato acordado con proveedor&lt;br&gt;Incluye nonce + timestamp&lt;br&gt;(protección anti-replay)" vertex="1">
          <mxGeometry height="70" width="200" x="190" y="717" as="geometry" />
        </mxCell>
        <mxCell id="a6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="SubtleCrypto.encrypt(RSA-OAEP)&#xa;Cifra bloque PIN con pubKey_HSM&#xa;→ ciphertext_HSM" vertex="1">
          <mxGeometry height="60" width="200" x="190" y="807" as="geometry" />
        </mxCell>
        <mxCell id="a7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="Uint8Array.fill(0)&#xa;Borra PIN + nonce de memoria&#xa;PCI req. 3.3 — Solo sale ciphertext_HSM" vertex="1">
          <mxGeometry height="50" width="200" x="190" y="887" as="geometry" />
        </mxCell>
        <mxCell id="fase3_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 3 — Interchange en HSM: descifra con privKey HSM → valida nonce → re-cifra con llave pública del proveedor" vertex="1">
          <mxGeometry height="22" width="1100" x="170" y="950" as="geometry" />
        </mxCell>
        <mxCell id="b3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Recibe { ciphertext_HSM, sessionId,&#xa;  correlationId }&#xa;Valida sessionId activo&#xa;Proxy opaco — NO descifra&#xa;Log: correlationId + timestamp" vertex="1">
          <mxGeometry height="80" width="180" x="470" y="982" as="geometry" />
        </mxCell>
        <mxCell id="b4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Envía cmd interchange al HSM&#xa;{ ciphertext_HSM, sessionId }&#xa;Canal mTLS red interna&#xa;Circuit breaker: timeout 5s&#xa;Retry: 1 intento, luego falla" vertex="1">
          <mxGeometry height="80" width="180" x="470" y="1082" as="geometry" />
        </mxCell>
        <mxCell id="c2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="1. Descifra con privKey_HSM&#xa;RSA-OAEP → bloque PIN en claro&#xa;Solo en RAM protegida del HSM&#xa;Valida nonce (anti-replay)&#xa;privKey_HSM invalida tras uso" vertex="1">
          <mxGeometry height="80" width="208" x="736" y="977" as="geometry" />
        </mxCell>
        <mxCell id="c3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=10;" value="2. Re-cifra con pubKey_PROVEEDOR&#xa;Llave pública del proveedor&#xa;precargada en HSM bajo TR-31&#xa;Rotación periódica programada&#xa;→ ciphertext_PROVEEDOR&#xa;PIN claro NUNCA sale del HSM" vertex="1">
          <mxGeometry height="90" width="208" x="736" y="1077" as="geometry" />
        </mxCell>
        <mxCell id="c4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="3. Retorna ciphertext_PROVEEDOR&#xa;+ sessionId al backend&#xa;Audit log: correlationId +&#xa;sessionId + timestamp + resultado" vertex="1">
          <mxGeometry height="70" width="208" x="736" y="1187" as="geometry" />
        </mxCell>
        <mxCell id="fase4_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 4 — Backend invoca API JSON del proveedor con PIN re-cifrado + idempotencyKey" vertex="1">
          <mxGeometry height="22" width="1100" x="170" y="1270" as="geometry" />
        </mxCell>
        <mxCell id="b5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Construye request JSON&#xa;{ cardId, ciphertext_PROVEEDOR,&#xa;  sessionId, tipo_op,&#xa;  idempotencyKey, correlationId }&#xa;Agrega headers auth del proveedor" vertex="1">
          <mxGeometry height="80" width="180" x="470" y="1297" as="geometry" />
        </mxCell>
        <mxCell id="p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="POST /api/pin/change (o /assign)&#xa;Recibe JSON con ciphertext_PROVEEDOR&#xa;Valida idempotencyKey (evita doble op)&#xa;Descifra con su privKey interna&#xa;Procesa cambio / asignación de PIN" vertex="1">
          <mxGeometry height="80" width="200" x="1030" y="1297" as="geometry" />
        </mxCell>
        <mxCell id="p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="Retorna JSON response&#xa;{ status: OK/ERROR,&#xa;  code, message, correlationId }&#xa;Sobre TLS 1.3 / mTLS" vertex="1">
          <mxGeometry height="70" width="200" x="1030" y="1397" as="geometry" />
        </mxCell>
        <mxCell id="a10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="Resultado al usuario&#xa;postMessage al portal padre&#xa;{ status: &#39;success&#39;|&#39;error&#39;, code }&#xa;Sin ningún dato sensible" vertex="1">
          <mxGeometry height="70" width="200" x="190" y="1307" as="geometry" />
        </mxCell>
        <mxCell id="nota_angular" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;fontColor=#023d74;" value="Angular: cifra SOLO con pubKey_HSM&#xa;No maneja PAN ni datos de tarjeta&#xa;El ciphertext_HSM es opaco para&#xa;cualquier capa fuera del HSM&#xa;CSP + SRI obligatorios (Req 6.4.3)" vertex="1">
          <mxGeometry height="82" width="178" x="470" y="700" as="geometry" />
        </mxCell>
        <mxCell id="nota_backend" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;fontColor=#333333;" value="Backend: PROXY SEGURO&#xa;Nunca descifra ciphertext_HSM&#xa;Nunca ve el PIN en claro&#xa;Fuera del scope CDE&#xa;correlationId en todos los logs&#xa;Circuit breaker + idempotencyKey" vertex="1">
          <mxGeometry height="90" width="180" x="470" y="800" as="geometry" />
        </mxCell>
        <mxCell id="nota_proveedor" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontColor=#1a3d1a;" value="Proveedor: recibe PIN cifrado&#xa;con SU propia llave pública&#xa;Solo él puede descifrar&#xa;Soporta idempotencyKey&#xa;Invocación: HTTP REST JSON / mTLS" vertex="1">
          <mxGeometry height="82" width="178" x="1248" y="1297" as="geometry" />
        </mxCell>
        <mxCell id="nota_pciv4" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#b85450;fontStyle=1;" value="MEJORAS PCI DSS v4.0:&#xa;• Req 4.2.1: mTLS en red interna&#xa;• Req 6.4.3: CSP + SRI en iframe&#xa;• Req 8.3.6: MFA pre-operación&#xa;• Req 12.3.1: TTL/timeout documentados&#xa;• Anti-replay: nonce en bloque PIN&#xa;• Observabilidad: correlationId E2E&#xa;• Resiliencia: circuit breaker + HA HSM&#xa;• Idempotencia: idempotencyKey al proveedor&#xa;• Rate limiting: protección HSM" vertex="1">
          <mxGeometry height="148" width="210" x="1248" y="105" as="geometry" />
        </mxCell>
        <mxCell id="nota_errores" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#b85450;" value="FLUJO DE ERROR:&#xa;• HSM timeout → invalida sesión,&#xa;  notifica usuario, log correlationId&#xa;• Proveedor error → NO reintenta&#xa;  (idempotencyKey protege)&#xa;• Nonce inválido → rechaza, alerta&#xa;• Rate limit excedido → HTTP 429&#xa;• MFA fallido → bloquea operación" vertex="1">
          <mxGeometry height="138" width="200" x="1248" y="270" as="geometry" />
        </mxCell>
        <mxCell id="nota_observabilidad" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#E6E6FA;strokeColor=#9370DB;fontSize=9;fontColor=#4B0082;" value="OBSERVABILIDAD:&#xa;correlationId viaja por las 4 capas&#xa;Métricas: tasa éxito/fallo, latencia&#xa;por fase, intentos fallidos/tarjeta&#xa;Alertas: anomalías en rate de uso&#xa;Dashboard PCI para auditoría" vertex="1">
          <mxGeometry height="100" width="200" x="1248" y="420" as="geometry" />
        </mxCell>
