        <mxCell id="lane_cb_back" parent="1" style="shape=swimlane;startSize=35;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;" value="Credibanco Backend (PCI DSS)" vertex="1">
