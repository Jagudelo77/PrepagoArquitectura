        <mxCell id="lane_iframe" parent="1" style="shape=swimlane;startSize=35;fillColor=#FF8C00;strokeColor=#d46b08;fontColor=#ffffff;fontStyle=1;fontSize=11;" value="Iframe Credibanco (PCI DSS)" vertex="1">
