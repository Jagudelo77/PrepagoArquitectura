        <mxCell id="lane_angular" parent="1" style="shape=swimlane;startSize=35;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" value="Angular App (Frontend Tarjeta Habiente)" vertex="1">
