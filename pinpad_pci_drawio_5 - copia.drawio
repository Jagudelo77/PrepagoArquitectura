        <mxCell id="fase4_title" parent="lane_angular" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;              verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 4 — Backend invoca API JSON del proveedor con PIN re-cifrado bajo llave del proveedor" vertex="1">
          <mxGeometry height="22" width="1100" y="880" as="geometry" />
        </mxCell>
        <mxCell id="lane_backend" parent="1" style="swimlane;startSize=50;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;fontColor=#333333;" value="Backend portal Credibanco&#xa;(Proxy seguro — fuera CDE)" vertex="1">
          <mxGeometry height="1110" width="240" x="450" y="17" as="geometry" />
        </mxCell>
        <mxCell id="nota_angular" parent="lane_backend" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;              fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;fontColor=#023d74;" value="Angular: cifra SOLO con pubKey_HSM&#xa;No maneja PAN ni datos de tarjeta&#xa;El ciphertext_HSM es opaco para&#xa;cualquier capa fuera del HSM" vertex="1">
          <mxGeometry height="71" width="178" x="20" y="499" as="geometry" />
        </mxCell>
        <mxCell id="lane_hsm" parent="1" style="swimlane;startSize=50;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;fontColor=#5a3d00;" value="HSM Credibanco&#xa;(CDE — Interchange de llaves)" vertex="1">
          <mxGeometry height="1100" width="280" x="710" y="17" as="geometry" />
        </mxCell>
        <mxCell id="lane_proveedor" parent="1" style="swimlane;startSize=50;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;fontColor=#1a3d1a;" value="Proveedor de cambio de PIN&#xa;(API JSON — TLS)" vertex="1">
          <mxGeometry height="1110" width="260" x="1010" y="17" as="geometry" />
        </mxCell>
        <mxCell id="cde_border" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d6b656;              dashed=1;dashPattern=8 4;fontSize=11;fontStyle=1;fontColor=#854f0b;              verticalAlign=top;spacingTop=4;pointerEvents=0;" value="Perímetro CDE — PCI DSS" vertex="1">
          <mxGeometry height="1117" width="294" x="703" y="10" as="geometry" />
        </mxCell>
        <mxCell id="fase1_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;              verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 1 — Inicialización: Angular obtiene pubKey efímera del HSM" vertex="1">
          <mxGeometry height="22" width="1100" x="170" y="73" as="geometry" />
        </mxCell>
        <mxCell id="fase2_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;              verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 2 — Captura y cifrado de PIN (Angular usa pubKey HSM — sin PAN, sin datos de tarjeta)" vertex="1">
          <mxGeometry height="22" width="1100" x="170" y="385" as="geometry" />
        </mxCell>
        <mxCell id="fase3_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;              verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 3 — Interchange en HSM: descifra con privKey HSM → re-cifra con llave pública del proveedor" vertex="1">
          <mxGeometry height="22" width="1100" x="170" y="689" as="geometry" />
        </mxCell>
        <mxCell id="a1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Portal padre envía ref. de tarjeta&#xa;postMessage { cardId, tipo_op }&#xa;cardId = identificador opaco interno&#xa;valida event.origin estrictamente" vertex="1">
          <mxGeometry height="70" width="200" x="190" y="105" as="geometry" />
        </mxCell>
        <mxCell id="a2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="POST /api/pin-session/init&#xa;{ cardId, tipo_op, sessionToken }" vertex="1">
          <mxGeometry height="50" width="200" x="190" y="215" as="geometry" />
        </mxCell>
        <mxCell id="b1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Valida sesión de usuario&#xa;Verifica cardId autorizado&#xa;Solicita pubKey efímera al HSM" vertex="1">
          <mxGeometry height="60" width="180" x="470" y="215" as="geometry" />
        </mxCell>
        <mxCell id="c1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Genera par RSA-2048 efímero&lt;br&gt;pubKey_HSM + privKey_HSM&lt;br&gt;TTL: 5 min — uso único&lt;br&gt;Almacena: sessionId ↔ privKey_HSM" vertex="1">
          <mxGeometry height="80" width="208" x="736" y="205" as="geometry" />
        </mxCell>
        <mxCell id="b2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Retorna { sessionId, pubKey_HSM_PEM }&#xa;al Angular iframe" vertex="1">
          <mxGeometry height="50" width="180" x="470" y="317" as="geometry" />
        </mxCell>
        <mxCell id="a3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="importRsaPublicKey(pubKey_HSM_PEM)&#xa;SubtleCrypto.importKey(&#39;spki&#39;)&#xa;No exportable — solo [&#39;encrypt&#39;]" vertex="1">
          <mxGeometry height="60" width="200" x="190" y="312" as="geometry" />
        </mxCell>
        <mxCell id="a4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Teclado PIN enmascarado&#xa;autocomplete=&quot;off&quot;&#xa;oncopy / onpaste bloqueado&#xa;Timeout 30s → clear()" vertex="1">
          <mxGeometry height="70" width="200" x="190" y="417" as="geometry" />
        </mxCell>
        <mxCell id="a5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;              fontSize=10;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=10;fontColor=default;" value="Construye bloque PIN&lt;br&gt;Formato acordado con proveedor&lt;br&gt;(estructura que el proveedor espera)" vertex="1">
          <mxGeometry height="70" width="200" x="190" y="517" as="geometry" />
        </mxCell>
        <mxCell id="a6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="SubtleCrypto.encrypt(RSA-OAEP)&#xa;Cifra bloque PIN con pubKey_HSM&#xa;→ ciphertext_HSM" vertex="1">
          <mxGeometry height="60" width="200" x="190" y="617" as="geometry" />
        </mxCell>
        <mxCell id="a7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="Uint8Array.fill(0)&#xa;Borra PIN de memoria — PCI req. 3.3&#xa;Solo sale ciphertext_HSM" vertex="1">
          <mxGeometry height="50" width="200" x="190" y="746" as="geometry" />
        </mxCell>
        <mxCell id="b3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Recibe { ciphertext_HSM, sessionId }&#xa;Valida sessionId activo&#xa;Proxy opaco — NO descifra" vertex="1">
          <mxGeometry height="60" width="180" x="470" y="741" as="geometry" />
        </mxCell>
        <mxCell id="b4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Envía cmd interchange al HSM&#xa;{ ciphertext_HSM, sessionId }&#xa;Canal TCP red interna — no internet" vertex="1">
          <mxGeometry height="60" width="180" x="470" y="821" as="geometry" />
        </mxCell>
        <mxCell id="c2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="1. Descifra con privKey_HSM&#xa;RSA-OAEP → bloque PIN en claro&#xa;Solo en RAM protegida del HSM&#xa;privKey_HSM invalida tras uso" vertex="1">
          <mxGeometry height="70" width="208" x="736" y="721" as="geometry" />
        </mxCell>
        <mxCell id="c3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;              fontStyle=1;fontSize=10;" value="2. Re-cifra con pubKey_PROVEEDOR&#xa;Llave pública del proveedor&#xa;precargada en el HSM bajo TR-31&#xa;→ ciphertext_PROVEEDOR&#xa;PIN claro NUNCA sale del HSM" vertex="1">
          <mxGeometry height="80" width="208" x="736" y="811" as="geometry" />
        </mxCell>
        <mxCell id="c4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="3. Retorna ciphertext_PROVEEDOR&#xa;+ sessionId al backend&#xa;Audit log: sessionId + timestamp" vertex="1">
          <mxGeometry height="60" width="208" x="736" y="981" as="geometry" />
        </mxCell>
        <mxCell id="b5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Construye request JSON&#xa;{ cardId, ciphertext_PROVEEDOR,&#xa;  sessionId, tipo_op, ... }&#xa;Agrega headers auth del proveedor" vertex="1">
          <mxGeometry height="70" width="180" x="470" y="976" as="geometry" />
        </mxCell>
        <mxCell id="p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="POST /api/pin/change (o /assign)&#xa;Recibe JSON con ciphertext_PROVEEDOR&#xa;Descifra con su privKey interna&#xa;Procesa cambio / asignación de PIN" vertex="1">
          <mxGeometry height="70" width="200" x="1030" y="936" as="geometry" />
        </mxCell>
        <mxCell id="p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="Retorna JSON response&#xa;{ status: OK/ERROR,&#xa;  code, message }&#xa;Sobre TLS 1.3 / mTLS" vertex="1">
          <mxGeometry height="60" width="200" x="1030" y="1026" as="geometry" />
        </mxCell>
        <mxCell id="a10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="Resultado al usuario&#xa;postMessage al portal padre&#xa;{ status: &#39;success&#39;|&#39;error&#39;, code }&#xa;Sin ningún dato sensible" vertex="1">
