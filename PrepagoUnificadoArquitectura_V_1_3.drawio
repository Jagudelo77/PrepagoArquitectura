        </mxCell>
        <mxCell id="e-limit-redis" edge="1" parent="1" source="limit-counter-svc" style="endArrow=block;endFill=1;html=1;strokeColor=#FF0000;strokeWidth=1.5;fontSize=8;fontColor=#FF0000;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;entryPerimeter=0;edgeStyle=orthogonalEdgeStyle;" target="GbSRN02RT5quMc9xkAOz-1" value="INCR/GET&#xa;contadores">
