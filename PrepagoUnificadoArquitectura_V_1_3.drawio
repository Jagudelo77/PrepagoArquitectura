        </mxCell>
        <mxCell id="rec-edge-2" edge="1" parent="1" source="rec-file-ingestion" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#3B82F6;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;entryPerimeter=0;edgeStyle=orthogonalEdgeStyle;" target="rec-file-storage" value="Almacena archivos&lt;br&gt;originales">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rec-edge-3" edge="1" parent="1" source="rec-file-ingestion" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#3B82F6;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="rec-matcher" value="INSERT clearing_staging">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rec-edge-4" edge="1" parent="1" source="rec-matcher" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#3B82F6;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;entryPerimeter=0;" target="rec-oracle" value="Read txn autorizadas +&lt;br&gt;clearing staging.&lt;br&gt;Write reconciliation_result">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rec-edge-5" edge="1" parent="1" source="rec-matcher" style="endArrow=block;endFill=1;html=1;strokeColor=#DC2626;strokeWidth=1.5;fontSize=8;fontColor=#DC2626;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="rec-exception" value="Excepciones&lt;br&gt;(diferencias)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rec-edge-6" edge="1" parent="1" source="rec-matcher" style="endArrow=block;endFill=1;html=1;strokeColor=#059669;strokeWidth=1.5;fontSize=8;fontColor=#059669;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="rec-settlement" value="Matched txns →&lt;br&gt;cálculo liquidación">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rec-edge-7" edge="1" parent="1" source="rec-settlement" style="endArrow=block;endFill=1;html=1;strokeColor=#059669;strokeWidth=1;strokeDashArray=4;fontSize=8;fontColor=#059669;entryX=1;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.75;exitDx=0;exitDy=0;" target="rec-oracle" value="Persist settlement_summary">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="840" y="790" />
              <mxPoint x="840" y="660" />
            </Array>
            <mxPoint x="880" y="660" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rec-edge-8" edge="1" parent="1" source="rec-exception" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;strokeDashArray=4;fontSize=8;fontColor=#3B82F6;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="rec-dashboard" value="Resultados +&lt;br&gt;excepciones">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rec-edge-9" edge="1" parent="1" source="rec-exception" style="endArrow=block;endFill=1;html=1;strokeColor=#DC2626;strokeWidth=1;strokeDashArray=4;fontSize=8;fontColor=#DC2626;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;entryPerimeter=0;edgeStyle=orthogonalEdgeStyle;" target="rec-oracle" value="Persist exceptions">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rec-note-1" parent="1" style="text;html=1;fontSize=9;fontStyle=2;align=center;fontColor=#60A5FA;fillColor=none;strokeColor=#60A5FA;rounded=1;spacingLeft=8;spacingRight=8;" value="⏰ Secuencia de ejecución diaria:&lt;br&gt;1. 05:00 — Clearing File Ingestion (recibe archivos franquicia)&lt;br&gt;2. 06:00 — Reconciliation Matcher (cuadre txn vs clearing)&lt;br&gt;3. 06:30 — Exception Handler (procesa diferencias)&lt;br&gt;4. 07:00 — Settlement Calculator (posición neta)&lt;br&gt;5. 08:00 — Dashboard disponible para operaciones" vertex="1">
          <mxGeometry height="75" width="380" x="80" y="770" as="geometry" />
        </mxCell>
        <mxCell id="rec-note-2" parent="1" style="text;html=1;fontSize=9;fontStyle=2;align=center;fontColor=#D97706;fillColor=#FFFBEB;strokeColor=#D97706;rounded=1;spacingLeft=8;spacingRight=8;" value="💡 El Matcher usa Oracle Read Replica para queries&lt;br&gt;pesados y no impactar el hot-path transaccional.&lt;br&gt;Las excepciones UNMATCHED_LOCAL con antigüedad&lt;br&gt;&amp;lt; 24h se auto-resuelven en el siguiente ciclo&lt;br&gt;(clearing puede llegar con 1 día de retraso)." vertex="1">
          <mxGeometry height="65" width="380" x="80" y="860" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="gmf-batch-001" name="GMF Batch">
    <mxGraphModel dx="786" dy="562" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="gmf-title" parent="1" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;fontColor=#000000;fillColor=none;strokeColor=none;" value="Cobro GMF Batch (4x1000) — Entidades con gmf_mode=BATCH" vertex="1">
          <mxGeometry height="35" width="700" x="40" y="30" as="geometry" />
        </mxCell>
        <mxCell id="gmf-sub" parent="1" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#9CA3AF;fillColor=none;strokeColor=none;" value="Proceso batch diario para entidades que no cobran GMF en línea. Calcula 4x1000 sobre txn del día anterior." vertex="1">
          <mxGeometry height="20" width="700" x="40" y="65" as="geometry" />
        </mxCell>
        <mxCell id="gmf-sched" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="300" x="80" y="120" as="geometry" />
        </mxCell>
        <mxCell id="gmf-sched-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="GMF Batch Scheduler" vertex="1">
          <mxGeometry height="22" width="300" x="80" y="128" as="geometry" />
        </mxCell>
        <mxCell id="gmf-sched-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Batch — CronJob 1:00 AM diario]" vertex="1">
          <mxGeometry height="14" width="300" x="80" y="150" as="geometry" />
        </mxCell>
        <mxCell id="gmf-sched-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="1. Identifica entidades con gmf_mode=BATCH&lt;br&gt;2. Lee transacciones aprobadas del día anterior&lt;br&gt;3. Filtra tarjetas NO exentas (gmf_exenta=N)&lt;br&gt;4. Calcula 4x1000 por cada txn aplicable&lt;br&gt;5. Genera lote de débitos GMF" vertex="1">
          <mxGeometry height="48" width="290" x="85" y="168" as="geometry" />
        </mxCell>
        <mxCell id="gmf-proc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="100" width="300" x="80" y="280" as="geometry" />
        </mxCell>
        <mxCell id="gmf-proc-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="GMF Debit Processor" vertex="1">
          <mxGeometry height="22" width="300" x="80" y="288" as="geometry" />
        </mxCell>
        <mxCell id="gmf-proc-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Procesa en chunks (100 registros):&lt;br&gt;• UPDATE account SET balance = balance - gmf_amount&lt;br&gt;• INSERT transaction (tipo=GMF_BATCH, source=SYSTEM_GMF)&lt;br&gt;• Si saldo insuficiente → marca PENDING (retry 3 días)&lt;br&gt;• Invalida balance cache en Redis" vertex="1">
          <mxGeometry height="60" width="290" x="85" y="314" as="geometry" />
        </mxCell>
        <mxCell id="gmf-oracle" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="80" width="200" x="130" y="440" as="geometry" />
        </mxCell>
        <mxCell id="gmf-oracle-t" parent="1" style="text;html=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Oracle (Read Replica → Primary)" vertex="1">
          <mxGeometry height="18" width="200" x="130" y="465" as="geometry" />
        </mxCell>
        <mxCell id="gmf-oracle-d" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Lee txn de Replica, escribe débitos en Primary" vertex="1">
          <mxGeometry height="14" width="200" x="130" y="485" as="geometry" />
        </mxCell>
        <mxCell id="gmf-output" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#10B981;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="80" width="280" x="480" y="289" as="geometry" />
        </mxCell>
        <mxCell id="gmf-output-t" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;fontColor=#10B981;fillColor=none;strokeColor=none;" value="Archivo GMFNOVDD.MM" vertex="1">
          <mxGeometry height="20" width="280" x="480" y="299" as="geometry" />
        </mxCell>
        <mxCell id="gmf-output-d" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#10B981;fillColor=none;strokeColor=none;" value="Detalle de cobros GMF por tarjeta/entidad&lt;br&gt;Incluye: exitosos + pendientes + fallidos&lt;br&gt;Se genera diario a las 1:00 AM post-proceso" vertex="1">
          <mxGeometry height="40" width="270" x="485" y="323" as="geometry" />
        </mxCell>
        <mxCell id="gmf-note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#FFFBEB;strokeColor=#D97706;fontSize=9;fontColor=#92400E;" value="REGLAS GMF BATCH:&lt;br&gt;&lt;br&gt;• Solo aplica si entity.gmf_mode = BATCH&lt;br&gt;• Tarjetas con gmf_exenta=Y se excluyen&lt;br&gt;• Se puede exonerar a nivel de tarjeta (pos 440)&lt;br&gt;• Aplica a: Retiros, Compras (según config AFG)&lt;br&gt;• Consultas de saldo: según parametría&lt;br&gt;• Cálculo: monto_txn * 0.004 (4x1000)&lt;br&gt;• Si saldo insuficiente: retry por 3 días&lt;br&gt;• Después de 3 días: marca como no cobrado&lt;br&gt;• Genera archivo GMFNOVDD.MM para entidad" vertex="1">
          <mxGeometry height="140" width="240" x="480" y="120" as="geometry" />
        </mxCell>
        <mxCell id="gmf-e1" edge="1" parent="1" source="gmf-sched" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=9;fontColor=#3B82F6;" target="gmf-proc" value="Lote de débitos GMF">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="gmf-e2" edge="1" parent="1" source="gmf-proc" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=9;fontColor=#3B82F6;" target="gmf-oracle" value="Débito atómico">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="gmf-e3" edge="1" parent="1" source="gmf-proc" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#10B981;strokeWidth=1.5;fontSize=9;fontColor=#10B981;" target="gmf-output" value="Genera archivo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="comisiones-batch-001" name="Comisiones Batch (Recobros)">
    <mxGraphModel dx="1426" dy="841" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="cb-title" parent="1" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;fontColor=#000000;fillColor=none;strokeColor=none;" value="Comisiones Batch — Recobros (COMI, CINS, CSAT)" vertex="1">
          <mxGeometry height="35" width="700" x="40" y="30" as="geometry" />
        </mxCell>
        <mxCell id="cb-sub" parent="1" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#9CA3AF;fillColor=none;strokeColor=none;" value="Proceso batch diario: reintenta cobros de comisiones que fallaron en línea por saldo insuficiente (hasta 3 meses)" vertex="1">
          <mxGeometry height="20" width="800" x="40" y="65" as="geometry" />
        </mxCell>
        <mxCell id="cb-sched" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="300" x="80" y="120" as="geometry" />
        </mxCell>
        <mxCell id="cb-sched-t" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Commission Retry Scheduler" vertex="1">
          <mxGeometry height="22" width="300" x="80" y="128" as="geometry" />
        </mxCell>
        <mxCell id="cb-sched-tech" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Batch — CronJob 2:00 AM diario]" vertex="1">
          <mxGeometry height="14" width="300" x="80" y="150" as="geometry" />
        </mxCell>
        <mxCell id="cb-sched-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="1. Busca commission_transaction con status=PENDING&lt;br&gt;2. Filtra: antigüedad &amp;lt; 3 meses (regla RECOBROS)&lt;br&gt;3. Agrupa por tarjeta (acumula comisiones pendientes)&lt;br&gt;4. Intenta débito consolidado por tarjeta&lt;br&gt;5. Si éxito → CSAT | Si falla → sigue PENDING | Si &amp;gt;3 meses → CINS" vertex="1">
          <mxGeometry height="48" width="290" x="85" y="168" as="geometry" />
        </mxCell>
        <mxCell id="cb-oracle" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="80" width="200" x="130" y="400" as="geometry" />
        </mxCell>
        <mxCell id="cb-oracle-t" parent="1" style="text;html=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Oracle Primary" vertex="1">
          <mxGeometry height="18" width="200" x="130" y="425" as="geometry" />
        </mxCell>
        <mxCell id="cb-oracle-d" parent="1" style="text;html=1;fontSize=8;align=center;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="commission_transaction, account, transaction" vertex="1">
          <mxGeometry height="14" width="200" x="130" y="445" as="geometry" />
        </mxCell>
        <mxCell id="cb-comi" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#10B981;strokeWidth=2;arcSize=8;fontSize=11;fontStyle=1;fontColor=#10B981;" value="COMIDD.MM&lt;br&gt;(Todas las comisiones)" vertex="1">
          <mxGeometry height="45" width="180" x="480" y="120" as="geometry" />
        </mxCell>
        <mxCell id="cb-csat" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#059669;strokeWidth=2;arcSize=8;fontSize=11;fontStyle=1;fontColor=#059669;" value="CSATDD.MM&lt;br&gt;(Satisfactorias — cobradas)" vertex="1">
          <mxGeometry height="45" width="180" x="480" y="185" as="geometry" />
        </mxCell>
        <mxCell id="cb-cins" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DC2626;strokeWidth=2;arcSize=8;fontSize=11;fontStyle=1;fontColor=#DC2626;" value="CINSDD.MM&lt;br&gt;(Insatisfactorias — no cobradas 3m)" vertex="1">
          <mxGeometry height="45" width="180" x="480" y="250" as="geometry" />
        </mxCell>
        <mxCell id="cb-note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#EFF6FF;strokeColor=#3B82F6;fontSize=9;fontColor=#1E40AF;" value="FLUJO DE RECOBRO:&lt;br&gt;&lt;br&gt;Txn en línea → comisión no cobrada (saldo=0)&lt;br&gt;→ INSERT commission_transaction (PENDING)&lt;br&gt;→ Retry diario por hasta 3 meses&lt;br&gt;→ Si se cobra → status=SUCCESS (CSAT)&lt;br&gt;→ Si 3 meses sin cobrar → status=FAILED (CINS)&lt;br&gt;&lt;br&gt;Mismo flujo aplica para:&lt;br&gt;• Comisiones de retiro/compra/consulta&lt;br&gt;• Tx Técnicamente Exitosas no cobradas&lt;br&gt;• Cuota de manejo fallida (Fee Retry)" vertex="1">
          <mxGeometry height="160" width="240" x="480" y="320" as="geometry" />
        </mxCell>
        <mxCell id="cb-e1" edge="1" parent="1" source="cb-sched" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=9;fontColor=#3B82F6;" target="cb-oracle" value="Retry débito">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cb-e2" edge="1" parent="1" source="cb-sched" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#10B981;strokeWidth=1.5;fontSize=9;fontColor=#10B981;" target="cb-comi" value="Genera">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
