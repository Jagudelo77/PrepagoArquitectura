        <mxCell id="cs-bt-ent" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;arcSize=12;fontStyle=1;fontSize=10;fontColor=#DC2626;" value="BLOQ TEMP&#xa;(Entidad)" vertex="1">
