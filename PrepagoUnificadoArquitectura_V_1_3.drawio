        </mxCell>
        <mxCell id="rec-file-storage-desc" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: NFS / PersistentVolume]&lt;br&gt;Archivos clearing recibidos + archivos&lt;br&gt;de diferencias generados" vertex="1">
          <mxGeometry height="35" width="210" x="85" y="401" as="geometry" />
        </mxCell>
        <mxCell id="rec-matcher" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="160" width="340" x="460" y="370" as="geometry" />
        </mxCell>
        <mxCell id="rec-matcher-title" parent="1" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Reconciliation Matcher" vertex="1">
          <mxGeometry height="25" width="340" x="460" y="378" as="geometry" />
        </mxCell>
        <mxCell id="rec-matcher-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Batch — Core de Reconciliación]" vertex="1">
          <mxGeometry height="14" width="340" x="460" y="403" as="geometry" />
        </mxCell>
        <mxCell id="rec-matcher-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Lógica de cuadre:&lt;br&gt;1. Lee transacciones autorizadas del día (Oracle)&lt;br&gt;2. Lee registros de clearing (staging table)&lt;br&gt;3. Match por: card_token + amount + date + auth_code&lt;br&gt;4. Clasifica: MATCHED, UNMATCHED_LOCAL,&lt;br&gt;   UNMATCHED_CLEARING, AMOUNT_MISMATCH&lt;br&gt;5. Genera reporte de diferencias&lt;br&gt;6. Persiste resultado en reconciliation_result table" vertex="1">
          <mxGeometry height="85" width="330" x="465" y="421" as="geometry" />
        </mxCell>
        <mxCell id="rec-oracle" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="120" width="260" x="500" y="600" as="geometry" />
        </mxCell>
        <mxCell id="rec-oracle-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Oracle Database" vertex="1">
          <mxGeometry height="22" width="260" x="500" y="628" as="geometry" />
        </mxCell>
        <mxCell id="rec-oracle-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Oracle 19c+ — Read Replica para queries pesados]" vertex="1">
          <mxGeometry height="14" width="260" x="500" y="650" as="geometry" />
        </mxCell>
        <mxCell id="rec-oracle-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Tablas: clearing_staging, reconciliation_result,&lt;br&gt;reconciliation_exception, settlement_summary.&lt;br&gt;Queries sobre Oracle Read Replica para no&lt;br&gt;impactar el hot-path transaccional." vertex="1">
          <mxGeometry height="48" width="250" x="505" y="668" as="geometry" />
        </mxCell>
        <mxCell id="rec-exception" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DC2626;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="160" width="340" x="880" y="370" as="geometry" />
        </mxCell>
        <mxCell id="rec-exception-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#DC2626;fillColor=none;strokeColor=none;" value="Exception Handler" vertex="1">
          <mxGeometry height="22" width="340" x="880" y="378" as="geometry" />
        </mxCell>
        <mxCell id="rec-exception-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#DC2626;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot — Async Worker]" vertex="1">
          <mxGeometry height="14" width="340" x="880" y="400" as="geometry" />
        </mxCell>
        <mxCell id="rec-exception-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#DC2626;fillColor=none;strokeColor=none;" value="Procesa diferencias encontradas:&lt;br&gt;• UNMATCHED_LOCAL → txn autorizada sin clearing&lt;br&gt;  (posible reverso pendiente o txn del mismo día)&lt;br&gt;• UNMATCHED_CLEARING → clearing sin autorización&lt;br&gt;  (posible fraude o error de procesador)&lt;br&gt;• AMOUNT_MISMATCH → diferencia de montos&lt;br&gt;  (ajuste parcial, conversión de moneda)&lt;br&gt;Genera alertas y escala a operaciones." vertex="1">
          <mxGeometry height="78" width="330" x="885" y="418" as="geometry" />
        </mxCell>
        <mxCell id="rec-settlement" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#059669;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="340" x="920" y="700" as="geometry" />
        </mxCell>
        <mxCell id="rec-settlement-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#059669;fillColor=none;strokeColor=none;" value="Settlement Calculator" vertex="1">
          <mxGeometry height="22" width="340" x="920" y="708" as="geometry" />
        </mxCell>
        <mxCell id="rec-settlement-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#059669;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot — Batch post-reconciliación]" vertex="1">
          <mxGeometry height="14" width="340" x="920" y="730" as="geometry" />
        </mxCell>
        <mxCell id="rec-settlement-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#059669;fillColor=none;strokeColor=none;" value="Calcula posición neta de liquidación:&lt;br&gt;• Total autorizaciones matched&lt;br&gt;• Total comisiones interchange&lt;br&gt;• Neto a recibir/pagar por entidad&lt;br&gt;Genera archivo de liquidación para tesorería.&lt;br&gt;Persiste en settlement_summary table." vertex="1">
          <mxGeometry height="65" width="330" x="925" y="748" as="geometry" />
        </mxCell>
        <mxCell id="rec-dashboard" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="130" width="340" x="880" y="170" as="geometry" />
        </mxCell>
        <mxCell id="rec-dashboard-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Reconciliation Dashboard" vertex="1">
          <mxGeometry height="22" width="340" x="880" y="178" as="geometry" />
        </mxCell>
        <mxCell id="rec-dashboard-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Angular 17+ — Módulo del Portal Administrativo]" vertex="1">
          <mxGeometry height="14" width="340" x="880" y="200" as="geometry" />
        </mxCell>
        <mxCell id="rec-dashboard-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Vista operativa de reconciliación:&lt;br&gt;• Resumen diario: matched vs exceptions&lt;br&gt;• Drill-down por excepción&lt;br&gt;• Resolución manual de diferencias&lt;br&gt;• Histórico de liquidaciones&lt;br&gt;• Exportación de reportes (CSV/PDF)" vertex="1">
          <mxGeometry height="60" width="330" x="885" y="218" as="geometry" />
        </mxCell>
        <mxCell id="rec-edge-1" edge="1" parent="1" source="rec-ext-franchise" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=2;fontSize=8;fontColor=#3B82F6;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="rec-file-ingestion" value="Archivos clearing&lt;br&gt;SFTP / GoAnywhere">
