        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-20" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Oracle Primary" vertex="1">
          <mxGeometry height="22" width="240" x="504" y="915" as="geometry" />
        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-21" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Oracle Database 19c+ — Read/Write]" vertex="1">
          <mxGeometry height="15" width="240" x="504" y="937" as="geometry" />
        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-22" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="&lt;b&gt;Stored Procedures:&lt;/b&gt;&lt;br&gt;SP_AUTHORIZE_TXN: débito atómico (monto+comisión+GMF)&lt;br&gt;SP_CHARGE_TECH_EXITOSA: cobro txn denegadas&lt;br&gt;SP_FALLBACK_READ: lee config si Redis down&lt;br&gt;Tabla transaction particionada por mes." vertex="1">
