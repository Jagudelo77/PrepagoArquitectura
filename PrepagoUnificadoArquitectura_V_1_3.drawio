        <mxCell id="cm-scheduler-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Prepaid_Fee_Scheduler" vertex="1">
          <mxGeometry height="22" width="300" x="80" y="188" as="geometry" />
        </mxCell>
        <mxCell id="cm-scheduler-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot 3 — CronJob OpenShift]" vertex="1">
          <mxGeometry height="14" width="300" x="80" y="215" as="geometry" />
        </mxCell>
        <mxCell id="cm-scheduler-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Ejecuta mensualmente (configurable por grupo de afinidad).&lt;br&gt;Consulta tarjetas activas con cuota pendiente.&lt;br&gt;Genera lote de cobros y dispara el Fee Processor.&lt;br&gt;Cron: 0 2 1 * * (1er día del mes, 2:00 AM)" vertex="1">
          <mxGeometry height="60" width="290" x="85" y="233" as="geometry" />
        </mxCell>
        <mxCell id="cm-processor" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="130" width="340" x="460" y="180" as="geometry" />
        </mxCell>
        <mxCell id="cm-processor-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Prepaid_Fee _Processor" vertex="1">
          <mxGeometry height="22" width="340" x="460" y="188" as="geometry" />
        </mxCell>
        <mxCell id="cm-processor-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Batch — Chunk-oriented processing]" vertex="1">
          <mxGeometry height="14" width="340" x="460" y="210" as="geometry" />
        </mxCell>
        <mxCell id="cm-processor-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Procesa lote de cobros en chunks (100 registros):&lt;br&gt;1. Lee tarjeta + cuenta + config cuota del grupo afinidad&lt;br&gt;2. Calcula monto (cuota base + IVA si aplica)&lt;br&gt;3. Débito atómico UPDATE account SET balance = balance - fee&lt;br&gt;4. INSERT fee_transaction (tipo=MANAGEMENT_FEE)&lt;br&gt;5. Si saldo insuficiente → marca como pendiente" vertex="1">
          <mxGeometry height="68" width="330" x="465" y="228" as="geometry" />
        </mxCell>
        <mxCell id="cm-oracle" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="120" width="260" x="500" y="400" as="geometry" />
        </mxCell>
        <mxCell id="cm-oracle-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Oracle Database" vertex="1">
          <mxGeometry height="22" width="260" x="500" y="428" as="geometry" />
        </mxCell>
        <mxCell id="cm-oracle-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Oracle 19c+ — Shared]" vertex="1">
          <mxGeometry height="14" width="260" x="500" y="450" as="geometry" />
        </mxCell>
        <mxCell id="cm-oracle-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Tablas: fee_schedule, fee_transaction, account (balance).&lt;br&gt;fee_config por affinity_group (monto, periodicidad, IVA).&lt;br&gt;Constraint: no permite balance negativo." vertex="1">
          <mxGeometry height="40" width="250" x="505" y="468" as="geometry" />
        </mxCell>
        <mxCell id="cm-notifier" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="240" x="940" y="185" as="geometry" />
