        <mxCell id="S102A3fR_j41dhUKZe1R-13" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Batch — CronJob OpenShift]" vertex="1">
          <mxGeometry height="14" width="340" x="706" y="585" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-14" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Lee archivos de GAW, parsea registros, invoca&lt;br&gt;el Card Creation Orchestrator por cada registro.&lt;br&gt;Genera archivo de respuesta al finalizar.&lt;br&gt;Tracking de estado por registro (OK/ERROR)." vertex="1">
          <mxGeometry height="58" width="330" x="711" y="604" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
