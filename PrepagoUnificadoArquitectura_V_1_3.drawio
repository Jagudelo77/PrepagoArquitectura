          <mxGeometry height="22" width="340" x="1436" y="797.5" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-44" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Component: Spring WebClient — Resilience4j Circuit Breaker + Retry]" vertex="1">
          <mxGeometry height="14" width="340" x="1436" y="819.5" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-45" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Cliente HTTP unificado para todas las APIs de Pomelo:&lt;br&gt;• GET /affinity-groups/{id}&lt;br&gt;• GET /clients/{docType}/{docNumber}&lt;br&gt;• POST /clients&lt;br&gt;• POST /cards&lt;br&gt;Circuit breaker, retry con backoff, timeout 5s." vertex="1">
          <mxGeometry height="65" width="330" x="1441" y="837.5" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-46" edge="1" parent="1" source="S102A3fR_j41dhUKZe1R-20" style="endArrow=block;endFill=1;html=1;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=8;fontColor=#60A5FA;align=center;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="S102A3fR_j41dhUKZe1R-42" value="">
