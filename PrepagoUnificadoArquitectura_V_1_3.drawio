        <mxCell id="rec-ext-franchise-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Sistema Externo]&lt;br&gt;&lt;br&gt;Genera archivos de clearing diarios:&lt;br&gt;• TC (Transaction Clearing) files&lt;br&gt;• Settlement reports&lt;br&gt;• Chargeback/dispute files" vertex="1">
          <mxGeometry height="75" width="270" x="85" y="200" as="geometry" />
        </mxCell>
        <mxCell id="rec-file-ingestion" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;" value="" vertex="1">
          <mxGeometry height="120" width="340" x="460" y="170" as="geometry" />
        </mxCell>
        <mxCell id="rec-file-ingestion-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Clearing File Ingestion" vertex="1">
          <mxGeometry height="22" width="340" x="460" y="178" as="geometry" />
        </mxCell>
        <mxCell id="rec-file-ingestion-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Batch — CronJob OpenShift]" vertex="1">
          <mxGeometry height="14" width="340" x="460" y="200" as="geometry" />
        </mxCell>
        <mxCell id="rec-file-ingestion-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Recibe archivos de clearing vía SFTP/GoAnywhere.&lt;br&gt;Parsea formato franquicia (ISO 8583 / propietario).&lt;br&gt;Normaliza registros e inserta en staging table.&lt;br&gt;Cron: 0 5 * * * (5:00 AM diario, post-clearing)" vertex="1">
          <mxGeometry height="55" width="330" x="465" y="218" as="geometry" />
        </mxCell>
        <mxCell id="rec-file-storage" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
          <mxGeometry height="100" width="220" x="80" y="350" as="geometry" />
        </mxCell>
        <mxCell id="rec-file-storage-title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="File Storage" vertex="1">
