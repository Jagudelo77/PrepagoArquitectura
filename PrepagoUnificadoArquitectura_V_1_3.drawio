          <mxGeometry height="14" width="340" x="460" y="630" as="geometry" />
        </mxCell>
        <mxCell id="cm-retry-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#D97706;fillColor=none;strokeColor=none;" value="Reintenta cobros fallidos por saldo insuficiente.&lt;br&gt;Ejecuta diariamente hasta max 3 reintentos.&lt;br&gt;Si falla 3 veces → marca tarjeta para revisión.&lt;br&gt;Cron: 0 3 * * * (3:00 AM diario)" vertex="1">
