          <mxGeometry height="14" width="240" x="940" y="210" as="geometry" />
        </mxCell>
        <mxCell id="cm-notifier-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Genera reporte de cobros ejecutados.&lt;br&gt;Notifica cobros fallidos (saldo insuficiente).&lt;br&gt;Envía resumen al portal administrativo.&lt;br&gt;Registra auditoría del proceso." vertex="1">
