          <mxGeometry height="25" width="480" x="380" y="558" as="geometry" />
        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-13" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot 3 + WebFlux — 3 pods, HPA max=8]" vertex="1">
          <mxGeometry height="15" width="480" x="380" y="582" as="geometry" />
        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-14" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="&lt;b&gt;Pipeline:&lt;/b&gt; 1.Resuelve tarjeta(Oracle) → 2.Lee AFG config(Redis→Oracle fallback) → 3.Valida estado →&lt;br&gt;4.CHECK límites(Limit Counter) → 5.Reglas negocio → 6.Calcula comisión(red+canal+exentas) →&lt;br&gt;7.Calcula GMF(si entidad=línea y tarjeta no exenta) → 8.SP_AUTHORIZE_TXN(débito atómico) →&lt;br&gt;9.INCREMENT contadores → 10.Response code. &lt;b&gt;Si denegada(51,55,57,61,75):&lt;/b&gt; SP_CHARGE_TECH_EXITOSA" vertex="1">
          <mxGeometry height="55" width="460" x="390" y="602" as="geometry" />
        </mxCell>
        <mxCell id="L-JxTnSPuCsDWRgZwE4I-19" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;size=12;" value="" vertex="1">
