        <mxCell id="limit-counter-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#D97706;fillColor=none;strokeColor=none;" value="[Container: Java 21 + Spring Boot 3]" vertex="1">
