        <mxCell id="cs-bd-ent" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7F1D1D;strokeColor=#7F1D1D;strokeWidth=2;arcSize=12;fontStyle=1;fontSize=10;fontColor=#FFFFFF;" value="BLOQ DEF&#xa;(Entidad)" vertex="1">
