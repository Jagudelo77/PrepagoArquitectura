        <mxCell id="nota-pci-cifrado" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#991B1B;fontStyle=1;" value="PCI DSS v4.0 — ALMACENAMIENTO:&lt;br&gt;&lt;br&gt;✅ PAN: cifrado AES-256-GCM (Req 3.5)&lt;br&gt;✅ PAN hash: SHA-256 para búsquedas&lt;br&gt;✅ Last 4: en claro (permitido Req 3.3)&lt;br&gt;✅ BIN: en claro (dato público)&lt;br&gt;✅ Exp date: cifrado o claro&lt;br&gt;✅ Card token: en claro (no es PAN)&lt;br&gt;&lt;br&gt;❌ CVV2: PROHIBIDO almacenar (Req 3.3.2)&lt;br&gt;   Se descarta inmediatamente&lt;br&gt;   Para visualización: consulta Pomelo&lt;br&gt;   en tiempo real (API call)" vertex="1">
          <mxGeometry height="180" width="250" x="330" y="950" as="geometry" />
        </mxCell>
        <mxCell id="S102A3fR_j41dhUKZe1R-42" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#3B82F6;strokeWidth=2;arcSize=8;pointerEvents=0;align=center;verticalAlign=top;fontFamily=Helvetica;fontSize=12;fontColor=default;gradientColor=none;" value="" vertex="1">
          <mxGeometry height="131" width="340" x="1436" y="789.5" as="geometry" />
