          <mxGeometry height="22" width="240" x="1374" y="1019" as="geometry" />
        </mxCell>
        <mxCell id="hsm-create-tech" parent="1" style="text;html=1;fontSize=8;align=center;verticalAlign=middle;fontColor=#5a3d00;fillColor=none;strokeColor=none;" value="[Hardware Security Module — CDE]" vertex="1">
          <mxGeometry height="14" width="240" x="1374" y="1041" as="geometry" />
        </mxCell>
        <mxCell id="hsm-create-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#5a3d00;fillColor=none;strokeColor=none;" value="Cmd M0: Cifra PAN → AES-256-GCM&lt;br&gt;Llave de datos custodiada bajo LMK&lt;br&gt;PAN en claro solo en RAM del HSM&lt;br&gt;Cmd M2: Descifra PAN (para visualización)" vertex="1">
          <mxGeometry height="55" width="230" x="1379" y="1059" as="geometry" />
        </mxCell>
        <mxCell id="e-orch-hsm" edge="1" parent="1" source="S102A3fR_j41dhUKZe1R-20" style="endArrow=block;endFill=1;html=1;strokeColor=#d6b656;strokeWidth=2;fontSize=8;fontColor=#5a3d00;align=center;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="hsm-create" value="6. Cifra PAN (cmd M0)&#xa;AES-256-GCM bajo LMK">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1394" y="909" />
              <mxPoint x="1394" y="986" />
