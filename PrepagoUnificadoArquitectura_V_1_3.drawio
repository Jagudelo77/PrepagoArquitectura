        <mxCell id="S102A3fR_j41dhUKZe1R-34" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="[Sistema Externo]&lt;br&gt;&lt;br&gt;• GET /affinity-groups/{id}&lt;br&gt;• GET /clients/{docType}/{docNumber}&lt;br&gt;• POST /clients&lt;br&gt;• POST /cards&lt;br&gt;• GET /cards/{id}/sensitive-data (PAN+exp+CVV2)" vertex="1">
