        <mxCell id="nota-pipeline" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ECFDF5;strokeColor=#10B981;fontSize=9;fontColor=#065F46;" value="COMISIÓN (paso 6):&#xa;Parametría AFG en Redis:&#xa;network_type + channel + txn_type&#xa;+ exempt_count + commission_value&#xa;IF contador ≤ exempt → $0&#xa;ELSE → commission_value&#xa;Se suma al débito atómico en SP" vertex="1">
          <mxGeometry height="110" width="200" x="30" y="550" as="geometry" />
        </mxCell>
        <mxCell id="nota-gmf" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ECFDF5;strokeColor=#10B981;fontSize=9;fontColor=#065F46;" value="GMF (paso 7):&#xa;Si entidad.gmf_mode = LINEA&#xa;Y tarjeta.gmf_exenta = N&#xa;→ Calcula 4x1000 sobre monto&#xa;→ Se suma al débito atómico&#xa;Si entidad.gmf_mode = BATCH&#xa;→ Se omite (cobro posterior)" vertex="1">
          <mxGeometry height="110" width="200" x="30" y="680" as="geometry" />
        </mxCell>
        <mxCell id="nota-tech-exit" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#991B1B;" value="TX TÉCNICAMENTE EXITOSA:&#xa;Si response_code IN (51,55,57,61,75)&#xa;Y regla TECH_EXITOSA activa en AFG:&#xa;→ SP_CHARGE_TECH_EXITOSA&#xa;→ Débito: valor fijo o según tabla&#xa;→ INSERT txn tipo=TECH_EXITOSA&#xa;No incrementa contadores de límite" vertex="1">
          <mxGeometry height="110" width="200" x="30" y="810" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
