        <mxCell id="fe-nota-pci-files" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#991B1B;fontStyle=1;" value="PCI DSS — ARCHIVOS CON PAN:&lt;br&gt;&lt;br&gt;Flujo: OFG descifra PAN (HSM cmd M2)&lt;br&gt;→ Genera archivo plano en NFS /output&lt;br&gt;→ GoAnywhere detecta archivo&lt;br&gt;→ Cifra con PGP (llave pública entidad)&lt;br&gt;→ Borra archivo plano original&lt;br&gt;→ Entrega .pgp vía SFTP a entidad&lt;br&gt;&lt;br&gt;Controles PCI:&lt;br&gt;• NFS /output dentro del CDE&lt;br&gt;• Permisos: solo OFG escribe, solo GAW lee&lt;br&gt;• Archivo plano temporal (segundos)&lt;br&gt;• GAW borra plano después de cifrar&lt;br&gt;• PAN en memoria Java solo durante escritura" vertex="1">
          <mxGeometry height="220" width="240" x="1670" y="1260" as="geometry" />
