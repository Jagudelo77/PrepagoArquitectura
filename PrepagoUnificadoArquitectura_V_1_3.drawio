        <mxCell id="cs-note" parent="1" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fontColor=#374151;fillColor=#F3F4F6;strokeColor=#D1D5DB;rounded=1;spacingLeft=8;spacingRight=8;spacingTop=6;" value="&lt;b&gt;Transiciones reversibles (desbloqueo):&lt;/b&gt;&lt;br&gt;• BLOQ_TEMP(Cli) → ACTIVA (TH desbloquea por Portal)&lt;br&gt;• BLOQ_TEMP(Ent) → ACTIVA (Entidad desbloquea por Archivo/API)&lt;br&gt;• BLOQ_PIN → ACTIVA (Reset PIN por Admin/Entidad)&lt;br&gt;&lt;br&gt;&lt;b&gt;Irreversibles:&lt;/b&gt;&lt;br&gt;• BLOQ_DEF → solo puede ir a RETIRADA (cuando saldo=0)&lt;br&gt;• EXPIRADA y RETIRADA son estados terminales&lt;br&gt;&lt;br&gt;&lt;b&gt;Mapeo Pomelo:&lt;/b&gt; BLOQ_TEMP → Bloqueado | BLOQ_DEF → Deshabilitado&lt;br&gt;&lt;b&gt;Regla:&lt;/b&gt; No crear tarjeta si existe otra en estado ≠ RETIRADA/EXPIRADA en mismo AFG+UserID" vertex="1">
          <mxGeometry height="170" width="420" x="700" y="150" as="geometry" />
        </mxCell>
