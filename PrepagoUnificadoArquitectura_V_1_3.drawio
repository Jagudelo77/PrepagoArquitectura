        <mxCell id="limit-counter-desc" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#D97706;fillColor=none;strokeColor=none;" value="Contadores por tarjeta en Redis:&lt;br&gt;• Qty/Monto retiros diarios (ATM)&lt;br&gt;• Qty/Monto compras diarias (POS)&lt;br&gt;• PIN errado • Utilizaciones&lt;br&gt;CHECK / INCREMENT / RESET&lt;br&gt;TTL = fin período (auto-reinicio)" vertex="1">
          <mxGeometry height="70" width="230" x="1010" y="712" as="geometry" />
        </mxCell>
        <mxCell id="e-engine-limit" edge="1" parent="1" source="L-JxTnSPuCsDWRgZwE4I-11" style="endArrow=block;endFill=1;html=1;strokeColor=#D97706;strokeWidth=1.5;fontSize=8;fontColor=#D97706;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" target="limit-counter-svc" value="4.CHECK límites&#xa;9.INCREMENT">
