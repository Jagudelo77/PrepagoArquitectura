        <mxCell id="2QuNeFU_GCBFWjPr9n5C-21" parent="1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#3B82F6;fillColor=none;strokeColor=none;" value="Backenddel portal admin:&lt;br&gt;• Administracion de Affinity Groupo&lt;br&gt;• Auditoría&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• /entities — CRUD Entidades (código compensación, feeID, Client ID Pomelo, GMF línea/batch)&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• /bins — CRUD BINes (tipo BIN, activar/desactivar, siembra de llaves)&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• /afg/{id}/business-rules — CRUD Reglas de Negocio (~30 reglas parametrizables)&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• /afg/{id}/validation-plans — CRUD Planes Validación (MCC/CU, carga masiva 20K)&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• /afg/{id}/commissions — CRUD Comisiones (red, canal, tipo trx, exentas, valor)&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• /afg/{id}/taxes — CRUD Impuestos (tipo trx, canal, tabla impuestos)&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• /afg/{id}/tech-successful-txn — CRUD Trx Técnicamente Exitosas&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• /afg/{id}/management-fee — CRUD Cuota de Manejo&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• Auditoría transversal (fecha, usuario, cambios)&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="161" width="330" x="-1011" y="-421" as="geometry" />
        </mxCell>
