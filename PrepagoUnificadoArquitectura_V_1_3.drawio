        <mxCell id="WYurlSI6gKorOprcLl8n-18" parent="WYurlSI6gKorOprcLl8n-1" style="text;html=1;fontSize=9;align=center;verticalAlign=top;fontColor=#2CA02C;fillColor=none;strokeColor=none;" value="• Consulta de saldo en tiempo real&lt;br&gt;• Historial de movimientos (filtrado)&lt;br&gt;• Bloqueo / Desbloqueo de tarjeta&lt;br&gt;• Actualización de datos personales&lt;br&gt;• Descarga de extracto (PDF)&amp;nbsp;&lt;br&gt;• Cambio de PIN (delegado a Credibanco Iframe)&lt;br&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;•&amp;nbsp;&lt;/span&gt;Activar Tarjeta&lt;br&gt;• Datos de tarjeta (last4, vencimiento)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
