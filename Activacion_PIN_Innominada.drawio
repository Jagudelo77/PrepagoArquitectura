        <mxCell id="f3_title" parent="1" style="text;html=1;strokeColor=#cccccc;fillColor=#f0f0f0;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=10;fontColor=#555555;" value="FASE 3 — Verificación OK: micro-portal carga Iframe PIN (secure-pin.credibanco.com) — mismo componente que portal TH nominadas" vertex="1">
          <mxGeometry height="22" width="1400" x="30" y="864" as="geometry" />
        </mxCell>
        <mxCell id="f3_b1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Micro-portal carga iframe:&#xa;&lt;iframe src=secure-pin.credibanco.com&gt;&#xa;postMessage { cardId, sessionToken }&#xa;Iframe solicita pubKey al backend&#xa;Backend → HSM cmd EI (RSA-2048)" vertex="1">
          <mxGeometry height="55" width="220" x="650" y="899" as="geometry" />
        </mxCell>
        <mxCell id="f3_hsm1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Cmd EI: Genera par RSA-2048&#xa;Resp EJ: pubKey(DER) +&#xa;privKey(cifrada bajo LMK)&#xa;HSM es stateless — no retiene" vertex="1">
          <mxGeometry height="65" width="220" x="945" y="892" as="geometry" />
        </mxCell>
        <mxCell id="f3_b2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Guarda en Redis (TTL 5 min):&#xa;session_pin ↔ privKey(cifrada_LMK)&#xa;Retorna { pubKey_PEM, nonce }&#xa;al micro-portal" vertex="1">
          <mxGeometry height="65" width="220" x="650" y="984" as="geometry" />
        </mxCell>
        <mxCell id="f3_mp1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#8B5CF6;fontSize=10;strokeWidth=2;" value="IFRAME PIN (secure-pin.credibanco.com)&#xa;importRsaPublicKey(pubKey_PEM)&#xa;SubtleCrypto.importKey(&#39;spki&#39;)&#xa;No exportable — solo [&#39;encrypt&#39;]" vertex="1">
          <mxGeometry height="55" width="240" x="342" y="984" as="geometry" />
        </mxCell>
        <mxCell id="f3_mp2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#8B5CF6;fontSize=10;strokeWidth=2;" value="IFRAME: Teclado PIN enmascarado&#xa;autocomplete=off, oncopy blocked&#xa;Timeout 30s inactividad → clear&#xa;Máx 3 intentos → invalida sesión" vertex="1">
          <mxGeometry height="65" width="240" x="342" y="1064" as="geometry" />
        </mxCell>
        <mxCell id="f3_th1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=10;fontStyle=1;" value="TH digita su PIN (4-6 dígitos)&#xa;y lo confirma en el iframe" vertex="1">
          <mxGeometry height="45" width="240" x="50" y="1074" as="geometry" />
        </mxCell>
        <mxCell id="f3_mp3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#8B5CF6;fontSize=10;" value="IFRAME: Construye bloque PIN:&#xa;{ pin, nonce, timestamp }&#xa;SubtleCrypto.encrypt(RSA-OAEP)&#xa;→ ciphertext_HSM" vertex="1">
          <mxGeometry height="65" width="240" x="343" y="1154" as="geometry" />
        </mxCell>
