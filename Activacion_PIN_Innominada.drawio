          <mxGeometry height="22" width="1400" x="30" y="440" as="geometry" />
        </mxCell>
        <mxCell id="f2_mp1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Formulario de verificación:&#xa;• Entidad emisora (desplegable)&#xa;• Últimos 4 dígitos del PAN&#xa;• Fecha de vencimiento (MM/AA)&#xa;• CVV2 (3 dígitos reverso)&#xa;autocomplete=off en todos" vertex="1">
          <mxGeometry height="90" width="240" x="350" y="619" as="geometry" />
        </mxCell>
        <mxCell id="f2_th1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=10;" value="TH mira su tarjeta física&#xa;Ingresa los datos solicitados&#xa;Presiona &quot;Verificar tarjeta&quot;" vertex="1">
          <mxGeometry height="55" width="240" x="35" y="634" as="geometry" />
        </mxCell>
        <mxCell id="f2_mp2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="POST /api/activation/verify&#xa;{ entity_code, last4, exp,&#xa;  cvv2, captcha_token }&#xa;TLS 1.3" vertex="1">
          <mxGeometry height="65" width="240" x="350" y="734" as="geometry" />
        </mxCell>
        <mxCell id="f2_b1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="Valida CAPTCHA (anti-bot)&#xa;Busca en Oracle:&#xa;entity + BIN(del entity) + last4&#xa;+ exp + cvv2_hash&#xa;Verifica: status = PEND_ACTIVAR&#xa;Verifica: intentos &lt; 3&#xa;Verifica: token no expirado" vertex="1">
