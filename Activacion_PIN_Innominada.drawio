        <mxCell id="e_f5_1" edge="1" parent="1" source="f4_p1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=1.5;dashed=1;fontSize=9;fontColor=#059669;" target="f5_b1" value="{ status: OK }">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1310" y="1682" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_f5_2" edge="1" parent="1" source="f5_b1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=1.5;dashed=1;" target="f5_mp1" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_f5_3" edge="1" parent="1" source="f5_mp1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=1.5;dashed=1;" target="f5_th1" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="nota_seguridad" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#b85450;fontStyle=1;" value="SEGURIDAD — Proof of Possession:&#xa;&#xa;Para activar se necesita:&#xa;• Entidad emisora (público pero filtra)&#xa;• Últimos 4 dígitos PAN (10,000 combinaciones)&#xa;• Fecha vencimiento (36-60 combinaciones)&#xa;• CVV2 (1,000 combinaciones)&#xa;&#xa;Con max 3 intentos → probabilidad&#xa;de fuerza bruta ≈ 0.000000083%&#xa;&#xa;Rate limiting adicional:&#xa;• 5 intentos / IP / hora&#xa;• CAPTCHA obligatorio&#xa;• Bloqueo permanente tras 3 fallos&#xa;  (requiere canal presencial)" vertex="1">
          <mxGeometry height="230" width="220" x="1450" y="100" as="geometry" />
        </mxCell>
        <mxCell id="nota_pci" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontColor=#b85450;" value="PCI DSS v4.0 COMPLIANCE:&#xa;&#xa;• Micro-portal NO captura PAN completo&#xa;  → fuera de scope CDE&#xa;• Solo captura: last4 + exp + CVV2&#xa;  (datos impresos, no track data)&#xa;• PIN cifrado E2E con SubtleCrypto&#xa;  → nunca en claro fuera del HSM&#xa;• CSP + SRI obligatorios (Req 6.4.3)&#xa;• TLS 1.3 en todo el flujo&#xa;• mTLS en canal HSM (Req 4.2.1)&#xa;• Nonce anti-replay en bloque PIN&#xa;• Idempotencia en llamada a Pomelo" vertex="1">
          <mxGeometry height="200" width="220" x="1450" y="350" as="geometry" />
        </mxCell>
        <mxCell id="nota_diferencia" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#E6E6FA;strokeColor=#9370DB;fontSize=9;fontColor=#4B0082;" value="DIFERENCIA vs TARJETA NOMINADA:&#xa;&#xa;Nominada:&#xa;  Auth: SSO + MFA (usuario conocido)&#xa;  Canal: Portal TH autenticado&#xa;  Sesión: JWT con refresh&#xa;&#xa;Innominada:&#xa;  Auth: Proof of Possession&#xa;  (last4 + exp + CVV2)&#xa;  Canal: Micro-portal público efímero&#xa;  Sesión: session_pin TTL 5 min&#xa;  Sin refresh, sin cookies&#xa;&#xa;Flujo de PIN: IDÉNTICO en ambos casos&#xa;(SubtleCrypto → HSM EI/GI/EO → Pomelo)" vertex="1">
          <mxGeometry height="240" width="220" x="1450" y="714" as="geometry" />
        </mxCell>
        <mxCell id="nota_errores" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#FFFBEB;strokeColor=#D97706;fontSize=9;fontColor=#92400E;" value="FLUJO DE ERRORES:&#xa;&#xa;• Datos tarjeta incorrectos (3x)&#xa;  → Bloqueo activación digital&#xa;  → TH debe ir a canal presencial&#xa;&#xa;• Token expirado (6 meses)&#xa;  → Mensaje: contacte a su entidad&#xa;&#xa;• Tarjeta ya activada&#xa;  → Mensaje: tarjeta ya está activa&#xa;&#xa;• HSM timeout&#xa;  → Invalida sesión, reintento manual&#xa;&#xa;• Pomelo error&#xa;  → idempotencyKey protege&#xa;  → TH puede reintentar" vertex="1">
          <mxGeometry height="230" width="220" x="1450" y="974" as="geometry" />
        </mxCell>
        <mxCell id="nota_thales" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontColor=#5a3d00;" value="THALES payShield COMMANDS:&#xa;&#xa;• EI/EJ: Generate RSA Key Pair&#xa;• GI/GJ: RSA Decrypt (privKey bajo LMK)&#xa;• EO/EP: RSA Encrypt (pubKey Pomelo)&#xa;• FK/FL: Load Public RSA Key&#xa;&#xa;HSM es STATELESS:&#xa;privKey sale cifrada bajo LMK&#xa;Backend la guarda en Redis (TTL 5m)&#xa;Solo el HSM puede descifrarla" vertex="1">
          <mxGeometry height="170" width="220" x="1450" y="1224" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
